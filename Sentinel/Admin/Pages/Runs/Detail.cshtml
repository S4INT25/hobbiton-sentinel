@page "/admin/runs/{runId}"
@model Sentinel.Admin.Pages.Runs.DetailModel
@{
    ViewData["Title"] = $"Run {Model.RunId}";
    ViewData["Nav"] = "runs";
}

<div class="space-y-4">
    <div class="flex items-center gap-3">
        <a href="/admin/runs" class="text-gray-500 hover:text-gray-300 text-sm">← Runs</a>
        <h1 class="text-lg font-semibold text-white font-mono">@Model.RunId</h1>
        @if (Model.Summary != null)
        {
            <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium
                @(Model.Summary.Status == "completed" ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" : "bg-amber-500/10 text-amber-400 border border-amber-500/20")">
                @Model.Summary.Status
            </span>
        }
    </div>

    @if (Model.Summary != null)
    {
        <div class="grid grid-cols-6 gap-3 text-xs">
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Started</div>
                <div class="text-white font-mono">@Model.Summary.StartedAt.ToString("HH:mm:ss")</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Duration</div>
                <div class="text-white font-mono">@($"{(Model.Summary.FinishedAt - Model.Summary.StartedAt).TotalMinutes:F1}m")</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Iterations</div>
                <div class="text-white font-mono">@Model.Summary.Iterations</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Input Tokens</div>
                <div class="text-white font-mono">@Model.Summary.InputTokens.ToString("N0")</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Output Tokens</div>
                <div class="text-white font-mono">@Model.Summary.OutputTokens.ToString("N0")</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Triggered By</div>
                <div class="text-white">@Model.Summary.TriggeredBy</div>
            </div>
        </div>
    }

    <!-- Tool call timeline -->
    <h2 class="text-sm font-medium text-gray-400">Tool Calls</h2>
    <div class="space-y-2">
        @foreach (var log in Model.Logs)
        {
            <div class="border border-gray-800 rounded-lg overflow-hidden" x-data="{ open: false }">
                <button @@click="open = !open" class="w-full flex items-center justify-between px-4 py-2.5 hover:bg-gray-900/50 transition-colors text-left">
                    <div class="flex items-center gap-3">
                        <span class="text-[10px] font-mono text-gray-600">@log.Iteration</span>
                        <span class="text-xs font-medium text-emerald-400 font-mono">@log.ToolName</span>
                        <span class="text-xs text-gray-500">@(log.DurationMs)ms</span>
                    </div>
                    <span class="text-xs text-gray-600 font-mono">@log.StartedAt.ToString("HH:mm:ss.fff")</span>
                </button>
                <div x-show="open" x-cloak class="border-t border-gray-800 bg-gray-900/30">
                    <div class="p-3">
                        <div class="text-[10px] text-gray-500 mb-1 uppercase tracking-wider">Arguments</div>
                        <pre class="text-xs text-gray-300 font-mono whitespace-pre-wrap break-all max-h-40 overflow-y-auto">@log.Args</pre>
                    </div>
                    <div class="p-3 border-t border-gray-800/50">
                        <div class="text-[10px] text-gray-500 mb-1 uppercase tracking-wider">Result</div>
                        <pre class="text-xs text-gray-300 font-mono whitespace-pre-wrap break-all max-h-60 overflow-y-auto">@log.Result</pre>
                    </div>
                </div>
            </div>
        }
        @if (!Model.Logs.Any())
        {
            <div class="text-center py-8 text-gray-600 text-xs">No tool calls recorded for this run</div>
        }
    </div>
</div>
