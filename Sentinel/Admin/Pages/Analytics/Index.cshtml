@page "/admin/analytics"
@model Sentinel.Admin.Pages.Analytics.IndexModel
@{
    ViewData["Title"] = "Analytics";
    ViewData["Nav"] = "analytics";
}

<div class="flex h-[calc(100vh-6rem)]" x-data="analyticsChat()">
    <!-- Conversation Sidebar -->
    <div class="w-56 border-r border-gray-800 flex flex-col shrink-0">
        <div class="flex items-center justify-between px-3 py-2 border-b border-gray-800">
            <span class="text-xs font-medium text-gray-400">History</span>
            <button @@click="newConversation()" class="px-2 py-1 text-[10px] bg-emerald-600 hover:bg-emerald-500 text-white rounded transition-colors">+ New</button>
        </div>
        <div class="flex-1 overflow-y-auto p-1.5 space-y-0.5">
            <template x-for="conv in conversations" :key="conv.id">
                <div @@click="loadConversation(conv.id)"
                     :class="conv.id === activeConversationId ? 'bg-gray-800/60 border-emerald-500/30' : 'border-transparent hover:bg-gray-900'"
                     class="px-2.5 py-2 rounded border cursor-pointer group transition-colors">
                    <div class="text-xs text-gray-300 truncate" x-text="conv.title"></div>
                    <div class="flex items-center justify-between mt-0.5">
                        <span class="text-[10px] text-gray-600" x-text="conv.database"></span>
                        <button @@click.stop="deleteConversation(conv.id)" class="opacity-0 group-hover:opacity-100 text-[10px] text-rose-500 hover:text-rose-400 transition-opacity">✕</button>
                    </div>
                </div>
            </template>
            <div x-show="conversations.length === 0" class="px-3 py-4 text-center text-[10px] text-gray-600">No conversations yet</div>
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="flex-1 flex flex-col min-w-0">
        <div class="flex items-center justify-between px-4 py-2 border-b border-gray-800">
            <div class="flex items-center gap-3">
                <select x-model="database" @@change="onDatabaseChange()" class="px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                    <option value="" disabled>Loading databases...</option>
                    <template x-for="db in databases" :key="db">
                        <option :value="db" x-text="db"></option>
                    </template>
                </select>
                <span x-show="Object.keys(activePolls).length > 0" class="flex items-center gap-1.5 text-[10px] text-emerald-400">
                    <svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                    Query running
                </span>
            </div>
            <button @@click="clearChat()" class="px-2.5 py-1.5 text-xs text-gray-500 hover:text-gray-300 border border-gray-800 rounded hover:bg-gray-900 transition-colors">
                Clear
            </button>
        </div>

        <!-- Chat Messages -->
        <div class="flex-1 overflow-y-auto space-y-4 p-4 pr-1" x-ref="messages">
            <template x-for="(msg, idx) in messages" :key="idx">
                <div>
                    <!-- User message -->
                    <template x-if="msg.role === 'user'">
                        <div class="flex justify-end">
                            <div class="max-w-2xl px-3 py-2 bg-emerald-600/20 border border-emerald-500/20 rounded-lg text-sm text-gray-200">
                                <span x-text="msg.content"></span>
                            </div>
                        </div>
                    </template>

                    <!-- Assistant message -->
                    <template x-if="msg.role === 'assistant'">
                        <div class="space-y-3 max-w-full">
                            <!-- Thinking (collapsible) -->
                            <template x-if="msg.thinking">
                                <details class="text-xs">
                                    <summary class="text-gray-500 cursor-pointer hover:text-gray-400">Reasoning</summary>
                                    <div class="mt-1 p-2 bg-gray-900/50 border border-gray-800/50 rounded text-gray-500 italic" x-text="msg.thinking"></div>
                                </details>
                            </template>

                            <!-- Explanation -->
                            <template x-if="msg.explanation">
                                <div class="text-sm text-gray-300" x-text="msg.explanation"></div>
                            </template>

                            <!-- Error -->
                            <template x-if="msg.error">
                                <div class="p-3 bg-rose-500/10 border border-rose-500/20 rounded-lg text-xs text-rose-400 font-mono whitespace-pre-wrap" x-text="msg.error"></div>
                            </template>

                            <!-- Chart -->
                            <template x-if="msg.chartType && msg.chartType !== 'none' && msg.rows && msg.rows.length > 0">
                                <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/30">
                                    <canvas :id="'chart-' + idx" class="max-h-64 w-full"></canvas>
                                    <template x-if="true" x-effect="renderChart(idx, msg)"></template>
                                </div>
                            </template>

                            <!-- Table -->
                            <template x-if="msg.columns && msg.columns.length > 0 && msg.rows && msg.rows.length > 0">
                                <div class="border border-gray-800 rounded-lg overflow-hidden">
                                    <div class="overflow-x-auto">
                                        <table class="w-full text-xs">
                                            <thead class="bg-gray-900/70 sticky top-0">
                                                <tr>
                                                    <template x-for="col in msg.columns" :key="col">
                                                        <th class="text-left px-3 py-2 font-medium text-gray-500 border-b border-gray-800 whitespace-nowrap" x-text="col"></th>
                                                    </template>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-gray-800/50">
                                                <template x-for="(row, rIdx) in msg.rows" :key="rIdx">
                                                    <tr class="hover:bg-gray-900/30">
                                                        <template x-for="col in msg.columns" :key="col">
                                                            <td class="px-3 py-1.5 text-gray-300 font-mono whitespace-nowrap" x-text="formatCell(row[col])"></td>
                                                        </template>
                                                    </tr>
                                                </template>
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="px-3 py-1.5 bg-gray-900/50 border-t border-gray-800 text-[10px] text-gray-600 flex items-center justify-between">
                                        <span><span x-text="msg.rowCount"></span> rows</span>
                                        <span x-text="`${(msg.inputTokens + msg.outputTokens).toLocaleString()} tokens`"></span>
                                    </div>
                                </div>
                            </template>

                            <!-- SQL (collapsible) -->
                            <template x-if="msg.sql">
                                <details class="text-xs">
                                    <summary class="text-gray-500 cursor-pointer hover:text-gray-400 flex items-center gap-1.5">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                                        View SQL
                                    </summary>
                                    <div class="mt-1 border border-gray-800 rounded-lg overflow-hidden">
                                        <div class="flex items-center justify-between px-3 py-1.5 bg-gray-900/70 border-b border-gray-800">
                                            <span class="text-[10px] text-gray-500 uppercase tracking-wider">SQL</span>
                                            <button @@click="copyText(msg.sql)" class="text-[10px] text-gray-600 hover:text-gray-400">Copy</button>
                                        </div>
                                        <pre class="p-3 text-xs text-emerald-300 font-mono whitespace-pre-wrap bg-gray-950" x-text="msg.sql"></pre>
                                    </div>
                                </details>
                            </template>
                        </div>
                    </template>
                </div>
            </template>

            <!-- Loading -->
            <template x-if="loading">
                <div class="flex items-center gap-2 text-xs text-gray-500">
                    <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                    Running query...
                </div>
            </template>
        </div>

        <!-- Input -->
        <div class="border-t border-gray-800 p-3">
            <form @@submit.prevent="send()" class="flex gap-2">
                <input type="text" x-model="input" placeholder="Ask about your data... e.g. 'Top 10 merchants by volume this week'"
                       :disabled="loading"
                       @@keydown.enter="send()"
                       class="flex-1 px-3 py-2.5 bg-gray-900 border border-gray-800 rounded-lg text-sm text-white placeholder-gray-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 disabled:opacity-50" />
                <button type="submit" :disabled="loading || !input.trim() || !database"
                        class="px-4 py-2.5 bg-emerald-600 hover:bg-emerald-500 disabled:bg-gray-800 disabled:text-gray-600 text-white text-sm font-medium rounded-lg transition-colors">
                    Ask
                </button>
            </form>
            <div class="mt-2 flex flex-wrap gap-2">
                <button @@click="quickAsk('Top 10 merchants by disbursement volume today')"
                        class="px-2 py-1 text-[10px] text-gray-500 border border-gray-800 rounded hover:bg-gray-900 hover:text-gray-300 transition-colors">
                    Top merchants today
                </button>
                <button @@click="quickAsk('Hourly transaction count for the last 24 hours')"
                        class="px-2 py-1 text-[10px] text-gray-500 border border-gray-800 rounded hover:bg-gray-900 hover:text-gray-300 transition-colors">
                    Hourly volume (24h)
                </button>
                <button @@click="quickAsk('Transaction status breakdown today')"
                        class="px-2 py-1 text-[10px] text-gray-500 border border-gray-800 rounded hover:bg-gray-900 hover:text-gray-300 transition-colors">
                    Status breakdown
                </button>
                <button @@click="quickAsk('Which wallets received the most disbursements this week?')"
                        class="px-2 py-1 text-[10px] text-gray-500 border border-gray-800 rounded hover:bg-gray-900 hover:text-gray-300 transition-colors">
                    Top recipients this week
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
function analyticsChat() {
    return {
        messages: [],
        input: '',
        loading: false,
        database: '',
        databases: [],
        charts: {},
        conversations: [],
        activeConversationId: null,
        activePolls: {},

        async init() {
            await this.loadDatabases();
            await this.loadConversations();
        },

        async loadDatabases() {
            try {
                const res = await fetch('/api/analytics/databases');
                this.databases = await res.json();
                if (this.databases.length > 0 && !this.database) {
                    this.database = this.databases[0];
                }
            } catch (e) {
                console.error('Failed to load databases:', e);
            }
        },

        async loadConversations() {
            try {
                const res = await fetch('/api/analytics/conversations');
                this.conversations = await res.json();
            } catch (e) {
                console.error('Failed to load conversations:', e);
            }
        },

        async loadConversation(id) {
            try {
                const res = await fetch(`/api/analytics/conversations/${id}`);
                if (!res.ok) return;
                const conv = await res.json();
                this.activeConversationId = conv.id;
                this.database = conv.database;

                // Map messages to display format
                this.messages = (conv.messages || []).map(m => {
                    if (m.role === 'assistant' && m.response) {
                        return { role: 'assistant', ...m.response };
                    }
                    return { role: m.role, content: m.content };
                });
                this.scrollToBottom();

                // Check for pending jobs
                await this.checkPendingJobs(id);
            } catch (e) {
                console.error('Failed to load conversation:', e);
            }
        },

        async checkPendingJobs(conversationId) {
            try {
                const res = await fetch(`/api/analytics/jobs?conversationId=${conversationId}`);
                const jobs = await res.json();
                jobs.filter(j => j.status === 'pending' || j.status === 'running')
                    .forEach(j => this.startPolling(j.jobId));
            } catch (e) {}
        },

        newConversation() {
            this.activeConversationId = null;
            this.clearChat();
        },

        onDatabaseChange() {
            if (this.database) this.newConversation();
        },

        async deleteConversation(id) {
            await fetch(`/api/analytics/conversations/${id}`, { method: 'DELETE' });
            if (this.activeConversationId === id) this.newConversation();
            await this.loadConversations();
        },

        async send() {
            const prompt = this.input.trim();
            if (!prompt || this.loading || !this.database) return;

            this.messages.push({ role: 'user', content: prompt });
            this.input = '';
            this.loading = true;
            this.scrollToBottom();

            try {
                const res = await fetch('/api/analytics/ask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        prompt,
                        database: this.database,
                        conversationId: this.activeConversationId
                    })
                });

                const data = await res.json();
                if (data.conversationId) {
                    this.activeConversationId = data.conversationId;
                    await this.loadConversations();
                }

                // Start polling for the job
                this.startPolling(data.jobId);
            } catch (err) {
                this.messages.push({ role: 'assistant', error: 'Request failed: ' + err.message });
                this.loading = false;
            }

            this.scrollToBottom();
        },

        startPolling(jobId) {
            if (this.activePolls[jobId]) return;

            const intervalId = setInterval(async () => {
                try {
                    const res = await fetch(`/api/analytics/jobs/${jobId}`);
                    if (!res.ok) { this.stopPolling(jobId); return; }
                    const job = await res.json();

                    if (job.status === 'completed') {
                        this.stopPolling(jobId);
                        if (job.result) {
                            this.messages.push({
                                role: 'assistant',
                                thinking: job.result.thinking,
                                sql: job.result.sql,
                                explanation: job.result.explanation,
                                error: job.result.error,
                                chartType: job.result.chartType || 'none',
                                columns: job.result.columns || [],
                                rows: job.result.rows || [],
                                rowCount: job.result.rowCount || 0,
                                inputTokens: job.result.inputTokens || 0,
                                outputTokens: job.result.outputTokens || 0
                            });
                        }
                        this.loading = false;
                        this.scrollToBottom();
                    } else if (job.status === 'failed') {
                        this.stopPolling(jobId);
                        this.messages.push({ role: 'assistant', error: job.error || 'Query failed' });
                        this.loading = false;
                        this.scrollToBottom();
                    }
                } catch (e) {
                    this.stopPolling(jobId);
                    this.loading = false;
                }
            }, 2000);

            this.activePolls[jobId] = intervalId;
        },

        stopPolling(jobId) {
            if (this.activePolls[jobId]) {
                clearInterval(this.activePolls[jobId]);
                delete this.activePolls[jobId];
            }
        },

        quickAsk(prompt) {
            this.input = prompt;
            this.send();
        },

        renderChart(idx, msg) {
            if (!msg.chartType || msg.chartType === 'none' || !msg.rows || msg.rows.length === 0) return;

            this.$nextTick(() => {
                const canvasId = 'chart-' + idx;
                const canvas = document.getElementById(canvasId);
                if (!canvas) return;

                if (this.charts[canvasId]) this.charts[canvasId].destroy();

                const columns = msg.columns;
                if (columns.length < 2) return;

                const labelCol = columns[0];
                const valueCols = columns.slice(1).filter(col =>
                    msg.rows.some(row => !isNaN(parseFloat(row[col])))
                );
                if (valueCols.length === 0) return;

                const labels = msg.rows.map(row => row[labelCol]);
                const colors = [
                    'rgba(16, 185, 129, 0.8)', 'rgba(59, 130, 246, 0.8)',
                    'rgba(245, 158, 11, 0.8)', 'rgba(239, 68, 68, 0.8)',
                    'rgba(139, 92, 246, 0.8)', 'rgba(236, 72, 153, 0.8)',
                    'rgba(20, 184, 166, 0.8)', 'rgba(249, 115, 22, 0.8)',
                ];
                const borderColors = colors.map(c => c.replace('0.8', '1'));

                const datasets = valueCols.map((col, i) => ({
                    label: col,
                    data: msg.rows.map(row => parseFloat(row[col]) || 0),
                    backgroundColor: msg.chartType === 'doughnut'
                        ? msg.rows.map((_, j) => colors[j % colors.length])
                        : colors[i % colors.length],
                    borderColor: msg.chartType === 'doughnut'
                        ? msg.rows.map((_, j) => borderColors[j % borderColors.length])
                        : borderColors[i % borderColors.length],
                    borderWidth: 1, tension: 0.3, fill: msg.chartType === 'line'
                }));

                this.charts[canvasId] = new Chart(canvas, {
                    type: msg.chartType,
                    data: { labels, datasets },
                    options: {
                        responsive: true, maintainAspectRatio: true,
                        plugins: { legend: { display: valueCols.length > 1 || msg.chartType === 'doughnut', labels: { color: '#9ca3af', font: { size: 11 } } } },
                        scales: msg.chartType === 'doughnut' ? {} : {
                            x: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: 'rgba(55, 65, 81, 0.3)' } },
                            y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: 'rgba(55, 65, 81, 0.3)' } }
                        }
                    }
                });
            });
        },

        formatCell(value) {
            if (!value) return '';
            const num = parseFloat(value);
            if (!isNaN(num) && num > 999) return num.toLocaleString();
            return value;
        },

        clearChat() {
            Object.values(this.charts).forEach(c => c.destroy());
            this.charts = {};
            this.messages = [];
        },

        scrollToBottom() {
            this.$nextTick(() => {
                const el = this.$refs.messages;
                if (el) el.scrollTop = el.scrollHeight;
            });
        },

        copyText(text) {
            navigator.clipboard.writeText(text);
        }
    };
}
</script>
