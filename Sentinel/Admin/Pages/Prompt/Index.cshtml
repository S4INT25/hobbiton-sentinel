@page "/admin/prompt"
@model Sentinel.Admin.Pages.Prompt.IndexModel
@{
    ViewData["Title"] = "System Prompt";
    ViewData["Nav"] = "prompt";
}

<div class="space-y-4">
    <div class="flex items-center justify-between">
        <h1 class="text-lg font-semibold text-white">System Prompt</h1>
        @if (Model.Current != null)
        {
            <div class="text-xs text-gray-500">
                Last updated by <span class="text-gray-400">@Model.Current.UpdatedBy</span>
                on @Model.Current.UpdatedAt?.ToString("MMM dd HH:mm")
            </div>
        }
    </div>

    <form method="post" asp-page-handler="Save" class="space-y-3">
        <div class="border border-gray-800 rounded-lg overflow-hidden">
            <textarea name="promptText" rows="30"
                      class="w-full p-4 bg-gray-900 text-xs text-gray-200 font-mono resize-y focus:outline-none"
                      placeholder="Leave empty to use default system prompt...">@Model.PromptText</textarea>
        </div>
        <div class="flex items-center gap-3">
            <button type="submit" class="px-4 py-2 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-colors">
                Save Override
            </button>
            @if (Model.Current != null)
            {
                <form method="post" asp-page-handler="Reset" class="inline">
                    <button type="submit" class="px-4 py-2 text-xs text-gray-400 hover:text-rose-400 transition-colors">
                        Reset to Default
                    </button>
                </form>
            }
        </div>
    </form>

    @if (Model.History.Any())
    {
        <div class="border-t border-gray-800 pt-4">
            <h2 class="text-sm font-medium text-gray-400 mb-3">History</h2>
            <div class="space-y-2">
                @foreach (var h in Model.History)
                {
                    <div class="flex items-center justify-between px-3 py-2 bg-gray-900/30 border border-gray-800/50 rounded text-xs">
                        <span class="text-gray-400">@h.UpdatedBy</span>
                        <span class="text-gray-500 font-mono">@h.UpdatedAt?.ToString("MMM dd HH:mm")</span>
                    </div>
                }
            </div>
        </div>
    }
</div>
