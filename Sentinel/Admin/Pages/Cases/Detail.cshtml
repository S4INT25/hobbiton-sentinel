@page "/admin/cases/{id}"
@model Sentinel.Admin.Pages.Cases.DetailModel
@{
    ViewData["Title"] = $"Case {Model.Case?.Id?[..8]}";
    ViewData["Nav"] = "cases";
}

<div class="space-y-4">
    <div class="flex items-center gap-3">
        <a href="/admin/cases" class="text-gray-500 hover:text-gray-300 text-sm">← Cases</a>
        <h1 class="text-lg font-semibold text-white">@Model.Case?.Title</h1>
    </div>

    @if (Model.Case != null)
    {
        var c = Model.Case;
        <div class="grid grid-cols-4 gap-3 text-xs">
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Severity</div>
                <div class="text-white font-medium">@c.Severity</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Status</div>
                <div class="text-white">@c.Status</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Created</div>
                <div class="text-white font-mono">@c.FirstSeen.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Last Seen</div>
                <div class="text-white font-mono">@c.LastSeen.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
        </div>

        <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/30">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-2">Notes</div>
            <pre class="text-xs text-gray-300 font-mono whitespace-pre-wrap">@c.Notes</pre>
        </div>

        @if (c.FollowUpQueries.Any())
        {
            <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/30">
                <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-2">Follow-Up Queries</div>
                @foreach (var q in c.FollowUpQueries)
                {
                    <pre class="text-xs text-gray-400 font-mono whitespace-pre-wrap mb-2">@q</pre>
                }
            </div>
        }

        <!-- Feedback Actions -->
        <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50 space-y-3" x-data="{ showFpForm: false }">
            <div class="text-xs font-medium text-gray-300">Actions</div>
            <div class="flex gap-2">
                <button @@click="showFpForm = !showFpForm" type="button"
                        class="px-3 py-1.5 text-xs bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-md border border-gray-700 transition-colors">
                    Mark False Positive
                </button>
                <form method="post" asp-page-handler="Feedback">
                    <input type="hidden" name="caseId" value="@c.Id" />
                    <input type="hidden" name="action" value="escalate" />
                    <button type="submit" class="px-3 py-1.5 text-xs bg-rose-600/20 hover:bg-rose-600/30 text-rose-400 rounded-md border border-rose-500/30 transition-colors">
                        Escalate
                    </button>
                </form>
                <form method="post" asp-page-handler="Feedback">
                    <input type="hidden" name="caseId" value="@c.Id" />
                    <input type="hidden" name="action" value="resolve" />
                    <button type="submit" class="px-3 py-1.5 text-xs bg-emerald-600/20 hover:bg-emerald-600/30 text-emerald-400 rounded-md border border-emerald-500/30 transition-colors">
                        Resolve
                    </button>
                </form>
            </div>

            <!-- Inline False Positive + Rule Creation -->
            <div x-show="showFpForm" x-cloak class="border border-gray-800 rounded-lg p-4 bg-gray-900/70 space-y-3 mt-3">
                <div class="text-xs text-gray-400">Mark as false positive and optionally create a suppression rule so this doesn't get flagged again.</div>
                <form method="post" asp-page-handler="FalsePositive" class="space-y-3">
                    <input type="hidden" name="caseId" value="@c.Id" />

                    <div>
                        <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Reason</label>
                        <input type="text" name="reason" required
                               class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white"
                               placeholder="Why this is not fraud..." />
                    </div>

                    <div x-data="{ createRule: true }">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox" name="createRule" x-model="createRule" checked
                                   class="rounded border-gray-700 bg-gray-900 text-emerald-500 focus:ring-emerald-500/20" />
                            <span class="text-xs text-gray-300">Create suppression rule to prevent future flags</span>
                        </label>

                        <div x-show="createRule" class="grid grid-cols-2 gap-3 mt-3">
                            <div>
                                <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Rule Type</label>
                                <select name="ruleType" class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                                    <option value="ip">IP Address</option>
                                    <option value="cidr">CIDR Range</option>
                                    <option value="asn">ASN</option>
                                    <option value="pattern_id">Pattern ID</option>
                                    <option value="keyword">Keyword</option>
                                    <option value="recipient">Recipient</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Match Value</label>
                                <input type="text" name="matchValue"
                                       class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white"
                                       placeholder="e.g. 159.89.x.x or AS14061" />
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-2">
                        <button type="submit" class="px-3 py-1.5 text-xs font-medium bg-gray-700 hover:bg-gray-600 text-white rounded-md transition-colors">
                            Confirm False Positive
                        </button>
                        <button type="button" @@click="showFpForm = false" class="px-3 py-1.5 text-xs text-gray-500 hover:text-gray-300">
                            Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-8 text-gray-600 text-sm">Case not found</div>
    }
</div>
