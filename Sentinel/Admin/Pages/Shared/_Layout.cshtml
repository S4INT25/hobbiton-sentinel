<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-950">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — Sentinel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com/3.4.16"></script>
    <script>
        function runTrigger() {
            return {
                loading: false,
                message: '',
                success: false,
                async trigger() {
                    this.loading = true;
                    this.message = '';
                    try {
                        const res = await fetch('/api/runs/trigger', { method: 'POST' });
                        if (res.ok || res.status === 202) {
                            this.success = true;
                            this.message = 'Run triggered successfully';
                            setTimeout(() => location.reload(), 1500);
                        } else if (res.status === 401) {
                            this.success = false;
                            this.message = 'Session expired — please log in again';
                        } else {
                            this.success = false;
                            this.message = `Failed (${res.status})`;
                        }
                    } catch (e) {
                        this.success = false;
                        this.message = 'Network error';
                    }
                    this.loading = false;
                    setTimeout(() => this.message = '', 5000);
                }
            };
        }
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'], mono: ['JetBrains Mono', 'monospace'] },
                    colors: {
                        accent: { DEFAULT: '#10b981', light: '#34d399', dark: '#059669' },
                    }
                }
            }
        }
    </script>
    <style>
        [x-cloak] { display: none !important; }
        body { font-family: 'Inter', system-ui, sans-serif; }
        code, pre, .font-mono { font-family: 'JetBrains Mono', monospace; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #0a0a0a; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 3px; }
    </style>
</head>
<body class="h-full dark text-gray-200 antialiased">
    <div class="flex h-full" x-data="{ sidebarOpen: true }">
        <!-- Sidebar -->
        <aside class="w-56 flex-shrink-0 border-r border-gray-800 bg-gray-950 flex flex-col"
               :class="sidebarOpen ? '' : 'hidden'">
            <div class="p-4 border-b border-gray-800">
                <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded bg-emerald-500/20 flex items-center justify-center">
                        <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                    </div>
                    <span class="font-semibold text-sm text-white">Sentinel</span>
                </div>
            </div>
            <nav class="flex-1 p-3 space-y-0.5 text-sm">
                <a href="/admin" class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md hover:bg-gray-900 text-gray-300 hover:text-white transition-colors @(ViewData["Nav"]?.ToString() == "dashboard" ? "bg-gray-900 text-white" : "")">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    Dashboard
                </a>
                <a href="/admin/runs" class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md hover:bg-gray-900 text-gray-300 hover:text-white transition-colors @(ViewData["Nav"]?.ToString() == "runs" ? "bg-gray-900 text-white" : "")">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    Runs
                </a>
                <a href="/admin/rules" class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md hover:bg-gray-900 text-gray-300 hover:text-white transition-colors @(ViewData["Nav"]?.ToString() == "rules" ? "bg-gray-900 text-white" : "")">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
                    Rules
                </a>
                <a href="/admin/cases" class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md hover:bg-gray-900 text-gray-300 hover:text-white transition-colors @(ViewData["Nav"]?.ToString() == "cases" ? "bg-gray-900 text-white" : "")">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    Cases
                </a>
                <a href="/admin/analytics" class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md hover:bg-gray-900 text-gray-300 hover:text-white transition-colors @(ViewData["Nav"]?.ToString() == "analytics" ? "bg-gray-900 text-white" : "")">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Analytics
                </a>
                <a href="/admin/prompt" class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md hover:bg-gray-900 text-gray-300 hover:text-white transition-colors @(ViewData["Nav"]?.ToString() == "prompt" ? "bg-gray-900 text-white" : "")">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                    Prompt
                </a>
                <a href="/admin/users" class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md hover:bg-gray-900 text-gray-300 hover:text-white transition-colors @(ViewData["Nav"]?.ToString() == "users" ? "bg-gray-900 text-white" : "")">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    Users
                </a>
                <a href="/admin/audit" class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md hover:bg-gray-900 text-gray-300 hover:text-white transition-colors @(ViewData["Nav"]?.ToString() == "audit" ? "bg-gray-900 text-white" : "")">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                    Audit
                </a>
            </nav>
            <div class="p-3 border-t border-gray-800">
                <div class="flex items-center gap-2 px-2.5 py-1.5 text-xs text-gray-500">
                    <div class="w-5 h-5 rounded-full bg-gray-800 flex items-center justify-center text-[10px] font-medium text-gray-400">
                        @(User.Identity?.Name?.ToUpper()[..1] ?? "?")
                    </div>
                    <span>@User.Identity?.Name</span>
                </div>
                <form method="post" action="/api/auth/logout" class="mt-1">
                    <button type="submit" class="w-full text-left px-2.5 py-1 text-xs text-gray-500 hover:text-gray-300 rounded hover:bg-gray-900 transition-colors">
                        Sign out
                    </button>
                </form>
            </div>
        </aside>

        <!-- Main content -->
        <main class="flex-1 overflow-y-auto bg-gray-950">
            <div class="max-w-6xl mx-auto px-6 py-6">
                @RenderBody()
            </div>
        </main>
    </div>
</body>
</html>
