@using Microsoft.JSInterop

<div class="relative">
    <button @onclick="() => open = !open" @onclick:stopPropagation="true"
            class="p-1 rounded text-gray-600 hover:text-gray-300 hover:bg-gray-800 transition-colors"
            title="Share chart">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
        </svg>
    </button>

    @if (open)
    {
        <div class="absolute right-0 top-8 z-30 w-44 bg-gray-900 border border-gray-700 rounded-lg shadow-xl overflow-hidden">
            <button @onclick="DownloadPng"
                    class="w-full px-3 py-2 text-xs text-left text-gray-300 hover:bg-gray-800 flex items-center gap-2 transition-colors">
                <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                </svg>
                Download PNG
            </button>
            <button @onclick="CopyLink"
                    class="w-full px-3 py-2 text-xs text-left text-gray-300 hover:bg-gray-800 flex items-center gap-2 transition-colors">
                <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
                @(linkCopied ? "Copied!" : "Copy link")
            </button>
        </div>
    }
</div>

@if (open)
{
    <div class="fixed inset-0 z-20" @onclick="() => open = false"></div>
}

@code {
    [Parameter, EditorRequired] public string ChartContainerId { get; set; } = "";
    [Parameter, EditorRequired] public string ChartTitle { get; set; } = "";
    [Parameter, EditorRequired] public string ConversationUrl { get; set; } = "";
    [Parameter, EditorRequired] public IJSRuntime JS { get; set; } = default!;

    private bool open;
    private bool linkCopied;

    private async Task DownloadPng()
    {
        open = false;
        try
        {
            var filename = string.IsNullOrWhiteSpace(ChartTitle)
                ? "chart"
                : ChartTitle.Replace(" ", "_").ToLowerInvariant();
            await JS.InvokeVoidAsync("chartInterop.downloadChartById", ChartContainerId, filename);
        }
        catch
        {
        }
    }

    private async Task CopyLink()
    {
        try
        {
            await JS.InvokeVoidAsync("chartInterop.copyToClipboard", ConversationUrl);
            linkCopied = true;
            StateHasChanged();
            await Task.Delay(1500);
            linkCopied = false;
            open = false;
        }
        catch
        {
        }
    }
}
