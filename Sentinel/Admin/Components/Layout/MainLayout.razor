@inherits LayoutComponentBase
@inject NavigationManager Navigation
@attribute [Authorize(Policy = AuthConstants.Policy)]

<div class="h-full bg-gray-950 flex flex-col">
    <!-- Mobile header -->
    <header class="md:hidden sticky top-0 z-20 bg-gray-950/95 backdrop-blur-sm border-b border-gray-800/80 px-4 py-2.5 flex items-center justify-between">
        <button @onclick="ToggleMobileNav" class="p-1.5 -ml-1 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800/60 active:scale-95 transition-all duration-150">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <div class="flex items-center gap-2">
            <img src="https://hobbiton.tech/assets/logo2-7db998ca.png" alt="Hobbition" class="h-6 w-6 rounded object-contain" />
            <span class="font-semibold text-sm text-white tracking-tight">Sentinel</span>
        </div>
        <div class="w-8"></div>
    </header>

    <!-- Overlay -->
    <div class="@OverlayClass" @onclick="CloseMobileNav"></div>

    <div class="flex flex-1 min-h-0">
        <!-- Sidebar -->
        <aside class="@SidebarClass">
            <div class="p-4 border-b border-gray-800/80">
                <div class="flex items-center gap-2.5">
                    <img src="https://hobbiton.tech/assets/logo2-7db998ca.png" alt="Hobbition" class="h-7 w-7 rounded object-contain" />
                    <div>
                        <div class="font-semibold text-sm text-white leading-none tracking-tight">Sentinel</div>
                        <div class="text-[10px] text-gray-500 leading-none mt-1">by Hobbition</div>
                    </div>
                </div>
            </div>
            <nav class="flex-1 overflow-y-auto p-3 space-y-0.5 text-sm" @onclick="OnNavClick">
                <NavLink href="/admin" Match="NavLinkMatch.All" class="nav-item flex items-center gap-2.5 px-2.5 py-2 rounded-lg hover:bg-gray-800/60 text-gray-400 hover:text-white transition-all duration-150" ActiveClass="bg-gray-800/80 text-white shadow-sm">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    Dashboard
                </NavLink>
                <NavLink href="/admin/chat" Match="NavLinkMatch.Prefix" class="nav-item flex items-center gap-2.5 px-2.5 py-2 rounded-lg hover:bg-gray-800/60 text-gray-400 hover:text-white transition-all duration-150" ActiveClass="bg-gray-800/80 text-white shadow-sm">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h8M8 14h5m-9 6h16a2 2 0 002-2V6a2 2 0 00-2-2H4a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    Chat
                </NavLink>
                <AuthorizeView Policy="@AuthConstants.AdminOnlyPolicy">
                    <Authorized>
                        <NavLink href="/admin/workflows" Match="NavLinkMatch.Prefix" class="nav-item flex items-center gap-2.5 px-2.5 py-2 rounded-lg hover:bg-gray-800/60 text-gray-400 hover:text-white transition-all duration-150" ActiveClass="bg-gray-800/80 text-white shadow-sm">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3M5 11h14M7 21h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v12a2 2 0 002 2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 15h2v2H9v-2zm4 0h2v2h-2v-2z"/></svg>
                            Workflows
                        </NavLink>
                        <NavLink href="/admin/rules" Match="NavLinkMatch.Prefix" class="nav-item flex items-center gap-2.5 px-2.5 py-2 rounded-lg hover:bg-gray-800/60 text-gray-400 hover:text-white transition-all duration-150" ActiveClass="bg-gray-800/80 text-white shadow-sm">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
                            Rules
                        </NavLink>
                        <NavLink href="/admin/cases" Match="NavLinkMatch.Prefix" class="nav-item flex items-center gap-2.5 px-2.5 py-2 rounded-lg hover:bg-gray-800/60 text-gray-400 hover:text-white transition-all duration-150" ActiveClass="bg-gray-800/80 text-white shadow-sm">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                            Cases
                        </NavLink>
                        <NavLink href="/admin/users" Match="NavLinkMatch.Prefix" class="nav-item flex items-center gap-2.5 px-2.5 py-2 rounded-lg hover:bg-gray-800/60 text-gray-400 hover:text-white transition-all duration-150" ActiveClass="bg-gray-800/80 text-white shadow-sm">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                            Users
                        </NavLink>
                        <NavLink href="/admin/audit" Match="NavLinkMatch.Prefix" class="nav-item flex items-center gap-2.5 px-2.5 py-2 rounded-lg hover:bg-gray-800/60 text-gray-400 hover:text-white transition-all duration-150" ActiveClass="bg-gray-800/80 text-white shadow-sm">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                            Audit
                        </NavLink>
                    </Authorized>
                </AuthorizeView>
            </nav>
            <AuthorizeView>
                <Authorized>
                    <div class="p-3 border-t border-gray-800/80">
                        <div class="flex items-center gap-2 px-2.5 py-1.5 text-xs text-gray-500">
                            <div class="w-6 h-6 rounded-full bg-gradient-to-br from-emerald-600 to-emerald-800 flex items-center justify-center text-[10px] font-semibold text-white shadow-sm">
                                @(context.User.Identity?.Name?.ToUpper()[..1] ?? "?")
                            </div>
                            <span class="truncate">@context.User.Identity?.Name</span>
                        </div>
                        <form method="post" action="/api/auth/logout" class="mt-1">
                            <button type="submit" class="w-full text-left px-2.5 py-1.5 text-xs text-gray-500 hover:text-white rounded-lg hover:bg-gray-800/60 transition-all duration-150">
                                Sign out
                            </button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </aside>

        <!-- Main content -->
        <main class="flex-1 overflow-y-auto overflow-x-hidden bg-gray-950">
            <div class="@ContentContainerClass">
                @Body
            </div>
        </main>
    </div>
</div>

@code {
    private bool isMobileNavOpen;

    private string SidebarClass => isMobileNavOpen
        ? "fixed inset-y-0 left-0 z-40 w-72 border-r border-gray-800/80 bg-gray-950 flex flex-col transform translate-x-0 transition-transform duration-250 ease-out md:relative md:w-56 md:translate-x-0 md:transition-none"
        : "fixed inset-y-0 left-0 z-40 w-72 border-r border-gray-800/80 bg-gray-950 flex flex-col transform -translate-x-full transition-transform duration-200 ease-in md:relative md:flex md:w-56 md:translate-x-0 md:transition-none";

    private string OverlayClass => isMobileNavOpen
        ? "fixed inset-0 z-30 bg-black/60 backdrop-blur-[2px] md:hidden transition-opacity duration-200 opacity-100"
        : "fixed inset-0 z-30 bg-black/60 backdrop-blur-[2px] md:hidden transition-opacity duration-200 opacity-0 pointer-events-none";

    private void ToggleMobileNav() => isMobileNavOpen = !isMobileNavOpen;
    private void CloseMobileNav() => isMobileNavOpen = false;
    private void OnNavClick() => isMobileNavOpen = false;

    private string ContentContainerClass
    {
        get
        {
            var route = "/" + Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
            var isChat = route.StartsWith("/admin/chat", StringComparison.OrdinalIgnoreCase)
                         || route.StartsWith("/admin/analytics", StringComparison.OrdinalIgnoreCase);
            return isChat
                ? "h-full px-3 sm:px-4 md:px-6 py-4 md:py-6"
                : "max-w-6xl mx-auto px-3 sm:px-4 md:px-6 py-4 md:py-6";
        }
    }
}
