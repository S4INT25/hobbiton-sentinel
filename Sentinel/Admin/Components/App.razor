<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-950">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <base href="/" />
    <title>Sentinel</title>
    <link rel="icon" type="image/png" href="https://hobbiton.tech/assets/logo2-7db998ca.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com/3.4.16?plugins=typography"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'], mono: ['JetBrains Mono', 'monospace'] },
                    colors: {
                        accent: { DEFAULT: '#10b981', light: '#34d399', dark: '#059669' },
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', system-ui, sans-serif; }
        code, pre, .font-mono { font-family: 'JetBrains Mono', monospace; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #4b5563; }

        /* Smooth animations */
        .animate-in { animation: fadeSlideIn 0.2s ease-out; }
        @@keyframes fadeSlideIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade { animation: fadeIn 0.15s ease-out; }
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* Button press effect */
        button:active:not(:disabled) { transform: scale(0.97); }
        
        /* Smooth table hover */
        tbody tr { transition: background-color 0.15s ease; }

        /* Nav item subtle indicator */
        .nav-item { position: relative; }

        /* Markdown prose overrides for chat */
        .prose-invert pre { background: #1f2937; border: 1px solid #374151; border-radius: 8px; padding: 12px 16px; overflow-x: auto; }
        .prose-invert code { background: #1f2937; padding: 2px 5px; border-radius: 4px; font-size: 0.85em; }
        .prose-invert pre code { background: transparent; padding: 0; }
        .prose-invert table { border-collapse: collapse; width: 100%; font-size: 0.8rem; }
        .prose-invert th, .prose-invert td { border: 1px solid #374151; padding: 6px 10px; }
        .prose-invert th { background: #1f2937; font-weight: 600; }
        .prose-invert blockquote { border-left: 3px solid #10b981; padding-left: 12px; color: #9ca3af; }
        .prose-invert a { color: #34d399; text-decoration: underline; }
        .prose-invert ul, .prose-invert ol { padding-left: 1.5em; }
        .prose-invert h1, .prose-invert h2, .prose-invert h3 { margin-top: 0.8em; margin-bottom: 0.4em; }

        /* Line clamp utility */
        .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

        /* Smooth chart swap — prevent layout collapse during re-render */
        .apexcharts-canvas {
            animation: chartFadeIn 0.2s ease-out;
        }

        @@keyframes chartFadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }
    </style>
    <HeadOutlet />
</head>
<body class="h-full dark text-gray-200 antialiased">
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script src="js/chart-interop.js"></script>

    <!-- Reconnect UI — visibility driven by Blazor's components-reconnect-* classes -->
    <div id="components-reconnect-modal">
        <div class="reconnect-card">
            <div class="reconnect-spinner"></div>
            <p class="reconnect-title">Reconnecting…</p>
            <p class="reconnect-sub">Restoring your session automatically.</p>
            <button onclick="window.location.reload()" class="reconnect-btn">Reload now</button>
        </div>
    </div>
    <style>
        #components-reconnect-modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(3, 7, 18, 0.85);
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
        }

        #components-reconnect-modal.components-reconnect-show,
        #components-reconnect-modal.components-reconnect-failed,
        #components-reconnect-modal.components-reconnect-rejected {
            display: flex;
        }

        #components-reconnect-modal .reconnect-card {
            background: #111827;
            border: 1px solid #1f2937;
            border-radius: 12px;
            padding: 24px 32px;
            text-align: center;
            max-width: 320px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.6);
        }

        #components-reconnect-modal .reconnect-spinner {
            width: 36px;
            height: 36px;
            border: 3px solid #1f2937;
            border-top-color: #10b981;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 16px;
        }

        #components-reconnect-modal .reconnect-title {
            color: #f9fafb;
            font-size: 14px;
            font-weight: 500;
            margin: 0 0 6px;
        }

        #components-reconnect-modal .reconnect-sub {
            color: #6b7280;
            font-size: 12px;
            margin: 0 0 16px;
        }

        #components-reconnect-modal .reconnect-btn {
            padding: 8px 20px;
            background: #10b981;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg)
            }
        }
    </style>

    <script>
        // Keep Blazor's DEFAULT reconnection handler — it runs the automatic retry loop.
        // We only widen the retry budget and layer no-touch recovery on top.
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 10,
                    retryIntervalMilliseconds: 3000
                }
            }
        });

        const reconnectModal = document.getElementById('components-reconnect-modal');
        const reconnectDead = () =>
            reconnectModal.classList.contains('components-reconnect-failed') ||
            reconnectModal.classList.contains('components-reconnect-rejected');

        // Recover without any user action:
        //  - "rejected": the server circuit is gone (typical after a long idle) — retrying can't
        //    help, so reload to start a fresh circuit.
        //  - "failed": retries exhausted (server briefly unreachable) — reload shortly to retry.
        new MutationObserver(() => {
            if (reconnectModal.classList.contains('components-reconnect-rejected')) {
                window.location.reload();
            } else if (reconnectModal.classList.contains('components-reconnect-failed')) {
                setTimeout(() => window.location.reload(), 3000);
            }
        }).observe(reconnectModal, {attributes: true, attributeFilter: ['class']});

        // Coming back to a long-backgrounded tab: if we're already disconnected, reload
        // immediately rather than waiting out the retry schedule.
        document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'visible' && reconnectDead()) {
                window.location.reload();
            }
        });
    </script>
</body>
</html>
