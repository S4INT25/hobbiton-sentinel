<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-950">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <base href="/" />
    <title>Sentinel</title>
    <link rel="icon" type="image/png" href="https://hobbiton.tech/assets/logo2-7db998ca.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com/3.4.16"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'], mono: ['JetBrains Mono', 'monospace'] },
                    colors: {
                        accent: { DEFAULT: '#10b981', light: '#34d399', dark: '#059669' },
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', system-ui, sans-serif; }
        code, pre, .font-mono { font-family: 'JetBrains Mono', monospace; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #4b5563; }

        /* Smooth animations */
        .animate-in { animation: fadeSlideIn 0.2s ease-out; }
        @@keyframes fadeSlideIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade { animation: fadeIn 0.15s ease-out; }
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* Button press effect */
        button:active:not(:disabled) { transform: scale(0.97); }
        
        /* Smooth table hover */
        tbody tr { transition: background-color 0.15s ease; }

        /* Nav item subtle indicator */
        .nav-item { position: relative; }

        /* Line clamp utility */
        .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
    <HeadOutlet />
</head>
<body class="h-full dark text-gray-200 antialiased">
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script src="js/chart-interop.js"></script>

    <!-- Reconnect UI -->
    <div id="blazor-reconnect-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(3,7,18,0.85);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center;">
        <div style="background:#111827;border:1px solid #1f2937;border-radius:12px;padding:24px 32px;text-align:center;max-width:320px;box-shadow:0 25px 50px rgba(0,0,0,0.6);">
            <div id="blazor-reconnect-spinner" style="width:36px;height:36px;border:3px solid #1f2937;border-top-color:#10b981;border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 16px;"></div>
            <p style="color:#f9fafb;font-size:14px;font-weight:500;margin:0 0 6px;">Reconnecting…</p>
            <p style="color:#6b7280;font-size:12px;margin:0 0 16px;">Your session is being restored</p>
            <button onclick="window.location.reload()" style="padding:8px 20px;background:#10b981;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;">Reload now</button>
        </div>
    </div>
    <style>@@keyframes spin{to{transform:rotate(360deg)}}</style>

    <script>
        // Show reconnect modal when Blazor circuit drops
        Blazor.defaultReconnectionHandler = {
            onConnectionDown: () => {
                document.getElementById('blazor-reconnect-modal').style.display = 'flex';
            },
            onConnectionUp: () => {
                document.getElementById('blazor-reconnect-modal').style.display = 'none';
            },
            onConnectionRetrying: () => {
                document.getElementById('blazor-reconnect-modal').style.display = 'flex';
            }
        };

        // Keep-alive ping every 25s to prevent idle timeout
        setInterval(() => {
            fetch('/_blazor', { method: 'HEAD' }).catch(() => {});
        }, 25000);
    </script>
</body>
</html>
