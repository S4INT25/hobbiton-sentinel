@page "/admin/reset-password"
@layout EmptyLayout
@attribute [AllowAnonymous]

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorParam { get; set; }
}

<PageTitle>Reset password — Sentinel</PageTitle>

<div class="h-full flex items-center justify-center">
    <div class="w-full max-w-sm px-6">
        <div class="text-center mb-8">
            <img src="https://hobbiton.tech/assets/logo2-7db998ca.png" alt="Hobbiton logo" class="w-50 h-24 mx-auto mb-3 rounded-lg object-contain" />
            <h1 class="text-lg font-semibold text-white">Sentinel</h1>
            <p class="text-sm text-gray-500 mt-1">Choose a new password</p>
        </div>

        @if (ErrorParam == "expired" || string.IsNullOrWhiteSpace(Token))
        {
            <div class="mb-4 p-3 rounded-md bg-rose-500/10 border border-rose-500/20 text-sm text-rose-400 text-center">
                This reset link is invalid or has expired.
            </div>
            <p class="mt-4 text-center text-xs text-gray-500">
                <a href="/admin/forgot-password" class="text-emerald-400 hover:text-emerald-300">Request a new link</a>
            </p>
        }
        else
        {
            @if (ErrorParam == "password")
            {
                <div class="mb-4 p-3 rounded-md bg-rose-500/10 border border-rose-500/20 text-sm text-rose-400">
                    Password must be at least 8 characters.
                </div>
            }
            else if (ErrorParam == "mismatch")
            {
                <div class="mb-4 p-3 rounded-md bg-rose-500/10 border border-rose-500/20 text-sm text-rose-400">
                    Passwords do not match.
                </div>
            }

            <form action="/admin/auth/reset-password" method="post" class="space-y-4">
                <input type="hidden" name="token" value="@Token" />
                <div>
                    <label class="block text-xs font-medium text-gray-400 mb-1.5">New password</label>
                    <input type="password" name="password" required autocomplete="new-password" autofocus
                           class="w-full px-3 py-2 bg-gray-900 border border-gray-800 rounded-md text-sm text-white placeholder-gray-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-400 mb-1.5">Confirm new password</label>
                    <input type="password" name="confirmPassword" required autocomplete="new-password"
                           class="w-full px-3 py-2 bg-gray-900 border border-gray-800 rounded-md text-sm text-white placeholder-gray-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20" />
                </div>
                <button type="submit"
                        class="w-full py-2 px-4 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-md transition-colors">
                    Set new password
                </button>
            </form>
        }
    </div>
</div>
