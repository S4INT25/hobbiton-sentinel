@page "/admin/workflows/{WorkflowId}"
@using Sentinel.Admin.Models
@using Sentinel.Infrastructure
@inject IWorkflowStore WorkflowStore
@inject IRunLogStore RunLogStore
@inject IFraudPatternStore FraudPatternStore
@inject IEvidenceSourceStore EvidenceSourceStore
@inject SchemaLoader SchemaLoader
@inject NavigationManager Nav
@attribute [Authorize(Policy = AuthConstants.AdminOnlyPolicy)]

<PageTitle>@(workflow?.Name ?? "Workflow") — Sentinel</PageTitle>

<div class="space-y-6">
    @* Header *@
    <div class="flex items-center gap-3">
        <a href="/admin/workflows" class="p-1.5 text-gray-500 hover:text-white transition-colors rounded-md hover:bg-gray-800">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div class="flex-1">
            <h1 class="text-lg font-semibold text-white">@(workflow?.Name ?? "Loading…")</h1>
            @if (workflow is not null)
            {
                <p class="text-xs text-gray-500 mt-0.5">@workflow.ActionType • @workflow.CronExpression</p>
            }
        </div>
    </div>

    @if (feedbackMessage is not null)
    {
        <div class="@FeedbackClass()" role="status">
            <div class="flex items-center justify-between gap-3">
                <span>@feedbackMessage</span>
                <button @onclick="ClearFeedback" class="text-[11px] text-gray-300 hover:text-white transition-colors">Dismiss</button>
            </div>
        </div>
    }

    @if (workflow is null)
    {
        <div class="text-center py-12 text-gray-500 text-sm">Loading workflow...</div>
    }
    else
    {
        @* Tabs *@
        <div class="border-b border-gray-800 flex gap-6">
            <button @onclick='() => activeTab = "prompt"' class="@TabClass("prompt")">System Prompt</button>
            <button @onclick='() => activeTab = "patterns"' class="@TabClass("patterns")">Fraud Patterns</button>
            <button @onclick='() => activeTab = "sources"' class="@TabClass("sources")">Evidence Sources</button>
            <button @onclick='() => activeTab = "runs"' class="@TabClass("runs")">Runs</button>
        </div>

        @* System Prompt Tab *@
        @if (activeTab == "prompt")
        {
            <div class="space-y-3">
                <p class="text-xs text-gray-500">Custom preamble injected at the start of the fraud agent prompt. Leave empty to use the default Lipila context.</p>
                <textarea @bind="workflow.SystemPrompt" rows="10"
                          class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors font-mono"
                          placeholder="You are a fraud analyst monitoring JUMP Mobility ride transactions..."></textarea>
                <button @onclick="SaveSystemPromptAsync" disabled="@saving"
                        class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                    @(saving ? "Saving…" : "Save Prompt")
                </button>
            </div>
        }

        @* Fraud Patterns Tab *@
        @if (activeTab == "patterns")
        {
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <p class="text-xs text-gray-500">Patterns scoped to this workflow. Global patterns (no workflow) are also included at runtime.</p>
                    <button @onclick="ShowPatternForm" class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-all duration-200">
                        Add Pattern
                    </button>
                </div>

                @if (showPatternForm)
                {
                    <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50 space-y-3">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs text-gray-400 mb-1">Name</label>
                                <input @bind="editPattern.Name" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-emerald-500 focus:outline-none transition-colors" />
                            </div>
                            <div>
                                <label class="block text-xs text-gray-400 mb-1">Category</label>
                                <select @bind="editPattern.Category" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-emerald-500 focus:outline-none transition-colors">
                                    <option value="TransactionAnomaly">Transaction Anomaly</option>
                                    <option value="VelocityAbuse">Velocity Abuse</option>
                                    <option value="IdentityFraud">Identity Fraud</option>
                                    <option value="AccountTakeover">Account Takeover</option>
                                    <option value="CollectionFraud">Collection Fraud</option>
                                    <option value="InternalThreat">Internal Threat</option>
                                    <option value="UserActivity">User Activity</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Description</label>
                            <textarea @bind="editPattern.Description" rows="3" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white focus:border-emerald-500 focus:outline-none transition-colors" placeholder="Describe the fraud pattern for the agent..."></textarea>
                        </div>
                        <div class="flex items-center gap-2">
                            <label class="flex items-center gap-2 text-xs text-gray-300 cursor-pointer">
                                <input type="checkbox" @bind="editPattern.Enabled" class="rounded bg-gray-800 border-gray-700 text-emerald-500 focus:ring-emerald-500" />
                                Enabled
                            </label>
                        </div>
                        <div class="flex items-center gap-2 pt-1">
                            <button @onclick="SavePatternAsync" disabled="@saving"
                                    class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                                @(saving ? "Saving…" : (editingPatternId > 0 ? "Update" : "Create"))
                            </button>
                            <button @onclick="CancelPatternForm" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white transition-colors">Cancel</button>
                        </div>
                    </div>
                }

                <div class="space-y-2">
                    @foreach (var pattern in workflowPatterns)
                    {
                        <div class="border border-gray-800 rounded-lg p-3 bg-gray-900/30 hover:bg-gray-900/50 transition-all duration-200 group">
                            <div class="flex items-start justify-between gap-3">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm font-medium text-white">@pattern.Name</span>
                                        <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-purple-500/10 text-purple-400 border border-purple-500/20">@pattern.Category</span>
                                        @if (!pattern.Enabled)
                                        {
                                            <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-700/40 text-gray-400 border border-gray-700">Disabled</span>
                                        }
                                    </div>
                                    <p class="text-xs text-gray-500 mt-1 line-clamp-2">@pattern.Description</p>
                                </div>
                                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                                    <button @onclick="() => EditPattern(pattern)" class="p-1.5 text-gray-500 hover:text-emerald-400 transition-colors" title="Edit">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                    </button>
                                    <button @onclick="() => DeletePatternAsync(pattern.Id)" class="p-1.5 text-gray-500 hover:text-rose-400 transition-colors" title="Delete">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                    @if (!workflowPatterns.Any())
                    {
                        <div class="text-center py-6 text-gray-600 text-xs">No patterns scoped to this workflow yet. Global patterns still apply.</div>
                    }
                </div>
            </div>
        }

        @* Evidence Sources Tab *@
        @if (activeTab == "sources")
        {
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <p class="text-xs text-gray-500">Evidence sources scoped to this workflow. Global sources (no workflow) are also included at runtime.</p>
                    <button @onclick="ShowSourceForm" class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-all duration-200">
                        Add Evidence Source
                    </button>
                </div>

                @if (showSourceForm)
                {
                    <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50 space-y-3">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs text-gray-400 mb-1">Name</label>
                                <input @bind="editSource.Name" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-emerald-500 focus:outline-none transition-colors" />
                            </div>
                            <div>
                                <label class="block text-xs text-gray-400 mb-1">Database</label>
                                <select @bind="editSource.EvidenceDatabase" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-emerald-500 focus:outline-none transition-colors">
                                    @foreach (var db in availableDatabases)
                                    {
                                        <option value="@db">@db</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs text-gray-400 mb-1">Merchant IDs (comma-separated)</label>
                                <input @bind="editSource.LipilaMerchantIds" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-emerald-500 focus:outline-none transition-colors" placeholder="35, 804, 821" />
                            </div>
                            <div>
                                <label class="block text-xs text-gray-400 mb-1">Partner ID (optional)</label>
                                <input type="number" @bind="editSource.LipilaPartnerId" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-emerald-500 focus:outline-none transition-colors" />
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Table Descriptions (JSON for agent context)</label>
                            <textarea @bind="editSource.TableDescriptions" rows="4" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white font-mono focus:border-emerald-500 focus:outline-none transition-colors" placeholder='{"users": "User accounts table with email, phone, created_at"}'></textarea>
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Evidence Checks (JSON array)</label>
                            <textarea @bind="editSource.EvidenceChecks" rows="3" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white font-mono focus:border-emerald-500 focus:outline-none transition-colors" placeholder='[{"name": "Check duplicate accounts", "query_hint": "..."}]'></textarea>
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Notes (free text for agent)</label>
                            <textarea @bind="editSource.Notes" rows="2" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white focus:border-emerald-500 focus:outline-none transition-colors" placeholder="Context about this evidence source..."></textarea>
                        </div>
                        <div class="flex items-center gap-2">
                            <label class="flex items-center gap-2 text-xs text-gray-300 cursor-pointer">
                                <input type="checkbox" @bind="editSource.Enabled" class="rounded bg-gray-800 border-gray-700 text-emerald-500 focus:ring-emerald-500" />
                                Enabled
                            </label>
                        </div>
                        <div class="flex items-center gap-2 pt-1">
                            <button @onclick="SaveSourceAsync" disabled="@saving"
                                    class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                                @(saving ? "Saving…" : (editingSourceId > 0 ? "Update" : "Create"))
                            </button>
                            <button @onclick="CancelSourceForm" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white transition-colors">Cancel</button>
                        </div>
                    </div>
                }

                <div class="space-y-2">
                    @foreach (var source in workflowSources)
                    {
                        <div class="border border-gray-800 rounded-lg p-3 bg-gray-900/30 hover:bg-gray-900/50 transition-all duration-200 group">
                            <div class="flex items-start justify-between gap-3">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm font-medium text-white">@source.Name</span>
                                        <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 font-mono">@source.EvidenceDatabase</span>
                                        @if (!source.Enabled)
                                        {
                                            <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-700/40 text-gray-400 border border-gray-700">Disabled</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(source.Notes))
                                    {
                                        <p class="text-xs text-gray-500 mt-1 line-clamp-2">@source.Notes</p>
                                    }
                                </div>
                                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                                    <button @onclick="() => EditSource(source)" class="p-1.5 text-gray-500 hover:text-emerald-400 transition-colors" title="Edit">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                    </button>
                                    <button @onclick="() => DeleteSourceAsync(source.Id)" class="p-1.5 text-gray-500 hover:text-rose-400 transition-colors" title="Delete">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                    @if (!workflowSources.Any())
                    {
                        <div class="text-center py-6 text-gray-600 text-xs">No evidence sources scoped to this workflow yet. Global sources still apply.</div>
                    }
                </div>
            </div>
        }

        @if (activeTab == "runs")
        {
            <div class="space-y-4">
                <div class="flex items-center justify-between gap-3">
                    <p class="text-xs text-gray-500">Tool calls from recent runs of this workflow.</p>
                    @if (selectedRunId is not null)
                    {
                        <a href="/admin/runs/@selectedRunId"
                           class="text-xs text-emerald-400 hover:text-emerald-300 transition-colors">
                            Open run detail →
                        </a>
                    }
                </div>

                @if (!workflowRuns.Any())
                {
                    <div class="text-center py-8 text-gray-600 text-xs">No runs recorded for this workflow yet.</div>
                }
                else
                {
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Run</label>
                        <select @bind="selectedRunId" @bind:after="LoadSelectedRunLogsAsync"
                                class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white focus:border-emerald-500 focus:outline-none transition-colors">
                            @foreach (var run in workflowRuns)
                            {
                                <option value="@run.RunId">
                                    @run.StartedAt.ToString("yyyy-MM-dd HH:mm:ss") • @run.Status • @run.RunId
                                </option>
                            }
                        </select>
                    </div>

                    <div class="space-y-2">
                        @foreach (var log in selectedRunLogs)
                        {
                            <div class="border border-gray-800 rounded-lg overflow-hidden">
                                <button @onclick="() => ToggleLog(log)"
                                        class="w-full flex items-center justify-between px-4 py-2.5 hover:bg-gray-900/50 transition-colors text-left">
                                    <div class="flex items-center gap-3">
                                        <span class="text-[10px] font-mono text-gray-600">@log.Iteration</span>
                                        <span class="text-xs font-medium text-emerald-400 font-mono">@log.ToolName</span>
                                        <span class="text-xs text-gray-500">@(log.DurationMs)ms</span>
                                    </div>
                                    <span class="text-xs text-gray-600 font-mono">@log.StartedAt.ToString("HH:mm:ss.fff")</span>
                                </button>
                                @if (expandedLogKeys.Contains(LogKey(log)))
                                {
                                    <div class="border-t border-gray-800 bg-gray-900/30">
                                        <div class="p-3">
                                            <div class="text-[10px] text-gray-500 mb-1 uppercase tracking-wider">Arguments</div>
                                            <pre class="text-xs text-gray-300 font-mono whitespace-pre-wrap break-all max-h-40 overflow-y-auto">@log.Args</pre>
                                        </div>
                                        <div class="p-3 border-t border-gray-800/50">
                                            <div class="text-[10px] text-gray-500 mb-1 uppercase tracking-wider">Result</div>
                                            <pre class="text-xs text-gray-300 font-mono whitespace-pre-wrap break-all max-h-60 overflow-y-auto">@log.Result</pre>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        @if (!selectedRunLogs.Any())
                        {
                            <div class="text-center py-8 text-gray-600 text-xs">No tool calls recorded for this run.</div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string WorkflowId { get; set; } = "";

    private WorkflowDefinition? workflow;
    private List<FraudPatternEntity> workflowPatterns = [];
    private List<EvidenceSource> workflowSources = [];
    private List<RunSummary> workflowRuns = [];
    private List<RunLog> selectedRunLogs = [];
    private HashSet<string> expandedLogKeys = [];
    private string? selectedRunId;
    private List<string> availableDatabases = ["lipila_blaze"];
    private string activeTab = "prompt";
    private bool saving;
    private string? feedbackMessage;
    private string feedbackKind = "success";

    // Pattern form state
    private bool showPatternForm;
    private int editingPatternId;
    private FraudPatternEntity editPattern = new() { Enabled = true };

    // Source form state
    private bool showSourceForm;
    private int editingSourceId;
    private EvidenceSource editSource = new() { Enabled = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadDatabasesAsync();
        await LoadWorkflowAsync();
    }

    private async Task LoadWorkflowAsync()
    {
        workflow = await WorkflowStore.GetByIdAsync(WorkflowId);
        if (workflow is null)
        {
            Nav.NavigateTo("/admin/workflows");
            return;
        }
        await ReloadScopedDataAsync();
        await ReloadRunsAsync();
    }

    private async Task ReloadScopedDataAsync()
    {
        workflowPatterns = await FraudPatternStore.GetByWorkflowAsync(WorkflowId);
        workflowSources = await EvidenceSourceStore.GetByWorkflowAsync(WorkflowId);
    }

    private async Task ReloadRunsAsync()
    {
        var runs = await RunLogStore.GetRecentRunsAsync(200);
        workflowRuns = runs
            .Where(r => r.TriggeredBy.Equals($"workflow:{WorkflowId}", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(r => r.StartedAt)
            .ToList();

        if (!workflowRuns.Any())
        {
            selectedRunId = null;
            selectedRunLogs = [];
            expandedLogKeys.Clear();
            return;
        }

        if (selectedRunId is null || !workflowRuns.Any(r => r.RunId == selectedRunId))
            selectedRunId = workflowRuns[0].RunId;

        await LoadSelectedRunLogsAsync();
    }

    private async Task LoadSelectedRunLogsAsync()
    {
        expandedLogKeys.Clear();
        if (string.IsNullOrWhiteSpace(selectedRunId))
        {
            selectedRunLogs = [];
            return;
        }

        selectedRunLogs = await RunLogStore.GetRunLogsAsync(selectedRunId);
    }

    private async Task LoadDatabasesAsync()
    {
        var dbs = await SchemaLoader.GetDatabasesAsync();
        availableDatabases = dbs.Count > 0 ? dbs.OrderBy(d => d).ToList() : ["lipila_blaze"];
    }

    // --- System Prompt ---
    private async Task SaveSystemPromptAsync()
    {
        if (workflow is null) return;
        saving = true;
        try
        {
            await WorkflowStore.UpsertAsync(workflow);
            SetFeedback("System prompt saved.");
        }
        catch (Exception ex)
        {
            SetFeedback($"Failed to save: {ex.Message}", "error");
        }
        finally { saving = false; }
    }

    // --- Fraud Patterns ---
    private void ShowPatternForm()
    {
        editPattern = new FraudPatternEntity { Enabled = true, WorkflowId = WorkflowId };
        editingPatternId = 0;
        showPatternForm = true;
    }

    private void EditPattern(FraudPatternEntity pattern)
    {
        editPattern = new FraudPatternEntity
        {
            Id = pattern.Id,
            Name = pattern.Name,
            Description = pattern.Description,
            Category = pattern.Category,
            Enabled = pattern.Enabled,
            WorkflowId = WorkflowId,
            CreatedAt = pattern.CreatedAt,
            CreatedBy = pattern.CreatedBy
        };
        editingPatternId = pattern.Id;
        showPatternForm = true;
    }

    private void CancelPatternForm()
    {
        showPatternForm = false;
        editPattern = new() { Enabled = true };
        editingPatternId = 0;
    }

    private async Task SavePatternAsync()
    {
        if (string.IsNullOrWhiteSpace(editPattern.Name))
        {
            SetFeedback("Pattern name is required.", "error");
            return;
        }

        saving = true;
        try
        {
            editPattern.WorkflowId = WorkflowId;
            if (editPattern.Id == 0)
            {
                // Generate a new ID for create
                var all = await FraudPatternStore.GetAllAsync();
                editPattern.Id = all.Count > 0 ? all.Max(p => p.Id) + 1 : 1;
                editPattern.CreatedBy = "admin";
            }
            await FraudPatternStore.UpsertAsync(editPattern);
            await ReloadScopedDataAsync();
            showPatternForm = false;
            editingPatternId = 0;
            SetFeedback(editingPatternId > 0 ? "Pattern updated." : "Pattern created.");
        }
        catch (Exception ex)
        {
            SetFeedback($"Failed to save pattern: {ex.Message}", "error");
        }
        finally { saving = false; }
    }

    private async Task DeletePatternAsync(int id)
    {
        try
        {
            await FraudPatternStore.DeleteAsync(id);
            await ReloadScopedDataAsync();
            SetFeedback("Pattern deleted.");
        }
        catch (Exception ex)
        {
            SetFeedback($"Failed to delete: {ex.Message}", "error");
        }
    }

    // --- Evidence Sources ---
    private void ShowSourceForm()
    {
        editSource = new EvidenceSource { Enabled = true, WorkflowId = WorkflowId };
        if (availableDatabases.Count > 0)
            editSource.EvidenceDatabase = availableDatabases[0];
        editingSourceId = 0;
        showSourceForm = true;
    }

    private void EditSource(EvidenceSource source)
    {
        editSource = new EvidenceSource
        {
            Id = source.Id,
            Name = source.Name,
            EvidenceDatabase = source.EvidenceDatabase,
            LipilaMerchantIds = source.LipilaMerchantIds,
            LipilaPartnerId = source.LipilaPartnerId,
            JoinMappings = source.JoinMappings,
            TableDescriptions = source.TableDescriptions,
            EvidenceChecks = source.EvidenceChecks,
            Notes = source.Notes,
            Enabled = source.Enabled,
            WorkflowId = WorkflowId,
            CreatedAt = source.CreatedAt,
            CreatedBy = source.CreatedBy
        };
        editingSourceId = source.Id;
        showSourceForm = true;
    }

    private void CancelSourceForm()
    {
        showSourceForm = false;
        editSource = new() { Enabled = true };
        editingSourceId = 0;
    }

    private async Task SaveSourceAsync()
    {
        if (string.IsNullOrWhiteSpace(editSource.Name))
        {
            SetFeedback("Source name is required.", "error");
            return;
        }

        saving = true;
        try
        {
            editSource.WorkflowId = WorkflowId;
            if (editSource.Id == 0)
            {
                var all = await EvidenceSourceStore.GetAllAsync();
                editSource.Id = all.Count > 0 ? all.Max(s => s.Id) + 1 : 1;
                editSource.CreatedBy = "admin";
            }
            await EvidenceSourceStore.UpsertAsync(editSource);
            await ReloadScopedDataAsync();
            showSourceForm = false;
            editingSourceId = 0;
            SetFeedback(editingSourceId > 0 ? "Evidence source updated." : "Evidence source created.");
        }
        catch (Exception ex)
        {
            SetFeedback($"Failed to save source: {ex.Message}", "error");
        }
        finally { saving = false; }
    }

    private async Task DeleteSourceAsync(int id)
    {
        try
        {
            await EvidenceSourceStore.DeleteAsync(id);
            await ReloadScopedDataAsync();
            SetFeedback("Evidence source deleted.");
        }
        catch (Exception ex)
        {
            SetFeedback($"Failed to delete: {ex.Message}", "error");
        }
    }

    // --- Helpers ---
    private void SetFeedback(string message, string kind = "success")
    {
        feedbackMessage = message;
        feedbackKind = kind;
    }

    private void ClearFeedback() => feedbackMessage = null;

    private static string LogKey(RunLog log) =>
        $"{log.Iteration}|{log.ToolName}|{log.StartedAt.Ticks}";

    private void ToggleLog(RunLog log)
    {
        var key = LogKey(log);
        if (!expandedLogKeys.Remove(key))
            expandedLogKeys.Add(key);
    }

    private string FeedbackClass() => feedbackKind switch
    {
        "error" => "rounded-lg border border-rose-500/40 bg-rose-500/10 px-3 py-2 text-xs text-rose-300",
        "info" => "rounded-lg border border-blue-500/40 bg-blue-500/10 px-3 py-2 text-xs text-blue-300",
        _ => "rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-2 text-xs text-emerald-300"
    };

    private string TabClass(string tab) => tab == activeTab
        ? "pb-2 text-sm font-medium text-emerald-400 border-b-2 border-emerald-400 transition-colors"
        : "pb-2 text-sm font-medium text-gray-500 hover:text-gray-300 border-b-2 border-transparent transition-colors";
}
