    private static readonly Dictionary<string, string> CronPresets = new(StringComparer.OrdinalIgnoreCase)
    {
        ["every-5-minutes"] = "*/5 * * * *",
        ["every-15-minutes"] = "*/15 * * * *",
        ["every-30-minutes"] = "*/30 * * * *",
        ["hourly"] = "0 * * * *",
        ["every-2-hours"] = "0 */2 * * *",
        ["daily"] = "0 0 * * *",
        ["weekly"] = "0 0 * * 1"
    };

    private static string DetectSchedulePreset(string? cron)
    {
        if (string.IsNullOrWhiteSpace(cron))
            return "hourly";

        foreach (var preset in CronPresets)
        {
            if (string.Equals(preset.Value, cron.Trim(), StringComparison.OrdinalIgnoreCase))
                return preset.Key;
        }

        return IsCustomDateCron(cron) ? "custom-date" : "hourly";
    }

    private static bool IsCustomDateCron(string cron)
    {
        var parts = cron.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length == 5 &&
               int.TryParse(parts[0], out _) &&
               int.TryParse(parts[1], out _) &&
               int.TryParse(parts[2], out _) &&
               int.TryParse(parts[3], out _) &&
               parts[4] == "*";
    }

    private static string? BuildDateTimeLocalFromCron(string? cron, string? timeZoneId)
    {
        if (string.IsNullOrWhiteSpace(cron))
            return null;

        var parts = cron.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length != 5 ||
            !int.TryParse(parts[0], out var minute) ||
            !int.TryParse(parts[1], out var hour) ||
            !int.TryParse(parts[2], out var day) ||
            !int.TryParse(parts[3], out var month) ||
            month is < 1 or > 12 ||
            day < 1)
        {
            return null;
        }

        var zone = WorkflowTimeZones.ResolveOrDefault(timeZoneId);
        var now = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, zone);
        var maxDay = DateTime.DaysInMonth(now.Year, month);
        if (day > maxDay || hour is < 0 or > 23 || minute is < 0 or > 59)
            return null;

        var date = new DateTime(now.Year, month, day, hour, minute, 0, DateTimeKind.Unspecified);
        return date.ToString("yyyy-MM-ddTHH:mm");
    }

    private static string? BuildCustomDateCron(string? dateTimeLocal, string? timeZoneId)
    {
        _ = WorkflowTimeZones.ResolveOrDefault(timeZoneId);
        if (string.IsNullOrWhiteSpace(dateTimeLocal))
            return null;

        if (!DateTime.TryParse(dateTimeLocal, out var selected))
            return null;

        return $"{selected.Minute} {selected.Hour} {selected.Day} {selected.Month} *";
    }

    private static string FormatDuration(TimeSpan? duration)
    {
        if (duration == null) return "—";
        var d = duration.Value;
        if (d.TotalSeconds < 60) return $"{d.TotalSeconds:F0}s";
        if (d.TotalMinutes < 60) return $"{d.TotalMinutes:F0}m {d.Seconds}s";
        return $"{d.TotalHours:F0}h {d.Minutes}m";
    }

    private static string FormatRelativeTime(DateTimeOffset? utcTime)
    {
        if (utcTime == null) return "Never";
        var diff = DateTimeOffset.UtcNow - utcTime.Value;
        if (diff.TotalSeconds < 0) // Future
        {
            var future = -diff;
            if (future.TotalMinutes < 1) return "< 1 min";
            if (future.TotalMinutes < 60) return $"in {future.TotalMinutes:F0}m";
            if (future.TotalHours < 24) return $"in {future.TotalHours:F0}h {future.Minutes}m";
            return utcTime.Value.ToString("MMM dd HH:mm");
        }
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{diff.TotalMinutes:F0}m ago";
        if (diff.TotalHours < 24) return $"{diff.TotalHours:F0}h ago";
        if (diff.TotalDays < 7) return $"{diff.TotalDays:F0}d ago";
        return utcTime.Value.ToString("MMM dd");
    }

    private class WorkflowRunState
    {
        public string TimeZoneId { get; set; } = WorkflowTimeZones.DefaultId;
        public DateTimeOffset? LastRunAt { get; set; }
        public string? LastRunStatus { get; set; }
        public TimeSpan? LastRunDuration { get; set; }
        public DateTimeOffset? NextRunAt { get; set; }
        public bool IsRunning { get; set; }
        public int TotalRuns { get; set; }
        public int SuccessfulRuns { get; set; }
        public int FailedRuns { get; set; }
    }

    private static string DisplayTimeZone(string? timeZoneId) =>
        WorkflowTimeZones.Options.FirstOrDefault(z => string.Equals(z.Id, WorkflowTimeZones.NormalizeOrDefaultId(timeZoneId), StringComparison.OrdinalIgnoreCase))?.Label
        ?? WorkflowTimeZones.DefaultId;

