        _ => db
    };

    private static readonly IReadOnlyList<string> AllowedDatabases =
    [
        "inshuwa", // insurer
        "lipila_blaze",
        "bnpl",
        "patumba_app"
    ];

    private static string FormatInZone(DateTimeOffset? utcTime, string? timeZoneId)
    {
        if (utcTime == null) return "Never";
        var zone = WorkflowTimeZones.ResolveOrDefault(timeZoneId);
        var inZone = TimeZoneInfo.ConvertTime(utcTime.Value, zone);
        return $"{inZone:yyyy-MM-dd HH:mm:ss} {zone.StandardName}";
    }
