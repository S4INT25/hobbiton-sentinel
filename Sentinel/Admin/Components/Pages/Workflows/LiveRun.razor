@page "/admin/workflows/{WorkflowId}/live/{RunId}"
@inject IRunLogStore RunLogStore
@inject IWorkflowStore WorkflowStore
@inject IActiveRunTracker RunTracker
@inject RunCancellationRegistry CancellationRegistry
@inject NavigationManager Nav
@attribute [Authorize(Policy = AuthConstants.AdminOnlyPolicy)]
@implements IDisposable

<PageTitle>Live Run — Sentinel</PageTitle>

<div class="space-y-4">
    <div class="flex items-center gap-3">
        <a href="/admin/workflows/@WorkflowId"
           class="p-1.5 text-gray-500 hover:text-white transition-colors rounded-md hover:bg-gray-800">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
        </a>
        <div class="flex-1">
            <h1 class="text-lg font-semibold text-white">
                @(workflow?.Name ?? "Workflow") — Live Run
            </h1>
            <p class="text-xs text-gray-500 mt-0.5 font-mono">@RunId</p>
        </div>
        <div class="flex items-center gap-2">
            @if (runStatus is "running" or "queued")
            {
                <button @onclick="StopRun" disabled="@stopping"
                        class="px-3 py-1.5 text-xs font-medium bg-rose-600 hover:bg-rose-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                    @(stopping ? "Stopping..." : "Stop Run")
                </button>
            }
            <a href="/admin/runs/@RunId?workflowId=@Uri.EscapeDataString(WorkflowId)"
               class="px-3 py-1.5 text-xs border border-gray-800 text-gray-400 hover:text-white hover:bg-gray-900 rounded-md transition-colors">
                Full detail
            </a>
        </div>
    </div>

    @* Status bar *@
    <div class="border rounded-lg p-3 @StatusBarClasses()">
        <div class="flex items-center gap-3">
            @if (runStatus is "running" or "queued")
            {
                <svg class="w-4 h-4 animate-spin shrink-0" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"/>
                    <path class="opacity-90" fill="currentColor" d="M4 12a8 8 0 018-8v3a5 5 0 00-5 5H4z"/>
                </svg>
            }
            else if (runStatus == "completed")
            {
                <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
            }
            else if (runStatus is "error" or "failed")
            {
                <svg class="w-4 h-4 text-rose-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            }
            else if (runStatus == "stopped")
            {
                <svg class="w-4 h-4 text-amber-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10h6v4H9z"/>
                </svg>
            }
            <div class="flex-1 min-w-0">
                <span class="text-sm font-medium capitalize">@(runStatus ?? "unknown")</span>
                @if (runStatus is "running" or "queued")
                {
                    <span class="text-xs text-gray-500 ml-2">@toolCalls.Count tool calls so far</span>
                }
            </div>
            @if (summary != null)
            {
                <div class="flex items-center gap-3 text-xs text-gray-500">
                    @if (summary.FinishedAt > summary.StartedAt)
                    {
                        <span>@FormatDuration(summary.FinishedAt - summary.StartedAt)</span>
                    }
                    <span class="font-mono tabular-nums">@((summary.InputTokens + summary.OutputTokens).ToString("N0")) tokens</span>
                </div>
            }
        </div>
        @if (summary is { Status: "error" or "failed" } && !string.IsNullOrWhiteSpace(summary.Error))
        {
            <div class="mt-2 p-2 bg-rose-500/10 border border-rose-500/20 rounded text-xs text-rose-400 whitespace-pre-wrap">@summary.Error</div>
        }
    </div>

    @* Live tool call timeline *@
    <div class="space-y-2">
        <h2 class="text-xs font-medium text-gray-400 uppercase tracking-wider">Tool Calls</h2>
        @if (!toolCalls.Any())
        {
            <div class="text-center py-8 text-gray-600 text-xs">
                @if (runStatus is "running" or "queued")
                {
                    <span>Waiting for the agent to start querying...</span>
                }
                else
                {
                    <span>No tool calls recorded.</span>
                }
            </div>
        }
        else
        {
            @foreach (var log in toolCalls)
            {
                <div class="border border-gray-800 rounded-lg overflow-hidden animate-in">
                    <button @onclick="() => ToggleLog(log)"
                            class="w-full flex items-center justify-between px-4 py-2.5 hover:bg-gray-900/50 transition-colors text-left">
                        <div class="flex items-center gap-3">
                            <span class="text-[10px] font-mono text-gray-600">@log.Iteration</span>
                            <span class="text-xs font-medium text-emerald-400 font-mono">@log.ToolName</span>
                            <span class="text-xs text-gray-500">@(log.DurationMs)ms</span>
                        </div>
                        <span class="text-xs text-gray-600 font-mono">@log.StartedAt.ToString("HH:mm:ss.fff")</span>
                    </button>
                    @if (expandedKeys.Contains(LogKey(log)))
                    {
                        <div class="border-t border-gray-800 bg-gray-900/30">
                            <div class="p-3">
                                <div class="text-[10px] text-gray-500 mb-1 uppercase tracking-wider">Arguments</div>
                                <pre class="text-xs text-gray-300 font-mono whitespace-pre-wrap break-all max-h-40 overflow-y-auto">@log.Args</pre>
                            </div>
                            <div class="p-3 border-t border-gray-800/50">
                                <div class="text-[10px] text-gray-500 mb-1 uppercase tracking-wider">Result</div>
                                <pre class="text-xs text-gray-300 font-mono whitespace-pre-wrap break-all max-h-60 overflow-y-auto">@log.Result</pre>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public string WorkflowId { get; set; } = "";
    [Parameter] public string RunId { get; set; } = "";

    private WorkflowDefinition? workflow;
    private RunSummary? summary;
    private string? runStatus;
    private List<RunLog> toolCalls = [];
    private HashSet<string> expandedKeys = [];
    private bool stopping;

    private PeriodicTimer? pollTimer;
    private CancellationTokenSource? pollCts;

    protected override async Task OnInitializedAsync()
    {
        workflow = await WorkflowStore.GetByIdAsync(WorkflowId);
        await RefreshAsync();
        StartPolling();
    }

    private async Task RefreshAsync()
    {
        // Check the live tracker first (for running/queued state), then fall back to summary
        var tracked = await RunTracker.GetAsync(RunId);
        summary = await RunLogStore.GetRunSummaryAsync(RunId);

        if (tracked != null)
            runStatus = tracked.Status;
        else if (summary != null)
            runStatus = summary.Status;
        else
            runStatus = "queued";

        toolCalls = await RunLogStore.GetRunLogsAsync(RunId);
    }

    private void StartPolling()
    {
        StopPolling();
        pollCts = new CancellationTokenSource();
        pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        var token = pollCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                while (await pollTimer.WaitForNextTickAsync(token))
                {
                    await InvokeAsync(async () =>
                    {
                        var prevCount = toolCalls.Count;
                        await RefreshAsync();

                        // Stop polling once the run has finished
                        if (runStatus is "completed" or "error" or "failed" or "stopped")
                            StopPolling();

                        StateHasChanged();
                    });
                }
            }
            catch (OperationCanceledException)
            {
            }
        }, token);
    }

    private void StopPolling()
    {
        pollCts?.Cancel();
        pollTimer?.Dispose();
        pollCts?.Dispose();
        pollTimer = null;
        pollCts = null;
    }

    private async Task StopRun()
    {
        stopping = true;
        try
        {
            CancellationRegistry.Cancel(RunId);
            await RunTracker.MarkStoppedAsync(RunId);
            runStatus = "stopped";
        }
        catch
        {
        }
        finally
        {
            stopping = false;
        }
    }

    private void ToggleLog(RunLog log)
    {
        var key = LogKey(log);
        if (!expandedKeys.Remove(key))
            expandedKeys.Add(key);
    }

    private static string LogKey(RunLog log) =>
            $"{log.Iteration}|{log.ToolName}|{log.StartedAt.Ticks}";

    private string StatusBarClasses() => runStatus switch
    {
            "running" or "queued" => "border-blue-500/30 bg-blue-500/5",
            "completed" => "border-emerald-500/30 bg-emerald-500/5",
            "error" or "failed" => "border-rose-500/30 bg-rose-500/5",
            "stopped" => "border-amber-500/30 bg-amber-500/5",
            _ => "border-gray-800 bg-gray-900/30"
    };

    private static string FormatDuration(TimeSpan? duration)
    {
        if (duration == null) return "";
        var d = duration.Value;
        if (d.TotalSeconds < 60) return $"{d.TotalSeconds:F0}s";
        if (d.TotalMinutes < 60) return $"{d.TotalMinutes:F0}m {d.Seconds}s";
        return $"{d.TotalHours:F0}h {d.Minutes}m";
    }

    public void Dispose() => StopPolling();
}
