@page "/admin/prompt"
@inject ISystemPromptStore PromptStore
@inject IAuditLogStore AuditStore
@inject AuthenticationStateProvider AuthState
@inject IHttpContextAccessor HttpContextAccessor
@attribute [Authorize(Policy = AuthConstants.Policy)]
@rendermode InteractiveServer

<PageTitle>System Prompt — Sentinel</PageTitle>

<div class="space-y-4">
    <div class="flex items-center justify-between">
        <h1 class="text-lg font-semibold text-white">System Prompt</h1>
        @if (current != null)
        {
            <div class="text-xs text-gray-500">
                Last updated by <span class="text-gray-400">@current.UpdatedBy</span>
                on @current.UpdatedAt?.ToString("MMM dd HH:mm")
            </div>
        }
    </div>

    <div class="space-y-3">
        <div class="border border-gray-800 rounded-lg overflow-hidden">
            <textarea @bind="promptText" rows="30"
                      class="w-full p-4 bg-gray-900 text-xs text-gray-200 font-mono resize-y focus:outline-none"
                      placeholder="Leave empty to use default system prompt..."></textarea>
        </div>
        <div class="flex items-center gap-3">
            <button @onclick="SavePrompt" class="px-4 py-2 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-colors">
                Save Override
            </button>
            @if (current != null)
            {
                <button @onclick="ResetPrompt" class="px-4 py-2 text-xs text-gray-400 hover:text-rose-400 transition-colors">
                    Reset to Default
                </button>
            }
        </div>
    </div>

    @if (history.Any())
    {
        <div class="border-t border-gray-800 pt-4">
            <h2 class="text-sm font-medium text-gray-400 mb-3">History</h2>
            <div class="space-y-2">
                @foreach (var h in history)
                {
                    <div class="flex items-center justify-between px-3 py-2 bg-gray-900/30 border border-gray-800/50 rounded text-xs">
                        <span class="text-gray-400">@h.UpdatedBy</span>
                        <span class="text-gray-500 font-mono">@h.UpdatedAt?.ToString("MMM dd HH:mm")</span>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private SystemPromptOverride? current;
    private string? promptText;
    private List<SystemPromptOverride> history = [];

    protected override async Task OnInitializedAsync()
    {
        current = await PromptStore.GetOverrideAsync();
        promptText = current?.PromptText;
        history = await PromptStore.GetHistoryAsync();
    }

    private async Task SavePrompt()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        var username = user.Identity?.Name ?? "unknown";

        await PromptStore.SaveOverrideAsync(promptText ?? "", username);
        await AuditStore.LogAsync(new AuditLog
        {
            UserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
            Username = username,
            Action = "update",
            ResourceType = "prompt",
            ResourceId = "system_prompt",
            Details = "Prompt override saved",
            IpAddress = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? ""
        });

        current = await PromptStore.GetOverrideAsync();
        history = await PromptStore.GetHistoryAsync();
    }

    private async Task ResetPrompt()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        var username = user.Identity?.Name ?? "unknown";

        await PromptStore.ClearOverrideAsync();
        await AuditStore.LogAsync(new AuditLog
        {
            UserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
            Username = username,
            Action = "reset",
            ResourceType = "prompt",
            ResourceId = "system_prompt",
            Details = "Reverted to default prompt",
            IpAddress = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? ""
        });

        current = null;
        promptText = null;
        history = await PromptStore.GetHistoryAsync();
    }
}
