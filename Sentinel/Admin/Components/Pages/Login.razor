@page "/admin/login"
@layout EmptyLayout
@attribute [AllowAnonymous]

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorParam { get; set; }

    [SupplyParameterFromQuery(Name = "reset")]
    public string? ResetParam { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrlParam { get; set; }

    private string SafeReturnUrl =>
        !string.IsNullOrWhiteSpace(ReturnUrlParam) && ReturnUrlParam.StartsWith("/")
            ? ReturnUrlParam
            : "/admin/chat";
}

<PageTitle>Sign in — Sentinel</PageTitle>

<div class="h-full flex items-center justify-center">
    <div class="w-full max-w-sm px-6">
        <div class="text-center mb-8">
            <img src="https://hobbiton.tech/assets/logo2-7db998ca.png" alt="Hobbition logo" class="w-50 h-24 mx-auto mb-3 rounded-lg object-contain" />
            <h1 class="text-lg font-semibold text-white">Sentinel</h1>
            <p class="text-sm text-gray-500 mt-1">Sign in to continue</p>
        </div>

        @if (ResetParam == "1")
        {
            <div class="mb-4 p-3 rounded-md bg-emerald-500/10 border border-emerald-500/20 text-sm text-emerald-400">
                Password updated. You can now sign in with your new password.
            </div>
        }
        @if (ErrorParam == "invalid")
        {
            <div class="mb-4 p-3 rounded-md bg-rose-500/10 border border-rose-500/20 text-sm text-rose-400">
                Invalid username or password
            </div>
        }

        @* Native HTML form POST — bypasses Blazor's interactive circuit entirely.
           The /admin/auth/signin endpoint handles SignInAsync and redirects. *@
        <form action="/admin/auth/signin" method="post" class="space-y-4">
            <input type="hidden" name="returnUrl" value="@SafeReturnUrl" />
            <div>
                <label class="block text-xs font-medium text-gray-400 mb-1.5">Email or username</label>
                <input type="text" name="username" required autocomplete="username" autofocus
                       class="w-full px-3 py-2 bg-gray-900 border border-gray-800 rounded-md text-sm text-white placeholder-gray-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-400 mb-1.5">Password</label>
                <input type="password" name="password" required autocomplete="current-password"
                       class="w-full px-3 py-2 bg-gray-900 border border-gray-800 rounded-md text-sm text-white placeholder-gray-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20" />
            </div>
            <button type="submit"
                    class="w-full py-2 px-4 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-md transition-colors">
                Sign in
            </button>
            <div class="text-center">
                <a href="/admin/forgot-password" class="text-xs text-gray-500 hover:text-emerald-400 transition-colors">Forgot your password?</a>
            </div>
        </form>

        <p class="mt-6 text-center text-xs text-gray-500">
            New to Sentinel?
            <a href="/admin/signup" class="text-emerald-400 hover:text-emerald-300">Create an account</a>
        </p>
    </div>
</div>
