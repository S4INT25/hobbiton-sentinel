@page "/admin/rules"
@inject IFeedbackRuleStore RuleStore
@inject IAuditLogStore AuditStore
@inject AuthenticationStateProvider AuthState
@inject IHttpContextAccessor HttpContextAccessor
@attribute [Authorize(Policy = AuthConstants.Policy)]
@rendermode InteractiveServer

<PageTitle>Rules — Sentinel</PageTitle>

<div class="space-y-4">
    <div class="flex items-center justify-between">
        <h1 class="text-lg font-semibold text-white">Feedback Rules</h1>
        <button @onclick="() => showAdd = !showAdd" class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-colors">
            Add Rule
        </button>
    </div>

    @if (showAdd)
    {
        <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50 space-y-3">
            <EditForm Model="newRule" OnValidSubmit="CreateRule" FormName="create-rule" class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Rule Type</label>
                    <select @bind="newRule.RuleType" class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                        <option value="ip">IP Address</option>
                        <option value="cidr">CIDR Range</option>
                        <option value="asn">ASN</option>
                        <option value="pattern_id">Pattern ID</option>
                        <option value="keyword">Keyword</option>
                        <option value="recipient">Recipient</option>
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Match Value</label>
                    <input type="text" @bind="newRule.MatchValue" required class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white" placeholder="e.g. 159.89.x.x or AS14061" />
                </div>
                <div>
                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Action</label>
                    <select @bind="newRule.Action" class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                        <option value="suppress">Suppress</option>
                        <option value="downgrade">Downgrade</option>
                        <option value="info_only">Info Only</option>
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Scope</label>
                    <select @bind="newRule.Scope" class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                        <option value="global">Global</option>
                        <option value="merchant">Merchant</option>
                        <option value="user">User</option>
                    </select>
                </div>
                <div class="col-span-2">
                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Reason</label>
                    <input type="text" @bind="newRule.Reason" required class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white" placeholder="Why this is safe / known good" />
                </div>
                <div class="col-span-2 flex justify-end gap-2">
                    <button type="button" @onclick="() => showAdd = false" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white">Cancel</button>
                    <button type="submit" class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md">Save</button>
                </div>
            </EditForm>
        </div>
    }

    <!-- Rules Table -->
    <div class="border border-gray-800 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-900/50">
                <tr class="text-xs text-gray-500 border-b border-gray-800">
                    <th class="text-left px-4 py-2 font-medium">Type</th>
                    <th class="text-left px-4 py-2 font-medium">Match</th>
                    <th class="text-left px-4 py-2 font-medium">Action</th>
                    <th class="text-left px-4 py-2 font-medium">Reason</th>
                    <th class="text-left px-4 py-2 font-medium">Hits</th>
                    <th class="text-left px-4 py-2 font-medium">Created</th>
                    <th class="text-left px-4 py-2 font-medium"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800/50">
                @foreach (var rule in PagedRules)
                {
                    <tr class="hover:bg-gray-900/30 transition-colors">
                        <td class="px-4 py-2.5">
                            <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-800 text-gray-300">@rule.RuleType</span>
                        </td>
                        <td class="px-4 py-2.5 text-xs font-mono text-gray-200">@rule.MatchValue</td>
                        <td class="px-4 py-2.5">
                            @if (rule.Action == "suppress")
                            {
                                <span class="text-[10px] text-rose-400">suppress</span>
                            }
                            else if (rule.Action == "downgrade")
                            {
                                <span class="text-[10px] text-amber-400">downgrade</span>
                            }
                            else
                            {
                                <span class="text-[10px] text-blue-400">info_only</span>
                            }
                        </td>
                        <td class="px-4 py-2.5 text-xs text-gray-400 max-w-xs truncate">@rule.Reason</td>
                        <td class="px-4 py-2.5 text-xs font-mono text-gray-500">@rule.HitCount</td>
                        <td class="px-4 py-2.5 text-xs text-gray-500">@rule.CreatedAt.ToString("MMM dd")</td>
                        <td class="px-4 py-2.5">
                            <button @onclick="() => DeleteRule(rule.Id)" class="text-xs text-gray-600 hover:text-rose-400 transition-colors">Delete</button>
                        </td>
                    </tr>
                }
                @if (!rules.Any())
                {
                    <tr><td colspan="7" class="px-4 py-8 text-center text-gray-600 text-xs">No rules configured</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if (rules.Count > PageSize)
    {
        <div class="mt-3 flex items-center justify-between text-xs">
            <span class="text-gray-500">Page @currentPage / @TotalPages</span>
            <div class="flex items-center gap-2">
                <button @onclick="PrevPage" disabled="@(currentPage <= 1)" class="px-2.5 py-1 border border-gray-800 rounded text-gray-300 disabled:opacity-40">Previous</button>
                <button @onclick="NextPage" disabled="@(currentPage >= TotalPages)" class="px-2.5 py-1 border border-gray-800 rounded text-gray-300 disabled:opacity-40">Next</button>
            </div>
        </div>
    }
</div>

@code {
    private List<FeedbackRule> rules = [];
    private bool showAdd;
    private FeedbackRule newRule = new() { RuleType = "ip", Action = "suppress", Scope = "global" };
    private int currentPage = 1;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)rules.Count / PageSize));
    private IEnumerable<FeedbackRule> PagedRules => rules.Skip((currentPage - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        rules = await RuleStore.GetAllRulesAsync();
        currentPage = Math.Min(currentPage, TotalPages);
    }

    private async Task CreateRule()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        newRule.CreatedBy = user.Identity?.Name ?? "unknown";
        await RuleStore.SaveAsync(newRule);
        await AuditStore.LogAsync(new AuditLog
        {
            UserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
            Username = user.Identity?.Name ?? "unknown",
            Action = "create",
            ResourceType = "rule",
            ResourceId = newRule.Id,
            Details = $"{newRule.RuleType}: {newRule.MatchValue} → {newRule.Action}",
            IpAddress = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? ""
        });

        newRule = new() { RuleType = "ip", Action = "suppress", Scope = "global" };
        showAdd = false;
        rules = await RuleStore.GetAllRulesAsync();
        currentPage = Math.Min(currentPage, TotalPages);
    }

    private async Task DeleteRule(string ruleId)
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        await RuleStore.DeleteAsync(ruleId);
        await AuditStore.LogAsync(new AuditLog
        {
            UserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
            Username = user.Identity?.Name ?? "unknown",
            Action = "delete",
            ResourceType = "rule",
            ResourceId = ruleId,
            IpAddress = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? ""
        });

        rules = await RuleStore.GetAllRulesAsync();
        currentPage = Math.Min(currentPage, TotalPages);
    }

    private void PrevPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }
}
