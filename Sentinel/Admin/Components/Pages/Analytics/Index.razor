    private static readonly HashSet<string> AmountColumnHints =
        new(StringComparer.OrdinalIgnoreCase) { "amount", "total", "volume", "sum", "value", "balance", "fee", "charge", "revenue" };

    private static string FormatCell(string? value, string? columnName = null)
    {
        if (string.IsNullOrEmpty(value)) return "";
        if (double.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var num))
        {
            var isAmountCol = columnName != null && AmountColumnHints.Any(h => columnName.Contains(h, StringComparison.OrdinalIgnoreCase));
            if (isAmountCol)
                return $"K {num:N2}";
            if (num > 999)
                return num.ToString("N0");
        }

        return value;
    }

