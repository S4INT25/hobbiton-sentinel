@page "/admin/chat"
@page "/admin/analytics"
@inject IAnalyticsChatStore ChatStore
@inject IAnalyticsJobStore JobStore
@inject AnalyticsQueryWorker Worker
@inject ClickHouseClient ClickHouse
@inject SchemaLoader SchemaLoader
@inject IFusionCache Cache
@inject IDatabaseProductStore ProductStore
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject NavigationManager Navigation
@attribute [Authorize(Policy = AuthConstants.Policy)]
@using System.Globalization
@using System.Text.Json
@using System.Text.RegularExpressions
@using Sentinel.Infrastructure
@using ZiggyCreatures.Caching.Fusion
@implements IDisposable

<PageTitle>Chat — Sentinel</PageTitle>

<div class="flex flex-col md:flex-row h-[calc(100vh-6rem)]">
    <!-- Conversation Sidebar -->
    <div
        class="@(showHistoryPanel ? "flex" : "hidden") w-full md:w-56 border-b md:border-b-0 md:border-r border-gray-800 flex-col shrink-0 max-h-64 md:max-h-none transition-all">
        <div class="flex items-center justify-between px-3 py-2 border-b border-gray-800">
            <span class="text-xs font-medium text-gray-400">History</span>
            <div class="flex items-center gap-1.5">
                <button @onclick="NewConversation"
                        class="px-2 py-1 text-[10px] bg-emerald-600 hover:bg-emerald-500 text-white rounded transition-colors">
                    + New
                </button>
                <button @onclick="() => showHistoryPanel = false"
                        class="p-1 text-gray-500 hover:text-gray-300 rounded hover:bg-gray-800 transition-colors"
                        title="Close history">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        </div>
        <div class="flex-1 overflow-y-auto p-1.5 space-y-0.5">
            @foreach (var conv in conversations)
            {
                <div @onclick="() => LoadConversation(conv.Id)"
                     class="px-2.5 py-2 rounded border cursor-pointer group transition-colors @(conv.Id == activeConversationId ? "bg-gray-800/60 border-emerald-500/30" : "border-transparent hover:bg-gray-900")">
                    <div class="text-xs text-gray-300 truncate">@conv.Title</div>
                    <div class="flex items-center justify-between mt-0.5">
                        <span class="text-[10px] text-gray-600">@conv.Database</span>
                        <button @onclick="() => DeleteConversation(conv.Id)" @onclick:stopPropagation="true"
                                class="opacity-0 group-hover:opacity-100 text-[10px] text-rose-500 hover:text-rose-400 transition-opacity">
                            ✕
                        </button>
                    </div>
                </div>
            }
            @if (!conversations.Any())
            {
                <div class="px-3 py-4 text-center text-[10px] text-gray-600">No conversations yet</div>
            }
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="flex-1 flex flex-col min-w-0">
        <div class="flex items-center justify-between px-4 py-2 border-b border-gray-800">
            <div class="flex items-center gap-2 md:gap-3 flex-wrap">
                <button @onclick="() => showHistoryPanel = !showHistoryPanel"
                        class="px-2.5 py-1.5 text-xs border rounded transition-colors whitespace-nowrap @(showHistoryPanel ? "bg-gray-800 border-gray-700 text-gray-200" : "border-gray-800 text-gray-500 hover:text-gray-300 hover:bg-gray-900")"
                        title="@(showHistoryPanel ? "Hide history" : "Show history")">
                    <span class="flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
                                stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        History
                    </span>
                </button>
                <span class="text-[10px] text-gray-500 uppercase tracking-wider">Product</span>
                <select value="@database" @onchange="OnDatabaseChanged" title="Product"
                        class="px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                    @foreach (var db in databases)
                    {
                        <option value="@db">@GetProductLabel(db)</option>
                    }
                </select>
                <select value="@mode" @onchange="OnModeChanged"
                        class="px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                    <option value="general">General</option>
                    <option value="fraud">Fraud Detection</option>
                </select>
                @if (!string.IsNullOrEmpty(dbLoadError))
                {
                    <span class="text-[10px] text-rose-400 truncate max-w-xs"
                          title="@dbLoadError">⚠ DB load failed</span>
                }
                @if (activePolls.Count > 0)
                {
                    <span
                        class="inline-flex items-center gap-1.5 text-[10px] px-2 py-1 rounded-full border border-emerald-500/30 bg-emerald-500/10 text-emerald-300">
                        <svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor"
                                    stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor"
                                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                        </svg>
                        Query running
                    </span>
                }
            </div>
            <div class="flex items-center gap-2">
                <a href="@($"/admin/present{(string.IsNullOrEmpty(activeConversationId) ? "" : "?conv=" + activeConversationId)}")"
                   class="px-2.5 py-1.5 text-xs border rounded transition-colors @(messages.Any(m => m.Role == "assistant") ? "border-gray-800 text-gray-500 hover:text-gray-300 hover:bg-gray-900" : "border-gray-800 text-gray-700 cursor-not-allowed pointer-events-none") whitespace-nowrap"
                   title="View insights as presentation">
                    <span class="flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                        Present
                    </span>
                </a>
                <button @onclick="() => debugMode = !debugMode"
                        class="px-2.5 py-1.5 text-xs border rounded transition-colors whitespace-nowrap @(debugMode ? "bg-amber-600/20 border-amber-500/40 text-amber-300" : "border-gray-800 text-gray-500 hover:text-gray-300 hover:bg-gray-900")"
                        title="@(debugMode ? "Hide debug info" : "Show SQL, reasoning & timeline")">
                    <span class="flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
                                stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                        Debug
                    </span>
                </button>
                <button @onclick="ClearChat"
                        class="px-2.5 py-1.5 text-xs text-gray-500 hover:text-gray-300 border border-gray-800 rounded hover:bg-gray-900 transition-colors whitespace-nowrap">
                    Clear
                </button>
            </div>
        </div>

        @if (showBetaDisclaimer)
        {
            <div
                class="mx-4 mt-3 rounded-lg border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-[11px] text-amber-200">
                <div class="flex items-start justify-between gap-3">
                    <p>
                        <span class="font-semibold">Beta disclaimer:</span> this assistant is still in beta and may
                        produce inaccurate information or wrong values when context is incomplete.
                    </p>
                    <button @onclick="DismissBetaDisclaimer"
                            class="shrink-0 text-amber-300 hover:text-amber-100 transition-colors"
                            title="Dismiss disclaimer">
                        ✕
                    </button>
                </div>
            </div>
        }

        <div class="flex-1 min-h-0">
            <div class="flex flex-col min-h-0 min-w-0 h-full">
                <!-- Chat Messages -->
                <div class="flex-1 overflow-y-auto space-y-4 p-4 pr-2" @ref="messagesContainer">
                    @foreach (var (msg, idx) in messages.Select((m, i) => (m, i)))
                    {
                        @if (msg.Role == "user")
                        {
                            <div class="flex justify-end">
                                <div
                                    class="max-w-2xl px-3 py-2 bg-emerald-600/20 border border-emerald-500/20 rounded-xl text-sm text-gray-200">
                                    @msg.Content
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="space-y-3 max-w-full border rounded-xl p-4 bg-gray-900/35 border-gray-800">

                                @if (!string.IsNullOrEmpty(msg.Error))
                                {
                                    <div
                                        class="p-3 bg-rose-500/10 border border-rose-500/20 rounded-lg text-xs text-rose-400 font-mono whitespace-pre-wrap">@msg.Error</div>
                                }

                                @if (!string.IsNullOrEmpty(msg.Explanation))
                                {
                                    <div
                                        class="text-sm text-gray-300 leading-relaxed prose prose-invert prose-sm max-w-none">@(MarkdownRenderer.ToHtml(msg.Explanation))</div>
                                }

                                @if (!string.IsNullOrEmpty(msg.Summary) || !string.IsNullOrEmpty(msg.RiskLevel) || (msg.Findings?.Count > 0) || (msg.RecommendedActions?.Count > 0))
                                {
                                    <div class="border border-gray-800 rounded-lg p-3 bg-gray-900/40 space-y-2">
                                        @if (!string.IsNullOrEmpty(msg.Summary))
                                        {
                                            <div
                                                class="text-sm text-gray-200 prose prose-invert prose-sm max-w-none">@(MarkdownRenderer.ToHtml(msg.Summary))</div>
                                        }
                                        @if (!string.IsNullOrEmpty(msg.RiskLevel))
                                        {
                                            <div class="text-xs"><span
                                                    class="@RiskLevelClasses(msg.RiskLevel)">@msg.RiskLevel</span></div>
                                        }
                                        @if (msg.Findings?.Count > 0)
                                        {
                                            <div>
                                                <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">
                                                    Findings
                                                </div>
                                                @foreach (var finding in msg.Findings)
                                                {
                                                    <div class="text-xs text-gray-300">• @finding</div>
                                                }
                                            </div>
                                        }
                                        @if (msg.RecommendedActions?.Count > 0)
                                        {
                                            <div>
                                                <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">
                                                    Recommended Actions
                                                </div>
                                                @foreach (var action in msg.RecommendedActions)
                                                {
                                                    <div class="text-xs text-gray-300">• @action</div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                                @if (msg.Results.Count > 1)
                                {
                                    @foreach (var (qr, ri) in msg.Results.Where(r => r.Rows.Count > 0).Select((r, i) => (r, i)))
                                    {
                                        <div
                                            class="border border-gray-800/60 rounded-lg overflow-hidden bg-gray-950/30">
                                            <div
                                                class="px-3 py-2 border-b border-gray-800/60 flex items-center justify-between">
                                                <span
                                                    class="text-xs font-medium text-gray-300">@(!string.IsNullOrEmpty(qr.Label) ? qr.Label : $"Result {ri + 1}")</span>
                                                <span class="text-[10px] text-gray-600">@qr.RowCount rows</span>
                                            </div>
                                            @if (qr.ChartType != "none")
                                            {
                                                <div class="p-3" style="min-height:330px">
                                                    <div class="flex items-center gap-1.5 mb-2 flex-wrap">
                                                        @foreach (var ct in GetApplicableChartTypes(qr))
                                                        {
                                                            var chartType = ct;
                                                            var result = qr;
                                                            <button
                                                                @onclick="() => ChangeResultChartType(result, chartType)"
                                                                class="px-2 py-0.5 text-[10px] rounded border transition-colors @(qr.ChartType == ct ? "bg-emerald-600/20 border-emerald-500/40 text-emerald-300" : "border-gray-700 text-gray-500 hover:text-gray-300 hover:border-gray-600")">
                                                                @ct
                                                            </button>
                                                        }
                                                    </div>
                                                    @if (qr.ChartType is "pie" or "donut" or "doughnut")
                                                    {
                                                        var pieSeries = GetPieSeries(qr);
                                                        if (pieSeries.Count > 0)
                                                        {
                                                            var seriesType = qr.ChartType is "donut" or "doughnut" ? SeriesType.Donut : SeriesType.Pie;
                                                            <ApexChart TItem="ChartDataPoint"
                                                                       Options="GetPieApexOptions()" Width="@("100%")"
                                                                       Height="280"
                                                                       @key="@($"apex-mr-{idx}-{ri}-{qr.ChartType}")">
                                                                <ApexPointSeries TItem="ChartDataPoint"
                                                                                 Items="pieSeries[0].Points"
                                                                                 Name="@pieSeries[0].Name"
                                                                                 XValue="@(e => e.Label)"
                                                                                 YValue="@(e => e.Value)"
                                                                                 SeriesType="@seriesType"/>
                                                            </ApexChart>
                                                        }
                                                    }
                                                    else if (qr.ChartType is "radialbar" or "radial")
                                                    {
                                                        var radialSeries = GetPieSeries(qr);
                                                        if (radialSeries.Count > 0)
                                                        {
                                                            <ApexChart TItem="ChartDataPoint"
                                                                       Options="GetRadialApexOptions()"
                                                                       Width="@("100%")" Height="280"
                                                                       @key="@($"apex-mr-{idx}-{ri}-{qr.ChartType}")">
                                                                <ApexPointSeries TItem="ChartDataPoint"
                                                                                 Items="radialSeries[0].Points"
                                                                                 Name="@radialSeries[0].Name"
                                                                                 XValue="@(e => e.Label)"
                                                                                 YValue="@(e => e.Value)"
                                                                                 SeriesType="SeriesType.RadialBar"/>
                                                            </ApexChart>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        var series = GetChartSeries(qr);
                                                        <ApexChart TItem="ChartDataPoint"
                                                                   Options="GetApexOptions(qr.ChartType)"
                                                                   Width="@("100%")" Height="280"
                                                                   @key="@($"apex-mr-{idx}-{ri}-{qr.ChartType}")">
                                                            @foreach (var s in series)
                                                            {
                                                                <ApexPointSeries TItem="ChartDataPoint" Items="s.Points"
                                                                                 Name="@s.Name"
                                                                                 XValue="@(e => e.Label)"
                                                                                 YValue="@(e => e.Value)"
                                                                                 SeriesType="@MapSeriesType(qr.ChartType)"/>
                                                            }
                                                        </ApexChart>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                                else if (HasChartContent(msg))
                                {
                                    <div class="border border-gray-800/60 rounded-lg p-3 bg-gray-950/30"
                                         style="min-height:370px">
                                        <div class="flex items-center gap-1.5 mb-2 flex-wrap">
                                            @foreach (var ct in GetApplicableChartTypes(msg))
                                            {
                                                var chartType = ct;
                                                var message = msg;
                                                <button @onclick="() => ChangeChartType(message, chartType)"
                                                        class="px-2 py-0.5 text-[10px] rounded border transition-colors @(msg.ChartType == ct ? "bg-emerald-600/20 border-emerald-500/40 text-emerald-300" : "border-gray-700 text-gray-500 hover:text-gray-300 hover:border-gray-600")">
                                                    @ct
                                                </button>
                                            }
                                        </div>
                                        @if (msg.ChartType is "scatter")
                                        {
                                            var scatterSeries = GetScatterSeries(msg);
                                            <ApexChart TItem="ScatterPoint" Options="GetScatterApexOptions()"
                                                       Width="@("100%")" Height="320"
                                                       @key="@($"apex-{idx}-{msg.ChartType}")">
                                                @foreach (var s in scatterSeries)
                                                {
                                                    <ApexPointSeries TItem="ScatterPoint" Items="s.Points"
                                                                     Name="@s.Name"
                                                                     XValue="@(e => e.X)" YValue="@(e => e.Y)"
                                                                     SeriesType="SeriesType.Scatter"/>
                                                }
                                            </ApexChart>
                                        }
                                        else if (msg.ChartType is "pie" or "donut" or "doughnut")
                                        {
                                            var pieSeries = GetPieSeries(msg);
                                            @if (pieSeries.Count > 0)
                                            {
                                                var seriesType = msg.ChartType is "donut" or "doughnut" ? SeriesType.Donut : SeriesType.Pie;
                                                <ApexChart TItem="ChartDataPoint" Options="GetPieApexOptions()"
                                                           Width="@("100%")" Height="320"
                                                           @key="@($"apex-{idx}-{msg.ChartType}")">
                                                    <ApexPointSeries TItem="ChartDataPoint" Items="pieSeries[0].Points"
                                                                     Name="@pieSeries[0].Name"
                                                                     XValue="@(e => e.Label)" YValue="@(e => e.Value)"
                                                                     SeriesType="@seriesType"/>
                                                </ApexChart>
                                            }
                                        }
                                        else if (msg.ChartType is "radialbar" or "radial")
                                        {
                                            var radialSeries = GetPieSeries(msg);
                                            @if (radialSeries.Count > 0)
                                            {
                                                <ApexChart TItem="ChartDataPoint" Options="GetRadialApexOptions()"
                                                           Width="@("100%")" Height="320"
                                                           @key="@($"apex-{idx}-{msg.ChartType}")">
                                                    <ApexPointSeries TItem="ChartDataPoint"
                                                                     Items="radialSeries[0].Points"
                                                                     Name="@radialSeries[0].Name"
                                                                     XValue="@(e => e.Label)" YValue="@(e => e.Value)"
                                                                     SeriesType="SeriesType.RadialBar"/>
                                                </ApexChart>
                                            }
                                        }
                                        else if (msg.ChartType is "radar")
                                        {
                                            var radarSeries = GetChartSeries(msg);
                                            <ApexChart TItem="ChartDataPoint" Options="GetRadarApexOptions()"
                                                       Width="@("100%")" Height="320"
                                                       @key="@($"apex-{idx}-{msg.ChartType}")">
                                                @foreach (var s in radarSeries)
                                                {
                                                    <ApexPointSeries TItem="ChartDataPoint" Items="s.Points"
                                                                     Name="@s.Name"
                                                                     XValue="@(e => e.Label)" YValue="@(e => e.Value)"
                                                                     SeriesType="SeriesType.Radar"/>
                                                }
                                            </ApexChart>
                                        }
                                        else if (msg.ChartType is "heatmap")
                                        {
                                            var heatSeries = GetChartSeries(msg);
                                            <ApexChart TItem="ChartDataPoint" Options="GetApexOptions(msg.ChartType)"
                                                       Width="@("100%")" Height="320"
                                                       @key="@($"apex-{idx}-{msg.ChartType}")">
                                                @foreach (var s in heatSeries)
                                                {
                                                    <ApexPointSeries TItem="ChartDataPoint" Items="s.Points"
                                                                     Name="@s.Name"
                                                                     XValue="@(e => e.Label)" YValue="@(e => e.Value)"
                                                                     SeriesType="SeriesType.Heatmap"/>
                                                }
                                            </ApexChart>
                                        }
                                        else if (msg.ChartType is "treemap")
                                        {
                                            var treeSeries = GetPieSeries(msg);
                                            @if (treeSeries.Count > 0)
                                            {
                                                <ApexChart TItem="ChartDataPoint"
                                                           Options="GetApexOptions(msg.ChartType)" Width="@("100%")"
                                                           Height="320" @key="@($"apex-{idx}-{msg.ChartType}")">
                                                    <ApexPointSeries TItem="ChartDataPoint" Items="treeSeries[0].Points"
                                                                     Name="@treeSeries[0].Name"
                                                                     XValue="@(e => e.Label)" YValue="@(e => e.Value)"
                                                                     SeriesType="SeriesType.Treemap"/>
                                                </ApexChart>
                                            }
                                        }
                                        else
                                        {
                                            var displaySeries = GetChartSeries(msg);
                                            <ApexChart TItem="ChartDataPoint" Options="GetApexOptions(msg.ChartType)"
                                                       Width="@("100%")" Height="320"
                                                       @key="@($"apex-{idx}-{msg.ChartType}")">
                                                @foreach (var s in displaySeries)
                                                {
                                                    <ApexPointSeries TItem="ChartDataPoint" Items="s.Points"
                                                                     Name="@s.Name"
                                                                     XValue="@(e => e.Label)" YValue="@(e => e.Value)"
                                                                     SeriesType="@MapSeriesType(msg.ChartType)"/>
                                                }
                                            </ApexChart>
                                        }
                                    </div>
                                }

                                <div class="flex items-center gap-3 text-[10px] text-gray-600">
                                    @if (msg.InputTokens + msg.OutputTokens > 0)
                                    {
                                        <span>@((msg.InputTokens + msg.OutputTokens).ToString("N0")) tokens</span>
                                    }
                                </div>

                                @if (debugMode && HasSqlContent(msg))
                                {
                                    <details class="border border-gray-800/60 rounded-lg overflow-hidden">
                                        <summary
                                            class="px-3 py-2 text-xs text-gray-400 cursor-pointer hover:text-gray-300 select-none bg-gray-900/40">
                                            SQL@(msg.Results.Count > 1 ? $" · {msg.Results.Count} queries" : "")
                                        </summary>
                                        @if (msg.Results.Count > 1)
                                        {
                                            <div class="divide-y divide-gray-800/40">
                                                @foreach (var (qr, ri) in msg.Results.Where(r => !string.IsNullOrWhiteSpace(r.Sql)).Select((r, i) => (r, i)))
                                                {
                                                    <div>
                                                        <div
                                                            class="px-3 py-1 text-[10px] text-gray-500 bg-gray-900/50">@(!string.IsNullOrEmpty(qr.Label) ? qr.Label : $"Query {ri + 1}")</div>
                                                        <pre
                                                            class="px-3 py-2 text-xs text-emerald-300 font-mono whitespace-pre-wrap bg-gray-950">@qr.Sql</pre>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <pre
                                                class="p-3 text-xs text-emerald-300 font-mono whitespace-pre-wrap bg-gray-950">@msg.Sql</pre>
                                        }
                                    </details>
                                }

                                @if (HasReasoningContent(msg))
                                {
                                    <details class="border border-gray-800/60 rounded-lg overflow-hidden">
                                        <summary
                                            class="px-3 py-2 text-xs text-gray-400 cursor-pointer hover:text-gray-300 select-none bg-gray-900/40">
                                            Reasoning
                                        </summary>
                                        <div
                                            class="p-3 text-xs text-gray-400 italic whitespace-pre-wrap bg-gray-950/40">@msg.Thinking</div>
                                    </details>
                                }

                                @if (debugMode && msg.StreamEvents?.Count > 0)
                                {
                                    <details class="border border-gray-800/60 rounded-lg overflow-hidden">
                                        <summary
                                            class="px-3 py-2 text-xs text-gray-400 cursor-pointer hover:text-gray-300 select-none bg-gray-900/40">
                                            Agent timeline · @msg.StreamEvents.Count steps
                                        </summary>
                                        <div class="p-2.5 space-y-1 bg-gray-950/40">
                                            @foreach (var evt in msg.StreamEvents)
                                            {
                                                <div class="flex items-start gap-2 text-xs">
                                                    <span
                                                        class="shrink-0 @StreamEventDotClass(evt.Type) w-1.5 h-1.5 rounded-full mt-1"></span>
                                                    <span class="@StreamEventTextClass(evt.Type)">@evt.Message</span>
                                                </div>
                                            }
                                        </div>
                                    </details>
                                }

                            </div>
                        }
                    }

                    @if (loading)
                    {
                        <div class="space-y-2 max-w-full" @ref="loadingAnchor">
                            @* Live progress bar — always visible *@
                            <div class="border border-gray-800 rounded-xl p-3 bg-gray-900/35 space-y-2.5">
                                @* Current status line *@
                                <div class="flex items-center gap-2.5">
                                    <svg class="w-4 h-4 animate-spin text-emerald-400 shrink-0" fill="none"
                                         viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor"
                                                stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor"
                                              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                    </svg>
                                    <span class="text-sm text-gray-300">@CurrentProgressLabel</span>
                                </div>

                                @* Step indicators — show completed + active steps *@
                                @if (_pendingMessage?.StreamEvents?.Count > 0)
                                {
                                    var recentEvents = _pendingMessage.StreamEvents.TakeLast(5).ToList();
                                    <div class="space-y-1 pl-6">
                                        @foreach (var evt in recentEvents)
                                        {
                                            var isLast = evt == recentEvents.Last();
                                            <div
                                                class="flex items-center gap-2 text-xs @(isLast ? "text-gray-300" : "text-gray-600")">
                                                @if (isLast)
                                                {
                                                    <span
                                                        class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse shrink-0"></span>
                                                }
                                                else
                                                {
                                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-600 shrink-0"></span>
                                                }
                                                <span class="truncate">@evt.Message</span>
                                            </div>
                                        }
                                    </div>
                                }

                                @* Thinking text *@
                                @if (!string.IsNullOrWhiteSpace(GetPendingThinkingText(_pendingMessage)))
                                {
                                    <div class="pl-6 border-l-2 border-emerald-500/20 ml-1.5">
                                        <div
                                            class="text-[10px] uppercase tracking-wider text-emerald-300/60 font-medium mb-0.5">
                                            Thinking
                                        </div>
                                        <div
                                            class="text-xs text-emerald-100/70 italic">@GetPendingThinkingText(_pendingMessage)</div>
                                    </div>
                                }
                            </div>

                            @* Debug: full timeline *@
                            @if (debugMode && _pendingMessage?.StreamEvents?.Count > 0)
                            {
                                <details class="border border-gray-800/60 rounded-lg overflow-hidden bg-gray-900/30">
                                    <summary
                                        class="px-3 py-1.5 border-b border-gray-800/60 flex items-center gap-2 cursor-pointer">
                                        <span class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">Full Agent Timeline · @_pendingMessage.StreamEvents.Count steps</span>
                                    </summary>
                                    <div class="p-2.5 space-y-1.5">
                                        @foreach (var evt in _pendingMessage.StreamEvents)
                                        {
                                            <div class="flex items-start gap-2 text-xs">
                                                <span
                                                    class="shrink-0 mt-0.5 @StreamEventDotClass(evt.Type) w-1.5 h-1.5 rounded-full"></span>
                                                <div class="min-w-0">
                                                    <span class="@StreamEventTextClass(evt.Type)">@evt.Message</span>
                                                    @if (!string.IsNullOrEmpty(evt.Sql))
                                                    {
                                                        <details class="mt-1">
                                                            <summary
                                                                class="text-gray-600 cursor-pointer hover:text-gray-500">
                                                                View SQL
                                                            </summary>
                                                            <pre
                                                                class="mt-1 p-2 text-[10px] bg-gray-950 text-emerald-300 rounded font-mono whitespace-pre-wrap border border-gray-800">@evt.Sql</pre>
                                                        </details>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </details>
                            }

                            @* Streaming text preview *@
                            @if (!string.IsNullOrEmpty(_streamingText))
                            {
                                <div class="space-y-3 max-w-full border rounded-xl p-4 bg-gray-900/35 border-gray-800">
                                    <div
                                        class="text-sm text-gray-300 leading-relaxed prose prose-invert prose-sm max-w-none">
                                        @(MarkdownRenderer.ToHtml(_streamingText))<span
                                            class="inline-block w-0.5 h-4 bg-emerald-400 animate-pulse ml-0.5 align-middle"></span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Input -->
                <div class="border-t border-gray-800 p-3">
                    <div class="mb-2 flex flex-wrap gap-2">
                        @foreach (var suggestion in quickAskSuggestions)
                        {
                            <button @onclick="() => QuickAsk(suggestion.Prompt)"
                                    class="px-2 py-1 text-[10px] text-gray-500 border border-gray-800 rounded hover:bg-gray-900 hover:text-gray-300 transition-colors">
                                @suggestion.Label
                            </button>
                        }
                    </div>
                    <form @onsubmit="Send" @onsubmit:preventDefault class="space-y-2">
                        <div
                            class="rounded-2xl border border-gray-700/80 bg-gray-900/80 shadow-[0_0_0_1px_rgba(255,255,255,0.02)] focus-within:border-emerald-500/50 focus-within:shadow-[0_0_0_2px_rgba(16,185,129,0.15)] transition-all">
                            <textarea @bind="input" @bind:event="oninput" rows="3"
                                      @onkeydown="OnComposerKeyDown"
                                      placeholder="Message Sentinel..."
                                      disabled="@loading"
                                      class="w-full px-4 pt-3 pb-2 bg-transparent border-0 text-sm text-white placeholder-gray-500 focus:outline-none disabled:opacity-50 resize-y min-h-[3rem] max-h-56"></textarea>
                            <div class="flex items-center justify-between px-2 pb-2">
                                <span class="pl-2 text-[10px] text-gray-500">Sentinel can make mistakes. Verify important results.</span>
                                <button type="submit"
                                        disabled="@(loading || string.IsNullOrWhiteSpace(input) || string.IsNullOrEmpty(database))"
                                        class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white text-gray-900 hover:bg-gray-200 disabled:bg-gray-800 disabled:text-gray-500 transition-colors"
                                        title="Send">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M5 12h13m-6-7l7 7-7 7"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@code {

    [SupplyParameterFromQuery(Name = "id")]
    public string? ConversationIdParam { get; set; }

    private List<ChatMessage> messages = [];
    private string input = "";
    private bool loading;
    private string database = "";
    private string mode = "general";
    private bool debugMode;
    private List<string> databases = [];
    private Dictionary<string, string> dbDisplayNames = new(StringComparer.OrdinalIgnoreCase);
    private string? dbLoadError;
    private List<AnalyticsConversation> conversations = [];
    private string? activeConversationId;
    private Dictionary<string, PeriodicTimer> activePolls = [];
    private ElementReference messagesContainer;
    private ElementReference loadingAnchor;
    private string userId = "default";
    private bool _shouldScrollToBottom;
    private bool _shouldScrollToLoading;
    private ChatMessage? _pendingMessage;
    private string _streamingText = "";
    private bool showHistoryMobile;
    private bool showHistoryPanel = true;
    private bool showBetaDisclaimer = true;
    private HashSet<string> databaseTables = new(StringComparer.OrdinalIgnoreCase);
    private List<QuickAskSuggestion> quickAskSuggestions = [];
    private int? selectedAssistantIdx;
    private bool showInsightsPanel; // kept for potential future use
    private const string TabSummary = "summary";
    private const string TabChart = "chart";
    private const string TabTable = "table";
    private const string TabSql = "sql";
    private const string TabReasoning = "reasoning";

    private ChatMessage? SelectedAssistantMessage =>
        selectedAssistantIdx is int idx &&
        idx >= 0 &&
        idx < messages.Count &&
        messages[idx].Role == "assistant"
            ? messages[idx]
            : messages.LastOrDefault(m => m.Role == "assistant");

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "default";
        await LoadDatabases();
        await LoadConversations();

        // Restore active conversation from URL query param (persists across browser refresh)
        if (!string.IsNullOrEmpty(ConversationIdParam))
        {
            await LoadConversation(ConversationIdParam, updateUrl: false);
        }
        else
        {
            await ResumeRunningConversationAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (_shouldScrollToLoading)
            {
                _shouldScrollToLoading = false;
                await JS.InvokeVoidAsync("chartInterop.scrollToElement", loadingAnchor);
            }
            else if (_shouldScrollToBottom)
            {
                _shouldScrollToBottom = false;
                await JS.InvokeVoidAsync("chartInterop.scrollToBottom", messagesContainer);
            }
        }
        catch
        {
        }
    }

    private string DbPrefKey => $"analytics:prefs:{userId}:database";
    private string ModePrefKey => $"analytics:prefs:{userId}:mode";
    private string BetaDisclaimerPrefKey => $"analytics:prefs:{userId}:beta-disclaimer-dismissed";

    private async Task LoadDatabases()
    {
        dbLoadError = null;

        try
        {
            var enabledProducts = await ProductStore.GetEnabledAsync();
            databases = enabledProducts.Select(p => p.DatabaseName).ToList();
            dbDisplayNames = enabledProducts.ToDictionary(
                p => p.DatabaseName, p => p.DisplayName, StringComparer.OrdinalIgnoreCase);
        }
        catch
        {
            // Fallback if DB is unavailable
            databases = ["lipila_blaze"];
            dbDisplayNames = new(StringComparer.OrdinalIgnoreCase) { ["lipila_blaze"] = "Lipila" };
        }

        // Restore saved database preference, fall back to first in list
        var saved = await Cache.GetOrDefaultAsync<string>(DbPrefKey);
        if (!string.IsNullOrEmpty(saved) && databases.Contains(saved, StringComparer.OrdinalIgnoreCase))
            database = saved;
        else if (databases.Count > 0)
            database = databases[0];

        var savedMode = await Cache.GetOrDefaultAsync<string>(ModePrefKey);
        mode = savedMode is "fraud" ? "fraud" : "general";

        var disclaimerDismissed = await Cache.GetOrDefaultAsync<string>(BetaDisclaimerPrefKey);
        showBetaDisclaimer = !string.Equals(disclaimerDismissed, "1", StringComparison.Ordinal);

        await RefreshDatabaseContext();
    }

    private async Task OnDatabaseChanged(ChangeEventArgs e)
    {
        database = e.Value?.ToString() ?? database;
        try
        {
            await Cache.SetAsync(DbPrefKey, database, new FusionCacheEntryOptions { Duration = TimeSpan.FromDays(30) });
        }
        catch
        {
            /* best-effort */
        }

        await RefreshDatabaseContext();
    }

    private async Task OnModeChanged(ChangeEventArgs e)
    {
        mode = e.Value?.ToString() is "fraud" ? "fraud" : "general";
        try
        {
            await Cache.SetAsync(ModePrefKey, mode, new FusionCacheEntryOptions { Duration = TimeSpan.FromDays(30) });
        }
        catch
        {
            /* best-effort */
        }

        BuildQuickAskSuggestions();
    }

    private string GetProductLabel(string databaseName)
    {
        if (string.IsNullOrWhiteSpace(databaseName))
            return "Unknown Product";

        if (dbDisplayNames.TryGetValue(databaseName, out var label) && !string.IsNullOrWhiteSpace(label))
            return label;

        // Fallback: title-case the database name
        return string.Join(" ", databaseName
            .Split(['_', '-'], StringSplitOptions.RemoveEmptyEntries)
            .Select(segment => char.ToUpperInvariant(segment[0]) + segment[1..]));
    }

    private async Task LoadConversations()
    {
        conversations = await ChatStore.ListConversationsAsync(userId);
    }

    private async Task LoadConversation(string id, bool updateUrl = true)
    {
        var conv = await ChatStore.GetConversationAsync(userId, id);
        if (conv == null) return;

        activeConversationId = conv.Id;
        database = conv.Database;
        mode = conv.Mode is "fraud" ? "fraud" : "general";
        try
        {
            await Cache.SetAsync(DbPrefKey, database, new FusionCacheEntryOptions { Duration = TimeSpan.FromDays(30) });
        }
        catch
        {
            /* best-effort */
        }

        try
        {
            await Cache.SetAsync(ModePrefKey, mode, new FusionCacheEntryOptions { Duration = TimeSpan.FromDays(30) });
        }
        catch
        {
            /* best-effort */
        }

        await RefreshDatabaseContext();
        messages = (conv.Messages ?? []).Select(m =>
        {
            if (m.Role == "assistant" && m.Response != null)
            {
                var assistant = new ChatMessage
                {
                    Role = "assistant",
                    Thinking = m.Response.Thinking,
                    Sql = m.Response.Sql,
                    Explanation = m.Response.Explanation,
                    Summary = m.Response.Summary,
                    RiskLevel = m.Response.RiskLevel,
                    Findings = m.Response.Findings ?? [],
                    RecommendedActions = m.Response.RecommendedActions ?? [],
                    Error = m.Response.Error,
                    ChartType = m.Response.ChartType ?? "none",
                    Columns = m.Response.Columns ?? [],
                    Rows = m.Response.Rows ?? [],
                    RowCount = m.Response.RowCount,
                    InputTokens = m.Response.InputTokens,
                    OutputTokens = m.Response.OutputTokens
                };
                NormalizeAssistantMessage(assistant);
                return assistant;
            }

            return new ChatMessage { Role = m.Role ?? "user", Content = m.Content };
        }).ToList();
        SelectLatestAssistantMessage();

        // Schedule scroll after next DOM update
        _shouldScrollToBottom = true;

        // Persist the active conversation in the URL so browser refresh restores it
        if (updateUrl)
            Navigation.NavigateTo($"/admin/chat?id={id}", replace: true);

        // Check pending jobs
        var jobs = await JobStore.GetUserJobsAsync(userId, id);
        foreach (var job in jobs.Where(j => j.Status == "pending" || j.Status == "running"))
        {
            StartPolling(job.Id);
        }
    }

    private void NewConversation()
    {
        activeConversationId = null;
        ClearChat();
        Navigation.NavigateTo("/admin/chat", replace: true);
    }

    private async Task DeleteConversation(string id)
    {
        await ChatStore.DeleteConversationAsync(userId, id);
        if (activeConversationId == id) NewConversation();
        await LoadConversations();
    }

    private async Task Send()
    {
        var prompt = input.Trim();
        if (string.IsNullOrEmpty(prompt) || loading || string.IsNullOrEmpty(database)) return;

        messages.Add(new ChatMessage { Role = "user", Content = prompt });
        _shouldScrollToLoading = true;
        input = "";
        loading = true;

        try
        {
            var conversationId = activeConversationId;

            if (string.IsNullOrEmpty(conversationId))
            {
                var conversation = new AnalyticsConversation
                {
                    Database = database,
                    Mode = mode,
                    UserId = userId,
                    Title = prompt.Length > 50 ? prompt[..47] + "..." : prompt
                };
                await ChatStore.SaveConversationAsync(conversation);
                conversationId = conversation.Id;
                activeConversationId = conversationId;
                await LoadConversations();
            }

            if (!string.IsNullOrEmpty(conversationId))
            {
                Navigation.NavigateTo($"/admin/chat?id={conversationId}", replace: true);
                await AppendUserMessageAsync(conversationId, prompt);
            }

            var job = new AnalyticsQueryJob
            {
                ConversationId = conversationId,
                UserId = userId,
                Prompt = prompt,
                Database = database,
                Mode = mode
            };

            await JobStore.CreateAsync(job);
            await Worker.EnqueueAsync(job.Id);
            StartPolling(job.Id);
        }
        catch (Exception ex)
        {
            var assistant = new ChatMessage { Role = "assistant", Error = "Request failed: " + ex.Message };
            NormalizeAssistantMessage(assistant);
            messages.Add(assistant);
            SelectLatestAssistantMessage();
            loading = false;
        }
    }

    private async Task AppendUserMessageAsync(string conversationId, string prompt)
    {
        var conversation = await ChatStore.GetConversationAsync(userId, conversationId);
        if (conversation == null)
            return;

        conversation.Database = database;
        conversation.Mode = mode;
        conversation.Messages.Add(new ChatEntry { Role = "user", Content = prompt });
        await ChatStore.SaveConversationAsync(conversation);
    }

    private async Task ResumeRunningConversationAsync()
    {
        var runningJob = (await JobStore.GetUserJobsAsync(userId))
            .Where(j => j.Status == "pending" || j.Status == "running")
            .OrderByDescending(j => j.SubmittedAt)
            .FirstOrDefault();

        if (!string.IsNullOrWhiteSpace(runningJob?.ConversationId))
            await LoadConversation(runningJob.ConversationId);
    }

    private async Task OnComposerKeyDown(KeyboardEventArgs e)
    {
        if (loading) return;
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            input = input.TrimEnd('\r', '\n');
            await Send();
        }
    }

    private async Task DismissBetaDisclaimer()
    {
        showBetaDisclaimer = false;
        try
        {
            await Cache.SetAsync(BetaDisclaimerPrefKey, "1",
                new FusionCacheEntryOptions { Duration = TimeSpan.FromDays(365) });
        }
        catch
        {
            /* best-effort */
        }
    }

    private void StartPolling(string jobId)
    {
        if (activePolls.ContainsKey(jobId)) return;

        _pendingMessage ??= new ChatMessage
        {
            Role = "progress",
            StreamEvents = [new AnalyticsStreamEvent { Type = "thinking", Message = "Analysing your question…", Attempt = 1 }]
        };

        var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(150));
        activePolls[jobId] = timer;

        _ = Task.Run(async () =>
        {
            while (await timer.WaitForNextTickAsync())
            {
                try
                {
                    // Update streaming text from live worker state (no cache round-trip)
                    var liveText = Worker.GetLiveText(jobId);
                    if (liveText != null && liveText != _streamingText)
                    {
                        _streamingText = liveText;
                        await InvokeAsync(StateHasChanged);
                    }

                    var job = await JobStore.GetAsync(jobId);
                    if (job == null)
                    {
                        StopPolling(jobId);
                        break;
                    }

                    if (_pendingMessage != null && job.StreamEvents.Count > (_pendingMessage.StreamEvents?.Count ?? 0))
                    {
                        _pendingMessage.StreamEvents = job.StreamEvents;
                        await InvokeAsync(StateHasChanged);
                    }

                    if (job.Status == "completed")
                    {
                        StopPolling(jobId);

                        if (job.Result != null)
                        {
                            var assistant = new ChatMessage
                            {
                                Role = "assistant",
                                Thinking = job.Result.Thinking,
                                Sql = job.Result.Sql,
                                Explanation = job.Result.Explanation,
                                Summary = job.Result.Summary,
                                RiskLevel = job.Result.RiskLevel,
                                Findings = job.Result.Findings ?? [],
                                RecommendedActions = job.Result.RecommendedActions ?? [],
                                Error = job.Result.Error,
                                ChartType = job.Result.ChartType ?? "none",
                                Columns = job.Result.Columns ?? [],
                                Rows = job.Result.Rows ?? [],
                                RowCount = job.Result.RowCount,
                                InputTokens = job.Result.InputTokens,
                                OutputTokens = job.Result.OutputTokens,
                                StreamEvents = job.StreamEvents,
                                Results = job.Result.Results ?? []
                            };
                            NormalizeAssistantMessage(assistant);
                            messages.Add(assistant);
                            SelectLatestAssistantMessage();
                        }

                        _pendingMessage = null;
                        _streamingText = "";
                        loading = false;
                        _shouldScrollToBottom = true;
                        await InvokeAsync(StateHasChanged);
                        break;
                    }
                    else if (job.Status == "failed")
                    {
                        StopPolling(jobId);
                        _pendingMessage = null;
                        _streamingText = "";
                        var assistant = new ChatMessage { Role = "assistant", Error = job.Error ?? "Query failed", StreamEvents = job.StreamEvents };
                        NormalizeAssistantMessage(assistant);
                        messages.Add(assistant);
                        SelectLatestAssistantMessage();
                        loading = false;
                        _shouldScrollToBottom = true;
                        await InvokeAsync(StateHasChanged);
                        break;
                    }
                }
                catch
                {
                    StopPolling(jobId);
                    _pendingMessage = null;
                    _streamingText = "";
                    loading = false;
                    await InvokeAsync(StateHasChanged);
                    break;
                }
            }
        });
    }

    private void StopPolling(string jobId)
    {
        if (activePolls.TryGetValue(jobId, out var timer))
        {
            timer.Dispose();
            activePolls.Remove(jobId);
        }
    }

    private async Task QuickAsk(string prompt)
    {
        input = prompt;
        await Send();
    }

    private async Task RefreshDatabaseContext()
    {
        await LoadDatabaseTables();
        BuildQuickAskSuggestions();
    }

    private async Task LoadDatabaseTables()
    {
        databaseTables.Clear();
        if (string.IsNullOrWhiteSpace(database)) return;

        try
        {
            var escapedDb = database.Replace("`", "``");
            var json = await ClickHouse.QueryAsync($"SHOW TABLES FROM `{escapedDb}`");
            if (json.StartsWith("ClickHouse error") || json.StartsWith("Error:") || json.StartsWith("Query failed:"))
                return;

            using var doc = JsonDocument.Parse(json);
            if (!doc.RootElement.TryGetProperty("data", out var data))
                return;

            foreach (var row in data.EnumerateArray())
            {
                foreach (var prop in row.EnumerateObject())
                {
                    if (prop.Value.ValueKind == JsonValueKind.String)
                    {
                        var tableName = prop.Value.GetString();
                        if (!string.IsNullOrWhiteSpace(tableName))
                            databaseTables.Add(tableName);
                        break;
                    }
                }
            }
        }
        catch
        {
            // best-effort metadata load
        }
    }

    private void BuildQuickAskSuggestions()
    {
        var todaysInsights = new QuickAskSuggestion("Today's insights",
            $"Give me a comprehensive summary of today's key metrics, trends, and notable activity in '{database}'. Include total volumes, success/failure rates, and anything unusual.");

        if (mode == "fraud")
        {
            quickAskSuggestions =
            [
                todaysInsights,
                new QuickAskSuggestion("High-risk patterns (24h)", $"Run fraud detection on '{database}' for last 24 hours. Return risk level, findings, and recommended actions."),
                new QuickAskSuggestion("Merchant anomaly scan", $"Identify unusual merchant behaviour in '{database}' over last 24 hours and classify risk."),
                new QuickAskSuggestion("Wallet risk hotspots", $"Find risky wallet/recipient concentration patterns in '{database}' this week."),
                new QuickAskSuggestion("Status mismatch checks", $"Detect suspicious status/amount inconsistencies in '{database}' with fraud-focused findings.")
            ];
            return;
        }

        quickAskSuggestions = (database?.ToLowerInvariant() switch
        {
            "lipila_blaze" => new List<QuickAskSuggestion>
            {
                todaysInsights,
                new("Hourly volume (24h)", $"Hourly transaction count for the last 24 hours in '{database}'"),
                new("Status breakdown", $"Transaction status breakdown today in '{database}' as a pie chart"),
                new("Top merchants today", $"Top 10 merchants by disbursement and Collections volume today in '{database}'"),
                new("Payment channels", $"Transaction volume by payment channel this week in '{database}'"),
            },
            "inshuwa" => new List<QuickAskSuggestion>
            {
                todaysInsights,
                new("Active policies", $"Count of active policies by insurance class in '{database}'"),
                new("Claims this month", $"Claims submitted this month grouped by status in '{database}'"),
                new("Premium revenue", $"Total premium revenue this week by policy type in '{database}'"),
                new("Motor vs Life", $"Compare motor and life policy counts over the last 30 days in '{database}'"),
            },
            "bnpl" => new List<QuickAskSuggestion>
            {
                todaysInsights,
                new("Active loans", $"Count of active loans by status in '{database}'"),
                new("Disbursements today", $"Total loan disbursements today in '{database}'"),
                new("Repayment rate", $"Repayment success rate this week in '{database}'"),
                new("Overdue loans", $"How many loans are overdue and their total value in '{database}'?"),
            },
            var db when db != null && db.StartsWith("patumba") => new List<QuickAskSuggestion>
            {
                todaysInsights,
                new("Savings overview", $"Total savings contributions this week in '{database}'"),
                new("Active goals", $"Count of active savings goals by status in '{database}'"),
                new("Top savers", $"Top 10 users by total contributions this month in '{database}'"),
                new("Withdrawals trend", $"Daily withdrawal volume over the last 7 days in '{database}'"),
            },
            _ => new List<QuickAskSuggestion>
            {
                todaysInsights,
                new("Recent activity", $"Show key activity trends for the last 24 hours in '{database}'"),
                new("Status distribution", $"Show status distribution for recent records in '{database}' as a pie chart"),
                new("Top entities", $"Show top entities by volume in '{database}'"),
                new("Daily trend (7d)", $"Show daily record counts over the last 7 days in '{database}' as a line chart"),
            }
        }).Take(5).ToList();
    }

    private static bool HasSummaryContent(ChatMessage msg) =>
        !string.IsNullOrWhiteSpace(msg.Explanation) ||
        !string.IsNullOrWhiteSpace(msg.Summary) ||
        !string.IsNullOrWhiteSpace(msg.RiskLevel) ||
        (msg.Findings?.Count > 0) ||
        (msg.RecommendedActions?.Count > 0) ||
        !string.IsNullOrWhiteSpace(msg.Error);

    private static bool HasChartContent(ChatMessage msg) =>
        (!string.IsNullOrWhiteSpace(msg.ChartType) && msg.ChartType != "none" && msg.Rows?.Count > 0)
        || msg.Results.Any(r => r.ChartType != "none" && r.Rows.Count > 0);

    private static bool HasTableContent(ChatMessage msg) =>
        (msg.Columns?.Count > 0 && msg.Rows?.Count > 0)
        || msg.Results.Any(r => r.Columns.Count > 0 && r.Rows.Count > 0);

    private static bool HasSqlContent(ChatMessage msg) =>
        !string.IsNullOrWhiteSpace(msg.Sql) || msg.Results.Any(r => !string.IsNullOrWhiteSpace(r.Sql));

    private static bool HasReasoningContent(ChatMessage msg) =>
        !string.IsNullOrWhiteSpace(msg.Thinking);

    private string CurrentProgressLabel
    {
        get
        {
            if (_pendingMessage?.StreamEvents?.Count > 0)
            {
                var last = _pendingMessage.StreamEvents.Last();
                return last.Type switch
                {
                    "sql" => "Running SQL query…",
                    "thinking" or "analysing" => "Analysing data…",
                    "tool_call" => last.Message ?? "Calling tool…",
                    "error" => "Encountered an issue, retrying…",
                    _ => last.Message ?? "Processing…"
                };
            }

            if (!string.IsNullOrEmpty(_streamingText)) return "Generating response…";
            return "Starting analysis…";
        }
    }

    private static string? GetPendingThinkingText(ChatMessage? pendingMessage)
    {
        if (pendingMessage?.StreamEvents?.Count is not > 0)
            return null;

        var latestThinking = pendingMessage.StreamEvents
            .LastOrDefault(e => string.Equals(e.Type, "thinking", StringComparison.OrdinalIgnoreCase)
                                || string.Equals(e.Type, "analysing", StringComparison.OrdinalIgnoreCase)
                                || string.Equals(e.Type, "asking", StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(latestThinking?.Message))
            return latestThinking.Message;

        var latestMessage = pendingMessage.StreamEvents.LastOrDefault(e => !string.IsNullOrWhiteSpace(e.Message));
        return latestMessage?.Message;
    }

