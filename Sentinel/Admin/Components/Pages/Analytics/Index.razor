    private static List<(string Name, List<ScatterPoint> Points)> GetScatterSeriesFromData(
        List<string> columns, List<Dictionary<string, string>> rows)
    {
        var numericCols = columns
            .Where(col => rows.Any(row => double.TryParse(row.GetValueOrDefault(col), out _)))
            .ToList();
        if (numericCols.Count < 2) return [];
        var xCol = numericCols[0];
        return numericCols.Skip(1).Select(yCol =>
            (HumanizeColumn(yCol), rows.Select((row, i) =>
                new ScatterPoint(
                    decimal.TryParse(row.GetValueOrDefault(xCol), out var x) ? x : i,
                    decimal.TryParse(row.GetValueOrDefault(yCol), out var y) ? y : 0m
                )).ToList())
        ).ToList();
    }

