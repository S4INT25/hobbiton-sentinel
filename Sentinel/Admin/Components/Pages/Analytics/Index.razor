@page "/admin/chat"
@page "/admin/analytics"
@inject IAnalyticsChatStore ChatStore
@inject IAnalyticsJobStore JobStore
@inject AnalyticsQueryWorker Worker
@inject Infrastructure.ClickHouseClient ClickHouse
@inject ZiggyCreatures.Caching.Fusion.IFusionCache Cache
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject NavigationManager Navigation
@attribute [Authorize(Policy = AuthConstants.Policy)]
@implements IDisposable

<PageTitle>Chat — Sentinel</PageTitle>

<div class="flex flex-col md:flex-row h-[calc(100vh-6rem)]">
    <!-- Conversation Sidebar -->
    <div class="@(showHistoryMobile ? "flex" : "hidden") md:flex w-full md:w-56 border-b md:border-b-0 md:border-r border-gray-800 flex-col shrink-0 max-h-64 md:max-h-none">
        <div class="flex items-center justify-between px-3 py-2 border-b border-gray-800">
            <span class="text-xs font-medium text-gray-400">History</span>
            <button @onclick="NewConversation" class="px-2 py-1 text-[10px] bg-emerald-600 hover:bg-emerald-500 text-white rounded transition-colors">+ New</button>
        </div>
        <div class="flex-1 overflow-y-auto p-1.5 space-y-0.5">
            @foreach (var conv in conversations)
            {
                <div @onclick="() => LoadConversation(conv.Id)"
                     class="px-2.5 py-2 rounded border cursor-pointer group transition-colors @(conv.Id == activeConversationId ? "bg-gray-800/60 border-emerald-500/30" : "border-transparent hover:bg-gray-900")">
                    <div class="text-xs text-gray-300 truncate">@conv.Title</div>
                    <div class="flex items-center justify-between mt-0.5">
                        <span class="text-[10px] text-gray-600">@conv.Database</span>
                        <button @onclick="() => DeleteConversation(conv.Id)" @onclick:stopPropagation="true" class="opacity-0 group-hover:opacity-100 text-[10px] text-rose-500 hover:text-rose-400 transition-opacity">✕</button>
                    </div>
                </div>
            }
            @if (!conversations.Any())
            {
                <div class="px-3 py-4 text-center text-[10px] text-gray-600">No conversations yet</div>
            }
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="flex-1 flex flex-col min-w-0">
        <div class="flex items-center justify-between px-4 py-2 border-b border-gray-800">
            <div class="flex items-center gap-2 md:gap-3 flex-wrap">
                <button @onclick="ToggleHistoryMobile" class="md:hidden px-2 py-1.5 bg-gray-900 border border-gray-800 rounded text-[10px] text-gray-300">History</button>
                <select value="@database" @onchange="OnDatabaseChanged" class="px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                    @foreach (var db in databases)
                    {
                        <option value="@db">@db</option>
                    }
                </select>
                <select value="@mode" @onchange="OnModeChanged" class="px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                    <option value="general">General</option>
                    <option value="fraud">Fraud Detection</option>
                </select>
                @if (!string.IsNullOrEmpty(dbLoadError))
                {
                    <span class="text-[10px] text-rose-400 truncate max-w-xs" title="@dbLoadError">⚠ DB load failed</span>
                }
                @if (activePolls.Count > 0)
                {
                    <span class="flex items-center gap-1.5 text-[10px] text-emerald-400">
                        <svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                        </svg>
                        Query running
                    </span>
                }
            </div>
            <button @onclick="ClearChat" class="px-2.5 py-1.5 text-xs text-gray-500 hover:text-gray-300 border border-gray-800 rounded hover:bg-gray-900 transition-colors whitespace-nowrap">
                Clear
            </button>
        </div>

        <!-- Chat Messages -->
        <div class="flex-1 overflow-y-auto space-y-4 p-4 pr-1" @ref="messagesContainer">
            @foreach (var (msg, idx) in messages.Select((m, i) => (m, i)))
            {
                @if (msg.Role == "user")
                {
                    <div class="flex justify-end">
                        <div class="max-w-2xl px-3 py-2 bg-emerald-600/20 border border-emerald-500/20 rounded-lg text-sm text-gray-200">
                            @msg.Content
                        </div>
                    </div>
                }
                else
                {
                    <div class="space-y-3 max-w-full">
                        @if (!string.IsNullOrEmpty(msg.Thinking))
                        {
                            <details class="text-xs">
                                <summary class="text-gray-500 cursor-pointer hover:text-gray-400">Reasoning</summary>
                                <div class="mt-1 p-2 bg-gray-900/50 border border-gray-800/50 rounded text-gray-500 italic">@msg.Thinking</div>
                            </details>
                        }

                        @if (!string.IsNullOrEmpty(msg.Explanation))
                        {
                            <div class="text-sm text-gray-300">@msg.Explanation</div>
                        }
                        @if (!string.IsNullOrEmpty(msg.Summary) || !string.IsNullOrEmpty(msg.RiskLevel) || (msg.Findings?.Count > 0) || (msg.RecommendedActions?.Count > 0))
                        {
                            <div class="border border-gray-800 rounded-lg p-3 bg-gray-900/40 space-y-2">
                                @if (!string.IsNullOrEmpty(msg.Summary))
                                {
                                    <div class="text-sm text-gray-200">@msg.Summary</div>
                                }
                                @if (!string.IsNullOrEmpty(msg.RiskLevel))
                                {
                                    <div class="text-xs">
                                        <span class="@RiskLevelClasses(msg.RiskLevel)">@msg.RiskLevel</span>
                                    </div>
                                }
                                @if (msg.Findings?.Count > 0)
                                {
                                    <div>
                                        <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Findings</div>
                                        @foreach (var finding in msg.Findings)
                                        {
                                            <div class="text-xs text-gray-300">• @finding</div>
                                        }
                                    </div>
                                }
                                @if (msg.RecommendedActions?.Count > 0)
                                {
                                    <div>
                                        <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Recommended Actions</div>
                                        @foreach (var action in msg.RecommendedActions)
                                        {
                                            <div class="text-xs text-gray-300">• @action</div>
                                        }
                                    </div>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(msg.Error))
                        {
                            <div class="p-3 bg-rose-500/10 border border-rose-500/20 rounded-lg text-xs text-rose-400 font-mono whitespace-pre-wrap">@msg.Error</div>
                        }

                        @if (!string.IsNullOrEmpty(msg.ChartType) && msg.ChartType != "none" && msg.Rows?.Count > 0)
                        {
                            <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/30">
                                <canvas id="chart-@idx" class="max-h-64 w-full"></canvas>
                            </div>
                        }

                        @if (msg.Columns?.Count > 0 && msg.Rows?.Count > 0)
                        {
                            <div class="border border-gray-800 rounded-lg overflow-hidden">
                                <div class="overflow-x-auto">
                                    <table class="w-full text-xs">
                                        <thead class="bg-gray-900/70 sticky top-0">
                                            <tr>
                                                @foreach (var col in msg.Columns)
                                                {
                                                    <th class="text-left px-3 py-2 font-medium text-gray-500 border-b border-gray-800 whitespace-nowrap">@col</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-gray-800/50">
                                            @foreach (var row in msg.Rows)
                                            {
                                                <tr class="hover:bg-gray-900/30">
                                                    @foreach (var col in msg.Columns)
                                                    {
                                                        <td class="px-3 py-1.5 text-gray-300 font-mono whitespace-nowrap">@FormatCell(row.GetValueOrDefault(col))</td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                <div class="px-3 py-1.5 bg-gray-900/50 border-t border-gray-800 text-[10px] text-gray-600 flex items-center justify-between">
                                    <span>@msg.RowCount rows</span>
                                    <span>@((msg.InputTokens + msg.OutputTokens).ToString("N0")) tokens</span>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(msg.Sql))
                        {
                            <details class="text-xs">
                                <summary class="text-gray-500 cursor-pointer hover:text-gray-400 flex items-center gap-1.5">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                                    View SQL
                                </summary>
                                <div class="mt-1 border border-gray-800 rounded-lg overflow-hidden">
                                    <div class="flex items-center justify-between px-3 py-1.5 bg-gray-900/70 border-b border-gray-800">
                                        <span class="text-[10px] text-gray-500 uppercase tracking-wider">SQL</span>
                                    </div>
                                    <pre class="p-3 text-xs text-emerald-300 font-mono whitespace-pre-wrap bg-gray-950">@msg.Sql</pre>
                                </div>
                            </details>
                        }
                    </div>
                }
            }

            @if (loading)
            {
                <div class="space-y-2 max-w-2xl">
                    @if (_pendingMessage?.StreamEvents?.Count > 0)
                    {
                        <div class="border border-gray-800/60 rounded-lg overflow-hidden bg-gray-900/30">
                            <div class="px-3 py-1.5 border-b border-gray-800/60 flex items-center gap-2">
                                <svg class="w-3 h-3 animate-spin text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                                <span class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">Agent Reasoning</span>
                            </div>
                            <div class="p-2.5 space-y-1.5">
                                @foreach (var evt in _pendingMessage.StreamEvents)
                                {
                                    <div class="flex items-start gap-2 text-xs">
                                        <span class="shrink-0 mt-0.5 @StreamEventDotClass(evt.Type) w-1.5 h-1.5 rounded-full"></span>
                                        <div class="min-w-0">
                                            <span class="@StreamEventTextClass(evt.Type)">@evt.Message</span>
                                            @if (!string.IsNullOrEmpty(evt.Sql))
                                            {
                                                <details class="mt-1">
                                                    <summary class="text-gray-600 cursor-pointer hover:text-gray-500">View SQL</summary>
                                                    <pre class="mt-1 p-2 text-[10px] bg-gray-950 text-emerald-300 rounded font-mono whitespace-pre-wrap border border-gray-800">@evt.Sql</pre>
                                                </details>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="flex items-center gap-2 text-xs text-gray-500">
                            <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                            Running query...
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Input -->
        <div class="border-t border-gray-800 p-3">
            <form @onsubmit="Send" @onsubmit:preventDefault class="flex gap-2">
                <input type="text" @bind="input" @bind:event="oninput" placeholder="Ask about your data... e.g. 'Top 10 merchants by volume this week'"
                       disabled="@loading"
                       class="flex-1 px-3 py-2.5 bg-gray-900 border border-gray-800 rounded-lg text-sm text-white placeholder-gray-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 disabled:opacity-50" />
                <button type="submit" disabled="@(loading || string.IsNullOrWhiteSpace(input) || string.IsNullOrEmpty(database))"
                        class="px-4 py-2.5 bg-emerald-600 hover:bg-emerald-500 disabled:bg-gray-800 disabled:text-gray-600 text-white text-sm font-medium rounded-lg transition-colors">
                    Ask
                </button>
            </form>
            <div class="mt-2 flex flex-wrap gap-2">
                @foreach (var suggestion in quickAskSuggestions)
                {
                    <button @onclick="() => QuickAsk(suggestion.Prompt)"
                            class="px-2 py-1 text-[10px] text-gray-500 border border-gray-800 rounded hover:bg-gray-900 hover:text-gray-300 transition-colors">
                        @suggestion.Label
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public string? ConversationIdParam { get; set; }

    private List<ChatMessage> messages = [];
    private string input = "";
    private bool loading;
    private string database = "";
    private string mode = "general";
    private List<string> databases = [];
    private string? dbLoadError;
    private List<AnalyticsConversation> conversations = [];
    private string? activeConversationId;
    private Dictionary<string, PeriodicTimer> activePolls = [];
    private ElementReference messagesContainer;
    private string userId = "default";
    private bool _renderChartsAfterUpdate;
    private ChatMessage? _pendingMessage;
    private bool showHistoryMobile;
    private HashSet<string> databaseTables = new(StringComparer.OrdinalIgnoreCase);
    private List<QuickAskSuggestion> quickAskSuggestions = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "default";
        await LoadDatabases();
        await LoadConversations();

        // Restore active conversation from URL query param (persists across browser refresh)
        if (!string.IsNullOrEmpty(ConversationIdParam))
            await LoadConversation(ConversationIdParam, updateUrl: false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_renderChartsAfterUpdate)
        {
            _renderChartsAfterUpdate = false;
            await RenderCharts();
        }
    }

    private static readonly HashSet<string> SystemDatabases =
        ["system", "INFORMATION_SCHEMA", "information_schema", "default"];

    private string DbPrefKey => $"analytics:prefs:{userId}:database";
    private string ModePrefKey => $"analytics:prefs:{userId}:mode";

    private async Task LoadDatabases()
    {
        databases = ["lipila_blaze"];
        dbLoadError = null;
        try
        {
            var json = await ClickHouse.QueryAsync("SHOW DATABASES");

            if (json.StartsWith("ClickHouse error") || json.StartsWith("Error:") || json.StartsWith("Query failed:"))
            {
                dbLoadError = json;
            }
            else
            {
                using var doc = System.Text.Json.JsonDocument.Parse(json);
                if (doc.RootElement.TryGetProperty("data", out var data))
                {
                    var loaded = data.EnumerateArray()
                        .Where(r => r.TryGetProperty("name", out var v) && v.ValueKind == System.Text.Json.JsonValueKind.String)
                        .Select(r => r.GetProperty("name").GetString()!)
                        .Where(s => !string.IsNullOrWhiteSpace(s) && !SystemDatabases.Contains(s))
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .OrderBy(s => s)
                        .ToList();
                    if (loaded.Count > 0)
                        databases = loaded;
                }
            }
        }
        catch (Exception ex)
        {
            dbLoadError = ex.Message;
        }

        // Restore saved database preference, fall back to first in list
        var saved = await Cache.GetOrDefaultAsync<string>(DbPrefKey);
        if (!string.IsNullOrEmpty(saved) && databases.Contains(saved, StringComparer.OrdinalIgnoreCase))
            database = saved;
        else if (databases.Count > 0)
            database = databases[0];

        var savedMode = await Cache.GetOrDefaultAsync<string>(ModePrefKey);
        mode = savedMode is "fraud" ? "fraud" : "general";

        await RefreshDatabaseContext();
    }

    private async Task OnDatabaseChanged(ChangeEventArgs e)
    {
        database = e.Value?.ToString() ?? database;
        try { await Cache.SetAsync(DbPrefKey, database, new ZiggyCreatures.Caching.Fusion.FusionCacheEntryOptions { Duration = TimeSpan.FromDays(30) }); } catch { /* best-effort */ }
        await RefreshDatabaseContext();
    }

    private async Task OnModeChanged(ChangeEventArgs e)
    {
        mode = e.Value?.ToString() is "fraud" ? "fraud" : "general";
        try { await Cache.SetAsync(ModePrefKey, mode, new ZiggyCreatures.Caching.Fusion.FusionCacheEntryOptions { Duration = TimeSpan.FromDays(30) }); } catch { /* best-effort */ }
        BuildQuickAskSuggestions();
    }

    private async Task LoadConversations()
    {
        conversations = await ChatStore.ListConversationsAsync(userId);
    }

    private async Task LoadConversation(string id, bool updateUrl = true)
    {
        var conv = await ChatStore.GetConversationAsync(userId, id);
        if (conv == null) return;

        activeConversationId = conv.Id;
        database = conv.Database;
        mode = conv.Mode is "fraud" ? "fraud" : "general";
        try { await Cache.SetAsync(DbPrefKey, database, new ZiggyCreatures.Caching.Fusion.FusionCacheEntryOptions { Duration = TimeSpan.FromDays(30) }); } catch { /* best-effort */ }
        try { await Cache.SetAsync(ModePrefKey, mode, new ZiggyCreatures.Caching.Fusion.FusionCacheEntryOptions { Duration = TimeSpan.FromDays(30) }); } catch { /* best-effort */ }
        await RefreshDatabaseContext();
        messages = (conv.Messages ?? []).Select(m =>
        {
            if (m.Role == "assistant" && m.Response != null)
            {
                return new ChatMessage
                {
                    Role = "assistant",
                    Thinking = m.Response.Thinking,
                    Sql = m.Response.Sql,
                    Explanation = m.Response.Explanation,
                    Summary = m.Response.Summary,
                    RiskLevel = m.Response.RiskLevel,
                    Findings = m.Response.Findings ?? [],
                    RecommendedActions = m.Response.RecommendedActions ?? [],
                    Error = m.Response.Error,
                    ChartType = m.Response.ChartType ?? "none",
                    Columns = m.Response.Columns ?? [],
                    Rows = m.Response.Rows ?? [],
                    RowCount = m.Response.RowCount,
                    InputTokens = m.Response.InputTokens,
                    OutputTokens = m.Response.OutputTokens
                };
            }
            return new ChatMessage { Role = m.Role ?? "user", Content = m.Content };
        }).ToList();

        // Schedule chart render after next DOM update
        _renderChartsAfterUpdate = true;

        // Persist the active conversation in the URL so browser refresh restores it
        if (updateUrl)
            Navigation.NavigateTo($"/admin/chat?id={id}", replace: true);

        // Check pending jobs
        var jobs = await JobStore.GetUserJobsAsync(userId, id);
        foreach (var job in jobs.Where(j => j.Status == "pending" || j.Status == "running"))
        {
            StartPolling(job.Id);
        }
    }

    private void NewConversation()
    {
        activeConversationId = null;
        ClearChat();
        Navigation.NavigateTo("/admin/chat", replace: true);
    }

    private async Task DeleteConversation(string id)
    {
        await ChatStore.DeleteConversationAsync(userId, id);
        if (activeConversationId == id) NewConversation();
        await LoadConversations();
    }

    private async Task Send()
    {
        var prompt = input.Trim();
        if (string.IsNullOrEmpty(prompt) || loading || string.IsNullOrEmpty(database)) return;

        messages.Add(new ChatMessage { Role = "user", Content = prompt });
        input = "";
        loading = true;

        try
        {
            var conversationId = activeConversationId;

            if (string.IsNullOrEmpty(conversationId))
            {
                var conversation = new AnalyticsConversation
                {
                    Database = database,
                    Mode = mode,
                    UserId = userId,
                    Title = prompt.Length > 50 ? prompt[..47] + "..." : prompt
                };
                await ChatStore.SaveConversationAsync(conversation);
                conversationId = conversation.Id;
                activeConversationId = conversationId;
                await LoadConversations();
            }

            var job = new AnalyticsQueryJob
            {
                ConversationId = conversationId,
                UserId = userId,
                Prompt = prompt,
                Database = database,
                Mode = mode
            };

            await JobStore.CreateAsync(job);
            await Worker.EnqueueAsync(job.Id);
            StartPolling(job.Id);
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage { Role = "assistant", Error = "Request failed: " + ex.Message });
            loading = false;
        }
    }

    private void StartPolling(string jobId)
    {
        if (activePolls.ContainsKey(jobId)) return;

        // Create a pending message placeholder that we'll populate with stream events
        _pendingMessage ??= new ChatMessage { Role = "progress", StreamEvents = [] };

        var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        activePolls[jobId] = timer;

        _ = Task.Run(async () =>
        {
            while (await timer.WaitForNextTickAsync())
            {
                try
                {
                    var job = await JobStore.GetAsync(jobId);
                    if (job == null) { StopPolling(jobId); break; }

                    // Always refresh stream events for live display
                    if (_pendingMessage != null && job.StreamEvents.Count > (_pendingMessage.StreamEvents?.Count ?? 0))
                    {
                        _pendingMessage.StreamEvents = job.StreamEvents;
                        await InvokeAsync(StateHasChanged);
                    }

                    if (job.Status == "completed")
                    {
                        StopPolling(jobId);
                        _pendingMessage = null;
                        if (job.Result != null)
                        {
                            messages.Add(new ChatMessage
                            {
                                Role = "assistant",
                                Thinking = job.Result.Thinking,
                                Sql = job.Result.Sql,
                                Explanation = job.Result.Explanation,
                                Summary = job.Result.Summary,
                                RiskLevel = job.Result.RiskLevel,
                                Findings = job.Result.Findings ?? [],
                                RecommendedActions = job.Result.RecommendedActions ?? [],
                                Error = job.Result.Error,
                                ChartType = job.Result.ChartType ?? "none",
                                Columns = job.Result.Columns ?? [],
                                Rows = job.Result.Rows ?? [],
                                RowCount = job.Result.RowCount,
                                InputTokens = job.Result.InputTokens,
                                OutputTokens = job.Result.OutputTokens
                            });
                        }
                        loading = false;
                        _renderChartsAfterUpdate = true;
                        await InvokeAsync(StateHasChanged);
                        break;
                    }
                    else if (job.Status == "failed")
                    {
                        StopPolling(jobId);
                        _pendingMessage = null;
                        messages.Add(new ChatMessage { Role = "assistant", Error = job.Error ?? "Query failed" });
                        loading = false;
                        await InvokeAsync(StateHasChanged);
                        break;
                    }
                }
                catch
                {
                    StopPolling(jobId);
                    _pendingMessage = null;
                    loading = false;
                    await InvokeAsync(StateHasChanged);
                    break;
                }
            }
        });
    }

    private void StopPolling(string jobId)
    {
        if (activePolls.TryGetValue(jobId, out var timer))
        {
            timer.Dispose();
            activePolls.Remove(jobId);
        }
    }

    private async Task QuickAsk(string prompt)
    {
        input = prompt;
        await Send();
    }

    private async Task RefreshDatabaseContext()
    {
        await LoadDatabaseTables();
        BuildQuickAskSuggestions();
    }

    private async Task LoadDatabaseTables()
    {
        databaseTables.Clear();
        if (string.IsNullOrWhiteSpace(database)) return;

        try
        {
            var escapedDb = database.Replace("`", "``");
            var json = await ClickHouse.QueryAsync($"SHOW TABLES FROM `{escapedDb}`");
            if (json.StartsWith("ClickHouse error") || json.StartsWith("Error:") || json.StartsWith("Query failed:"))
                return;

            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (!doc.RootElement.TryGetProperty("data", out var data))
                return;

            foreach (var row in data.EnumerateArray())
            {
                foreach (var prop in row.EnumerateObject())
                {
                    if (prop.Value.ValueKind == System.Text.Json.JsonValueKind.String)
                    {
                        var tableName = prop.Value.GetString();
                        if (!string.IsNullOrWhiteSpace(tableName))
                            databaseTables.Add(tableName);
                        break;
                    }
                }
            }
        }
        catch
        {
            // best-effort metadata load
        }
    }

    private void BuildQuickAskSuggestions()
    {
        if (mode == "fraud")
        {
            quickAskSuggestions =
            [
                new QuickAskSuggestion("High-risk patterns (24h)", $"Run fraud detection on '{database}' for last 24 hours. Return risk level, findings, and recommended actions."),
                new QuickAskSuggestion("Merchant anomaly scan", $"Identify unusual merchant behaviour in '{database}' over last 24 hours and classify risk."),
                new QuickAskSuggestion("Wallet risk hotspots", $"Find risky wallet/recipient concentration patterns in '{database}' this week."),
                new QuickAskSuggestion("Status mismatch checks", $"Detect suspicious status/amount inconsistencies in '{database}' with fraud-focused findings.")
            ];
            return;
        }

        var hasTransactions = HasTableLike("transaction");
        var hasMerchants = HasTableLike("merchant");
        var hasWallets = HasTableLike("wallet");
        var hasBatchPayments = HasTableLike("batch_payment");

        var suggestions = new List<QuickAskSuggestion>();

        if (hasTransactions || hasBatchPayments)
        {
            suggestions.Add(new QuickAskSuggestion(
                "Hourly volume (24h)",
                $"Hourly transaction count for the last 24 hours in database '{database}'"));

            suggestions.Add(new QuickAskSuggestion(
                "Status breakdown",
                $"Transaction status breakdown today in database '{database}'. Use case-insensitive status filters."));
        }

        if (hasMerchants && (hasTransactions || hasBatchPayments))
        {
            suggestions.Add(new QuickAskSuggestion(
                "Top merchants today",
                $"Top 10 merchants by disbursement volume today in database '{database}'. If status filtering is used, compare status case-insensitively."));
        }

        if (hasWallets && (hasTransactions || hasBatchPayments))
        {
            suggestions.Add(new QuickAskSuggestion(
                "Top recipients this week",
                $"Which wallets received the most disbursements this week in database '{database}'?"));
        }

        if (suggestions.Count == 0)
        {
            suggestions.Add(new QuickAskSuggestion(
                "Explore recent activity",
                $"Show key activity trends for the last 24 hours in database '{database}' based on available tables."));
            suggestions.Add(new QuickAskSuggestion(
                "Top entities",
                $"Show top entities by volume in database '{database}' using the most relevant transactional tables."));
            suggestions.Add(new QuickAskSuggestion(
                "Status mix",
                $"Show status distribution for recent records in database '{database}' and use case-insensitive matching for status-like fields."));
            suggestions.Add(new QuickAskSuggestion(
                "Anomalies",
                $"Find unusual spikes or drops in the last 7 days in database '{database}' using available metrics."));
        }

        quickAskSuggestions = suggestions.Take(4).ToList();
    }

    private bool HasTableLike(string token) =>
        databaseTables.Any(t => t.Contains(token, StringComparison.OrdinalIgnoreCase));

    private void ToggleHistoryMobile() => showHistoryMobile = !showHistoryMobile;

    private async Task RenderCharts()
    {
        for (int i = 0; i < messages.Count; i++)
        {
            var msg = messages[i];
            if (!string.IsNullOrEmpty(msg.ChartType) && msg.ChartType != "none" && msg.Rows?.Count > 0 && msg.Columns?.Count >= 2)
            {
                var labelCol = msg.Columns[0];
                var valueCols = msg.Columns.Skip(1)
                    .Where(col => msg.Rows.Any(row => double.TryParse(row.GetValueOrDefault(col), out _)))
                    .ToList();

                if (valueCols.Count == 0) continue;

                var labels = msg.Rows.Select(row => row.GetValueOrDefault(labelCol) ?? "").ToArray();
                var datasets = valueCols.Select(col => new
                {
                    label = col,
                    data = msg.Rows.Select(row => double.TryParse(row.GetValueOrDefault(col), out var v) ? v : 0.0).ToArray()
                }).ToArray();

                try
                {
                    await JS.InvokeVoidAsync("chartInterop.renderChart", $"chart-{i}", msg.ChartType, labels, datasets, null);
                }
                catch (JSException)
                {
                    // chartInterop not yet available (script still loading) — skip silently
                }
            }
        }
    }

    private void ClearChat()
    {
        _ = JS.InvokeVoidAsync("chartInterop.destroyAllCharts");
        messages.Clear();
        _pendingMessage = null;
    }

    private static string FormatCell(string? value)
    {
        if (string.IsNullOrEmpty(value)) return "";
        if (double.TryParse(value, out var num) && num > 999)
            return num.ToString("N0");
        return value;
    }

    public void Dispose()
    {
        foreach (var timer in activePolls.Values)
            timer.Dispose();
        activePolls.Clear();
    }

    private static string StreamEventDotClass(string type) => type switch
    {
        "thinking" => "bg-emerald-500/60 mt-1",
        "sql" or "executing" => "bg-blue-500/60 mt-1",
        "error" => "bg-rose-500 mt-1",
        "fixing" => "bg-amber-500/80 mt-1",
        "done" => "bg-emerald-400 mt-1",
        _ => "bg-gray-600 mt-1"
    };

    private static string StreamEventTextClass(string type) => type switch
    {
        "error" => "text-rose-400",
        "fixing" => "text-amber-300",
        "done" => "text-emerald-400",
        "sql" or "executing" => "text-blue-300",
        _ => "text-gray-400"
    };

    private static string RiskLevelClasses(string? riskLevel) => (riskLevel ?? "").ToLowerInvariant() switch
    {
        "critical" => "inline-flex px-2 py-0.5 rounded text-[10px] font-medium bg-rose-500/20 text-rose-300 border border-rose-500/30",
        "high" => "inline-flex px-2 py-0.5 rounded text-[10px] font-medium bg-amber-500/20 text-amber-300 border border-amber-500/30",
        "medium" => "inline-flex px-2 py-0.5 rounded text-[10px] font-medium bg-blue-500/20 text-blue-300 border border-blue-500/30",
        _ => "inline-flex px-2 py-0.5 rounded text-[10px] font-medium bg-emerald-500/20 text-emerald-300 border border-emerald-500/30"
    };

