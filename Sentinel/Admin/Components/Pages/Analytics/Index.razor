    private static List<(string Name, List<ChartDataPoint> Points)> GetPieSeriesFromData(
        List<string> columns, List<Dictionary<string, string>> rows)
    {
        // Find label columns (non-numeric or identifier) and value column (first non-identifier numeric)
        var labelCols = columns.Where(col =>
            IsIdentifierColumn(col) || !rows.Any(row => double.TryParse(row.GetValueOrDefault(col), out _))
        ).ToList();
        if (labelCols.Count == 0) labelCols.Add(columns[0]);

        var valueCol = columns
            .FirstOrDefault(col => !IsIdentifierColumn(col) &&
                                   !labelCols.Contains(col) &&
                                   rows.Any(row => double.TryParse(row.GetValueOrDefault(col), out _)));
        // Fallback to any numeric column
        valueCol ??= columns.FirstOrDefault(col => rows.Any(row => double.TryParse(row.GetValueOrDefault(col), out _)));
        if (valueCol == null) return [];

        string GetLabel(Dictionary<string, string> row) =>
            string.Join(" ", labelCols
                .Select(c => row.GetValueOrDefault(c) ?? "")
                .Where(v => !string.IsNullOrWhiteSpace(v)));

        var points = rows.Select(row =>
            new ChartDataPoint(
                GetLabel(row),
                decimal.TryParse(row.GetValueOrDefault(valueCol), out var v) ? v : 0m
            )).ToList();
        return [("Values", points)];
    }

