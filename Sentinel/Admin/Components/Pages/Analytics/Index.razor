    private void NormalizeAssistantMessage(ChatMessage msg)
    {
        if (msg.Role != "assistant") return;
        var availableTabs = new List<string>();
        if (HasSummaryContent(msg)) availableTabs.Add(TabSummary);
        if (HasChartContent(msg)) availableTabs.Add(TabChart);
        if (HasTableContent(msg)) availableTabs.Add(TabTable);
        if (HasSqlContent(msg)) availableTabs.Add(TabSql);
        if (HasReasoningContent(msg)) availableTabs.Add(TabReasoning);
        msg.ActiveTab = availableTabs.Contains(msg.ActiveTab) ? msg.ActiveTab : availableTabs.FirstOrDefault() ?? TabSummary;
    }

