    }

    private static List<string> GetApplicableChartTypes(QueryResult r)
    {
        if (r.Columns.Count < 2 || r.Rows.Count == 0) return [];
        return GetApplicableChartTypesFromData(r.Columns, r.Rows);
    }

    private static List<string> GetApplicableChartTypesFromData(
        List<string> columns, List<Dictionary<string, string>> rows)
    {
        var types = new List<string>();

        var numericCols = columns.Skip(1)
            .Where(col => rows.Any(row => double.TryParse(row.GetValueOrDefault(col), out _)))
            .ToList();

        var rowCount = rows.Count;
        var hasLabels = rows.Any(row => !double.TryParse(row.GetValueOrDefault(columns[0]), out _));

        if (hasLabels && numericCols.Count > 0)
        {
            types.Add("bar");
            types.Add("line");
            types.Add("area");
        }

        if (hasLabels && numericCols.Count >= 1 && rowCount <= 12)
        {
            types.Add("pie");
            types.Add("donut");
        }

        if (numericCols.Count >= 2)
            types.Add("scatter");

        if (hasLabels && numericCols.Count > 0 && rowCount <= 10)
            types.Add("radar");

        if (hasLabels && numericCols.Count >= 1 && rowCount <= 8)
            types.Add("radialbar");

        if (hasLabels && numericCols.Count >= 1)
            types.Add("treemap");

        if (hasLabels && numericCols.Count > 1 && rowCount > 2)
            types.Add("heatmap");

        return types;
    }

