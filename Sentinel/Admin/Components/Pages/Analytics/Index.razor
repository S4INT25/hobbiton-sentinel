    }

    private static List<(string Name, List<ChartDataPoint> Points)> GetChartSeriesFromData(
        List<string> columns, List<Dictionary<string, string>> rows)
    {
        // Identify label columns (non-numeric, non-identifier) and value columns (numeric, non-identifier)
        var labelCols = new List<string>();
        var numericCols = new List<string>();

        foreach (var col in columns)
        {
            bool isNumeric = rows.Any(row => double.TryParse(row.GetValueOrDefault(col), out _));
            if (isNumeric && !IsIdentifierColumn(col))
                numericCols.Add(col);
            else if (!isNumeric || IsIdentifierColumn(col))
                labelCols.Add(col);
        }

        // If no label columns found, use first column
        if (labelCols.Count == 0) labelCols.Add(columns[0]);

        // Build combined label from all label columns (e.g. "William Mwape")
        string GetLabel(Dictionary<string, string> row) =>
            string.Join(" ", labelCols
                .Select(c => row.GetValueOrDefault(c) ?? "")
                .Where(v => !string.IsNullOrWhiteSpace(v)));

        // Detect grouped/pivoted pattern: exactly one non-identifier numeric column AND
        // a category column that repeats with few distinct values relative to rows
        if (labelCols.Count >= 2 && numericCols.Count >= 1)
        {
            // Check if last label col is a category grouping (few distinct values, repeating labels)
            var lastLabelCol = labelCols.Last();
            var distinctLabels = rows.Select(r => r.GetValueOrDefault(lastLabelCol)).Distinct().Count();
            var distinctFirstLabel = rows.Select(r => r.GetValueOrDefault(labelCols[0])).Distinct().Count();

            // It's a grouped series if the last label col has fewer distinct values than the first
            // (e.g. event_type has 3 values vs event_hour has 8 values)
            if (distinctLabels < distinctFirstLabel && distinctLabels <= 20)
            {
                var valueCol = numericCols[0];
                var xLabelCols = labelCols.Take(labelCols.Count - 1).ToList();

                string GetXLabel(Dictionary<string, string> row) =>
                    string.Join(" ", xLabelCols
                        .Select(c => row.GetValueOrDefault(c) ?? "")
                        .Where(v => !string.IsNullOrWhiteSpace(v)));

                var groups = rows
                    .GroupBy(row => row.GetValueOrDefault(lastLabelCol) ?? "Unknown")
                    .ToList();

                return groups.Select(g =>
                    (g.Key, g.Select(row =>
                        new ChartDataPoint(
                            GetXLabel(row),
                            decimal.TryParse(row.GetValueOrDefault(valueCol), out var v) ? v : 0m
                        )).ToList())
                ).ToList();
            }
        }

        // Default: each numeric column is a separate series
        if (numericCols.Count == 0)
        {
            // Fallback: last column as value even if identifier
            var lastNumeric = columns
                .LastOrDefault(col => rows.Any(row => double.TryParse(row.GetValueOrDefault(col), out _)));
            if (lastNumeric != null) numericCols = [lastNumeric];
            else return [];
        }

        return numericCols.Select(col =>
            (HumanizeColumn(col), rows.Select(row =>
                new ChartDataPoint(
                    GetLabel(row),
                    decimal.TryParse(row.GetValueOrDefault(col), out var v) ? v : 0m
                )).ToList())
        ).ToList();
    }

    private static bool IsIdentifierColumn(string columnName)
    {
        var lower = columnName.ToLowerInvariant().Replace("_", " ").Replace("-", " ");
        string[] identifierPatterns =
        [
            "phone", "mobile", "msisdn", "cell",
            "id", "uuid", "guid",
            "account number", "account no",
            "code", "reference", "ref no",
            "national id", "nrc"
        ];
        return identifierPatterns.Any(p => lower.Contains(p));
    }

