@page "/admin/settings"
@inject IFraudPatternStore PatternStore
@inject IEvidenceSourceStore SourceStore
@inject IAuditLogStore AuditStore
@attribute [Authorize(Policy = AuthConstants.AdminOnlyPolicy)]

<PageTitle>Settings — Sentinel</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-lg font-semibold text-white">Settings</h1>
            <p class="text-xs text-gray-500 mt-0.5">Manage fraud detection patterns and system configuration</p>
        </div>
    </div>

    <div class="flex items-center gap-2 border-b border-gray-800 pb-3">
        <button @onclick="() => activeTab = SettingsTab.FraudPatterns"
                class="@TabClass(SettingsTab.FraudPatterns)">
            Fraud Patterns
        </button>
        <button @onclick="() => activeTab = SettingsTab.EvidenceSources"
                class="@TabClass(SettingsTab.EvidenceSources)">
            Evidence Sources
        </button>
    </div>

    @if (activeTab == SettingsTab.FraudPatterns)
    {
    <!-- Fraud Patterns Section -->
    <div class="space-y-3">
        <div class="flex items-center justify-between">
            <h2 class="text-sm font-medium text-gray-300">Fraud Patterns</h2>
            <button @onclick="ShowAddForm" class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-all duration-200">
                Add Pattern
            </button>
        </div>

        @if (showForm)
        {
            <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50 space-y-3 animate-in">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Name</label>
                        <input @bind="editPattern.Name" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors" placeholder="Pattern name" />
                    </div>
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Category</label>
                        <select @bind="editPattern.Category" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-emerald-500 focus:outline-none transition-colors">
                            @foreach (var cat in Categories)
                            {
                                <option value="@cat">@FormatCategory(cat)</option>
                            }
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Description</label>
                    <textarea @bind="editPattern.Description" rows="4"
                              class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors font-mono text-xs leading-relaxed"
                              placeholder="Describe when this pattern should be flagged..."></textarea>
                </div>
                <div class="flex items-center gap-2">
                    <label class="flex items-center gap-2 text-xs text-gray-300 cursor-pointer">
                        <input type="checkbox" @bind="editPattern.Enabled" class="rounded bg-gray-800 border-gray-700 text-emerald-500 focus:ring-emerald-500" />
                        Enabled
                    </label>
                </div>
                <div class="flex items-center gap-2 pt-1">
                    <button @onclick="SavePattern" disabled="@saving"
                            class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                        @(saving ? "Saving…" : (isEditing ? "Update" : "Create"))
                    </button>
                    <button @onclick="CancelForm" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white transition-colors">
                        Cancel
                    </button>
                </div>
            </div>
        }

        <!-- Category filter -->
        <div class="flex flex-wrap gap-1.5">
            <button @onclick="() => selectedCategory = null"
                    class="@CategoryFilterClass(null)">All</button>
            @foreach (var cat in Categories)
            {
                var c = cat;
                <button @onclick="() => selectedCategory = c"
                        class="@CategoryFilterClass(c)">@FormatCategory(c)</button>
            }
        </div>

        <!-- Pattern list -->
        <div class="space-y-2">
            @foreach (var pattern in FilteredPatterns)
            {
                <div class="border border-gray-800 rounded-lg p-3 bg-gray-900/30 hover:bg-gray-900/50 transition-all duration-200 group">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2">
                                <span class="text-xs font-mono text-gray-600">#@pattern.Id</span>
                                <span class="text-sm font-medium text-white">@pattern.Name</span>
                                <span class="@CategoryBadgeClass(pattern.Category)">@FormatCategory(pattern.Category)</span>
                                @if (!pattern.Enabled)
                                {
                                    <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-700/40 text-gray-400 border border-gray-700">Disabled</span>
                                }
                            </div>
                            <p class="text-xs text-gray-500 mt-1 line-clamp-2 whitespace-pre-wrap">@pattern.Description.Trim()</p>
                        </div>
                        <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                            <button @onclick="() => EditPattern(pattern)" class="p-1.5 text-gray-500 hover:text-emerald-400 transition-colors" title="Edit">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            </button>
                            <button @onclick="() => TogglePattern(pattern)" class="p-1.5 text-gray-500 hover:text-amber-400 transition-colors" title="@(pattern.Enabled ? "Disable" : "Enable")">
                                @if (pattern.Enabled)
                                {
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                                }
                                else
                                {
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                }
                            </button>
                            <button @onclick="() => DeletePattern(pattern)" class="p-1.5 text-gray-500 hover:text-rose-400 transition-colors" title="Delete">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
            }

            @if (!FilteredPatterns.Any())
            {
                <div class="text-center py-8 text-gray-600 text-xs">No patterns found</div>
            }
        </div>
    </div>
    }

    @if (activeTab == SettingsTab.EvidenceSources)
    {
    <!-- Evidence Sources Section -->
    <div class="space-y-3">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-sm font-medium text-gray-300">Evidence Sources</h2>
                <p class="text-xs text-gray-600 mt-0.5">Cross-database sources the agent queries for additional evidence</p>
            </div>
            <button @onclick="ShowAddSourceForm" class="px-3 py-1.5 text-xs font-medium bg-blue-600 hover:bg-blue-500 text-white rounded-md transition-all duration-200">
                Add Source
            </button>
        </div>

        @if (showSourceForm)
        {
            <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50 space-y-3 animate-in">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Name</label>
                        <input @bind="editSource.Name" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors" placeholder="e.g. Patumba App" />
                    </div>
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Evidence Database</label>
                        <input @bind="editSource.EvidenceDatabase" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors" placeholder="e.g. patumba_app" />
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Lipila Merchant IDs (comma-separated)</label>
                        <input @bind="editSource.LipilaMerchantIds" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors" placeholder="e.g. 35" />
                    </div>
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Lipila Partner ID</label>
                        <input type="number" @bind="editSource.LipilaPartnerId" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors" />
                    </div>
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Join Mappings (JSON)</label>
                    <textarea @bind="editSource.JoinMappings" rows="3"
                              class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors font-mono text-xs leading-relaxed"
                              placeholder='{"lipila_field": "account_number", "evidence_field": "billed_account"}'></textarea>
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Table Descriptions</label>
                    <textarea @bind="editSource.TableDescriptions" rows="3"
                              class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors font-mono text-xs leading-relaxed"
                              placeholder="Describe the key tables in this database..."></textarea>
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Evidence Checks (JSON array)</label>
                    <textarea @bind="editSource.EvidenceChecks" rows="3"
                              class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors font-mono text-xs leading-relaxed"
                              placeholder='["Check 1", "Check 2"]'></textarea>
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Notes</label>
                    <textarea @bind="editSource.Notes" rows="2"
                              class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white placeholder-gray-600 focus:border-emerald-500 focus:outline-none transition-colors text-xs leading-relaxed"
                              placeholder="Additional context for the agent..."></textarea>
                </div>
                <div class="flex items-center gap-2">
                    <label class="flex items-center gap-2 text-xs text-gray-300 cursor-pointer">
                        <input type="checkbox" @bind="editSource.Enabled" class="rounded bg-gray-800 border-gray-700 text-emerald-500 focus:ring-emerald-500" />
                        Enabled
                    </label>
                </div>
                <div class="flex items-center gap-2 pt-1">
                    <button @onclick="SaveSource" disabled="@savingSource"
                            class="px-3 py-1.5 text-xs font-medium bg-blue-600 hover:bg-blue-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                        @(savingSource ? "Saving…" : (isEditingSource ? "Update" : "Create"))
                    </button>
                    <button @onclick="CancelSourceForm" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white transition-colors">
                        Cancel
                    </button>
                </div>
            </div>
        }

        <div class="space-y-2">
            @foreach (var source in sources)
            {
                <div class="border border-gray-800 rounded-lg p-3 bg-gray-900/30 hover:bg-gray-900/50 transition-all duration-200 group">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="text-xs font-mono text-gray-600">#@source.Id</span>
                                <span class="text-sm font-medium text-white">@source.Name</span>
                                <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20">@source.EvidenceDatabase</span>
                                @if (!string.IsNullOrWhiteSpace(source.LipilaMerchantIds))
                                {
                                    <span class="text-[10px] text-gray-500">Merchants: @source.LipilaMerchantIds</span>
                                }
                                @if (source.LipilaPartnerId > 0)
                                {
                                    <span class="text-[10px] text-gray-500">Partner: @source.LipilaPartnerId</span>
                                }
                                @if (!source.Enabled)
                                {
                                    <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-700/40 text-gray-400 border border-gray-700">Disabled</span>
                                }
                            </div>
                        </div>
                        <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                            <button @onclick="() => EditSource(source)" class="p-1.5 text-gray-500 hover:text-emerald-400 transition-colors" title="Edit">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            </button>
                            <button @onclick="() => ToggleSource(source)" class="p-1.5 text-gray-500 hover:text-amber-400 transition-colors" title="@(source.Enabled ? "Disable" : "Enable")">
                                @if (source.Enabled)
                                {
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                                }
                                else
                                {
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                }
                            </button>
                            <button @onclick="() => DeleteSource(source)" class="p-1.5 text-gray-500 hover:text-rose-400 transition-colors" title="Delete">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
            @if (!sources.Any())
            {
                <div class="text-center py-8 text-gray-600 text-xs">No evidence sources configured</div>
            }
        </div>
    </div>
    }
</div>

@code {
    private enum SettingsTab
    {
        FraudPatterns,
        EvidenceSources
    }

    private SettingsTab activeTab = SettingsTab.FraudPatterns;

    // --- Fraud Patterns ---
    private List<FraudPatternEntity> patterns = [];
    private FraudPatternEntity editPattern = new();
    private bool showForm;
    private bool isEditing;
    private bool saving;
    private string? selectedCategory;

    // --- Evidence Sources ---
    private List<EvidenceSource> sources = [];
    private EvidenceSource editSource = new();
    private bool showSourceForm;
    private bool isEditingSource;
    private bool savingSource;

    private static readonly string[] Categories =
    [
        "TransactionAnomaly", "VelocityAbuse", "IdentityAndAccess",
        "AccountCompromise", "NetworkAnomaly", "DataIntegrity", "MerchantOnboarding"
    ];

    private IEnumerable<FraudPatternEntity> FilteredPatterns =>
        selectedCategory is null
            ? patterns
            : patterns.Where(p => p.Category == selectedCategory);

    protected override async Task OnInitializedAsync()
    {
        patterns = await PatternStore.GetAllAsync();
        sources = await SourceStore.GetAllAsync();
    }

    private void ShowAddForm()
    {
        editPattern = new FraudPatternEntity
        {
            Id = patterns.Count > 0 ? patterns.Max(p => p.Id) + 1 : 1,
            Enabled = true,
            Category = "TransactionAnomaly"
        };
        isEditing = false;
        showForm = true;
    }

    private void EditPattern(FraudPatternEntity pattern)
    {
        editPattern = new FraudPatternEntity
        {
            Id = pattern.Id,
            Name = pattern.Name,
            Description = pattern.Description,
            Category = pattern.Category,
            Enabled = pattern.Enabled,
            CreatedBy = pattern.CreatedBy
        };
        isEditing = true;
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        editPattern = new();
    }

    private async Task SavePattern()
    {
        if (string.IsNullOrWhiteSpace(editPattern.Name)) return;
        saving = true;
        try
        {
            await PatternStore.UpsertAsync(editPattern);
            patterns = await PatternStore.GetAllAsync();
            showForm = false;
        }
        finally { saving = false; }
    }

    private async Task TogglePattern(FraudPatternEntity pattern)
    {
        pattern.Enabled = !pattern.Enabled;
        await PatternStore.UpsertAsync(pattern);
        patterns = await PatternStore.GetAllAsync();
    }

    private async Task DeletePattern(FraudPatternEntity pattern)
    {
        await PatternStore.DeleteAsync(pattern.Id);
        patterns = await PatternStore.GetAllAsync();
    }

    private void ShowAddSourceForm()
    {
        editSource = new EvidenceSource
        {
            Id = sources.Count > 0 ? sources.Max(s => s.Id) + 1 : 1,
            Enabled = true
        };
        isEditingSource = false;
        showSourceForm = true;
    }

    private void EditSource(EvidenceSource source)
    {
        editSource = new EvidenceSource
        {
            Id = source.Id,
            Name = source.Name,
            EvidenceDatabase = source.EvidenceDatabase,
            LipilaMerchantIds = source.LipilaMerchantIds,
            LipilaPartnerId = source.LipilaPartnerId,
            JoinMappings = source.JoinMappings,
            TableDescriptions = source.TableDescriptions,
            EvidenceChecks = source.EvidenceChecks,
            Notes = source.Notes,
            Enabled = source.Enabled,
            CreatedBy = source.CreatedBy
        };
        isEditingSource = true;
        showSourceForm = true;
    }

    private void CancelSourceForm()
    {
        showSourceForm = false;
        editSource = new();
    }

    private async Task SaveSource()
    {
        if (string.IsNullOrWhiteSpace(editSource.Name)) return;
        savingSource = true;
        try
        {
            await SourceStore.UpsertAsync(editSource);
            sources = await SourceStore.GetAllAsync();
            showSourceForm = false;
        }
        finally { savingSource = false; }
    }

    private async Task ToggleSource(EvidenceSource source)
    {
        source.Enabled = !source.Enabled;
        await SourceStore.UpsertAsync(source);
        sources = await SourceStore.GetAllAsync();
    }

    private async Task DeleteSource(EvidenceSource source)
    {
        await SourceStore.DeleteAsync(source.Id);
        sources = await SourceStore.GetAllAsync();
    }

    private string TabClass(SettingsTab tab) =>
        tab == activeTab
            ? "px-3 py-1.5 text-xs font-medium rounded-md bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 transition-all duration-200"
            : "px-3 py-1.5 text-xs font-medium rounded-md bg-gray-800 text-gray-400 border border-gray-700 hover:border-gray-600 hover:text-white transition-all duration-200";

    private string CategoryFilterClass(string? cat) =>
        cat == selectedCategory
            ? "px-2 py-1 text-[10px] font-medium rounded-full bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 transition-all duration-200"
            : "px-2 py-1 text-[10px] font-medium rounded-full bg-gray-800 text-gray-400 border border-gray-700 hover:border-gray-600 transition-all duration-200";

    private static string CategoryBadgeClass(string category) => category switch
    {
        "TransactionAnomaly" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20",
        "VelocityAbuse" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-500/10 text-amber-400 border border-amber-500/20",
        "IdentityAndAccess" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-purple-500/10 text-purple-400 border border-purple-500/20",
        "AccountCompromise" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-rose-500/10 text-rose-400 border border-rose-500/20",
        "NetworkAnomaly" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-cyan-500/10 text-cyan-400 border border-cyan-500/20",
        "DataIntegrity" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20",
        "MerchantOnboarding" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-orange-500/10 text-orange-400 border border-orange-500/20",
        _ => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-500/10 text-gray-400 border border-gray-500/20"
    };

    private static string FormatCategory(string cat) => cat switch
    {
        "TransactionAnomaly" => "Transaction",
        "VelocityAbuse" => "Velocity",
        "IdentityAndAccess" => "Identity",
        "AccountCompromise" => "Account",
        "NetworkAnomaly" => "Network",
        "DataIntegrity" => "Data Integrity",
        "MerchantOnboarding" => "Merchant",
        _ => cat
    };
}
