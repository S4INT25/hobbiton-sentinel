@page "/admin"
@using Sentinel.Infrastructure
@using Sentinel.Jobs
@inject ICaseStore CaseStore
@inject IRunLogStore RunLogStore
@inject IFeedbackRuleStore RuleStore
@inject IWorkflowStore WorkflowStore
@inject WorkflowSchedulerService WorkflowScheduler
@inject SchemaLoader SchemaLoader
@inject AuthenticationStateProvider AuthState
@attribute [Authorize(Policy = AuthConstants.Policy)]

<PageTitle>Dashboard — Sentinel</PageTitle>

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-3">
        <div>
            <h1 class="text-xl font-semibold text-white tracking-tight">Dashboard</h1>
            <p class="text-xs text-gray-500 mt-0.5">Fraud detection overview</p>
        </div>
        <div class="flex items-center gap-3">
            @if (!string.IsNullOrEmpty(triggerMessage))
            {
                <span
                    class="text-xs animate-fade @(triggerSuccess ? "text-emerald-400" : "text-rose-400")">@triggerMessage</span>
            }
            <AuthorizeView Policy="@AuthConstants.AdminOnlyPolicy">
                <Authorized>
                    <button @onclick="OpenWorkflowModal"
                            class="px-4 py-2 text-xs font-medium bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white rounded-lg shadow-sm shadow-blue-900/20 transition-all duration-150">
                        Create Workflow
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="@StatsGridClass">
        @if (isAdmin)
        {
            <div
                class="p-4 rounded-xl bg-gray-900/60 border border-gray-800/60 hover:border-gray-700/60 transition-colors duration-200">
                <div class="flex items-center gap-2 mb-2">
                    <div class="w-7 h-7 rounded-lg bg-rose-500/10 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                        </svg>
                    </div>
                    <span class="text-[11px] text-gray-500 font-medium">Open Cases</span>
                </div>
                <div class="text-2xl font-semibold text-white tabular-nums">@openCases</div>
            </div>
            <div
                class="p-4 rounded-xl bg-gray-900/60 border border-gray-800/60 hover:border-gray-700/60 transition-colors duration-200">
                <div class="flex items-center gap-2 mb-2">
                    <div class="w-7 h-7 rounded-lg bg-amber-500/10 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                        </svg>
                    </div>
                    <span class="text-[11px] text-gray-500 font-medium">Active Rules</span>
                </div>
                <div class="text-2xl font-semibold text-white tabular-nums">@activeRules</div>
            </div>
        }
        <div
            class="p-4 rounded-xl bg-gray-900/60 border border-gray-800/60 hover:border-gray-700/60 transition-colors duration-200">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-7 h-7 rounded-lg bg-purple-500/10 flex items-center justify-center">
                    <svg class="w-3.5 h-3.5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                </div>
                <span class="text-[11px] text-gray-500 font-medium">Tokens (24h)</span>
            </div>
            <div class="text-xl font-semibold text-white tabular-nums font-mono">@tokensUsed.ToString("N0")</div>
        </div>
        <div
            class="p-4 rounded-xl bg-gray-900/60 border border-gray-800/60 hover:border-gray-700/60 transition-colors duration-200">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-7 h-7 rounded-lg bg-cyan-500/10 flex items-center justify-center">
                    <svg class="w-3.5 h-3.5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M8 7V3m8 4V3M5 11h14M7 21h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <span class="text-[11px] text-gray-500 font-medium">Workflow Runs (24h)</span>
            </div>
            <div class="text-2xl font-semibold text-white tabular-nums">@workflowRuns24h</div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div>
        <h2 class="text-sm font-medium text-gray-300 mb-3">Quick Actions</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            @if (isAdmin)
            {
                <a href="/admin/workflows"
                   class="p-4 rounded-xl bg-gray-900/60 border border-gray-800/60 hover:border-emerald-500/30 hover:bg-gray-900/80 transition-all duration-200 group">
                    <div class="flex items-center gap-3">
                        <div
                            class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center group-hover:bg-emerald-500/20 transition-colors">
                            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M13 10V3L4 14h7v7l9-11h-7z"/>
                            </svg>
                        </div>
                        <div>
                            <span class="text-sm font-medium text-white">Workflows</span>
                            <p class="text-[11px] text-gray-500">Manage and run workflows</p>
                        </div>
                    </div>
                </a>
                <a href="/admin/cases"
                   class="p-4 rounded-xl bg-gray-900/60 border border-gray-800/60 hover:border-rose-500/30 hover:bg-gray-900/80 transition-all duration-200 group">
                    <div class="flex items-center gap-3">
                        <div
                            class="w-8 h-8 rounded-lg bg-rose-500/10 flex items-center justify-center group-hover:bg-rose-500/20 transition-colors">
                            <svg class="w-4 h-4 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                            </svg>
                        </div>
                        <div>
                            <span class="text-sm font-medium text-white">Cases</span>
                            <p class="text-[11px] text-gray-500">@openCases open investigations</p>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>

    <!-- Recent Runs Table -->
    <div>
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-sm font-medium text-gray-300">Recent Runs</h2>
            <a href="@(isAdmin ? "/admin/workflows" : "/admin/runs")" class="text-[11px] text-gray-500 hover:text-gray-300 transition-colors">
                @(isAdmin ? "View all in Workflows →" : "View all runs →")
            </a>
        </div>
        <div class="border border-gray-800/60 rounded-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm min-w-[640px]">
                    <thead>
                    <tr class="border-b border-gray-800/60 bg-gray-900/30">
                        <th class="text-left px-4 py-2.5 text-[11px] font-medium text-gray-500 uppercase tracking-wider">
                            Run
                        </th>
                        <th class="text-left px-4 py-2.5 text-[11px] font-medium text-gray-500 uppercase tracking-wider">
                            Started
                        </th>
                        <th class="text-left px-4 py-2.5 text-[11px] font-medium text-gray-500 uppercase tracking-wider">
                            Tokens
                        </th>
                        <th class="text-left px-4 py-2.5 text-[11px] font-medium text-gray-500 uppercase tracking-wider">
                            Status
                        </th>
                        <th class="text-left px-4 py-2.5 text-[11px] font-medium text-gray-500 uppercase tracking-wider">
                            Trigger
                        </th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800/40">
                    @foreach (var run in recentRunsList.Take(10))
                    {
                        <tr class="hover:bg-gray-900/40">
                            <td class="px-4 py-2.5">
                                <a href="/admin/runs/@run.RunId"
                                   class="text-emerald-400 hover:text-emerald-300 font-mono text-xs transition-colors">@run.RunId[..Math.Min(12, run.RunId.Length)]</a>
                            </td>
                            <td class="px-4 py-2.5 text-gray-400 text-xs">@run.StartedAt.ToString("MMM dd HH:mm")</td>
                            <td class="px-4 py-2.5 text-gray-300 font-mono text-xs tabular-nums">@((run.InputTokens + run.OutputTokens).ToString("N0"))</td>
                            <td class="px-4 py-2.5">
                                <span class="@RunStatusClasses(run.Status)">@run.Status</span>
                            </td>
                            <td class="px-4 py-2.5 text-gray-500 text-xs truncate max-w-[160px]">
                                @if (run.TriggeredBy.StartsWith("workflow:", StringComparison.OrdinalIgnoreCase))
                                {
                                    <a href="/admin/workflows"
                                       class="text-cyan-400 hover:text-cyan-300 transition-colors">@run.TriggeredBy["workflow:".Length..]</a>
                                }
                                else
                                {
                                    @run.TriggeredBy
                                }
                            </td>
                        </tr>
                    }
                    @if (!recentRunsList.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-10 text-center text-gray-600 text-xs">No runs recorded yet
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (showWorkflowModal)
{
    <div class="fixed inset-0 z-50 bg-black/70 backdrop-blur-sm flex items-center justify-center p-4">
        <div
            class="w-full max-w-2xl border border-gray-800 bg-gray-900 rounded-xl p-4 space-y-3 shadow-2xl transition-all duration-200">
            <h3 class="text-sm font-semibold text-white">Create Workflow</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Name</label>
                    <input @bind="newWorkflow.Name"
                           class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-blue-500 focus:outline-none transition-colors"/>
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Action Type</label>
                    <select @bind="newWorkflow.ActionType"
                            class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-blue-500 focus:outline-none transition-colors">
                        <option value="@WorkflowActionTypes.EmailReport">Email Report</option>
                        <option value="@WorkflowActionTypes.FraudRun">Fraud Run</option>
                    </select>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Database</label>
                    <select @bind="newWorkflow.TargetDatabase"
                            class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-blue-500 focus:outline-none transition-colors">
                        @foreach (var database in workflowDatabases)
                        {
                            <option value="@database">@database</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Schedule Preset</label>
                    <select value="@newWorkflowSchedulePreset" @onchange="OnNewWorkflowSchedulePresetChanged"
                            class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-blue-500 focus:outline-none transition-colors">
                        <option value="every-5-minutes">Every 5 minutes</option>
                        <option value="every-15-minutes">Every 15 minutes</option>
                        <option value="every-30-minutes">Every 30 minutes</option>
                        <option value="hourly">Every 1 hour</option>
                        <option value="every-2-hours">Every 2 hours</option>
                        <option value="daily">Every day</option>
                        <option value="weekly">Every week</option>
                        <option value="custom-date">Custom date/time</option>
                    </select>
                </div>
            </div>
            @if (newWorkflowSchedulePreset == "custom-date")
            {
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Custom Date/Time (UTC)</label>
                    <input type="datetime-local" value="@newWorkflowCustomDateTimeLocal"
                           @onchange="OnNewWorkflowCustomDateChanged"
                           class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-blue-500 focus:outline-none transition-colors"/>
                </div>
            }
            <div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Cron (UTC)</label>
                    <input @bind="newWorkflow.CronExpression"
                           class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white font-mono focus:border-blue-500 focus:outline-none transition-colors"
                           placeholder="0 */2 * * *"/>
                </div>
            </div>
            <div>
                <label class="block text-xs text-gray-400 mb-1">Prompt</label>
                <textarea @bind="newWorkflow.CustomPrompt" rows="4"
                          class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm text-white focus:border-blue-500 focus:outline-none transition-colors"
                          placeholder="Describe what to query or monitor."></textarea>
            </div>
            @if (WorkflowActionTypes.Normalize(newWorkflow.ActionType) == WorkflowActionTypes.EmailReport)
            {
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Email Subject</label>
                        <input @bind="newWorkflow.EmailSubject"
                               class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-blue-500 focus:outline-none transition-colors"/>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">Recipients (comma-separated)</label>
                        <input @bind="newWorkflow.EmailRecipients"
                               class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:border-blue-500 focus:outline-none transition-colors"/>
                    </div>
                </div>
            }
            <div class="flex items-center justify-end gap-2 pt-1">
                <button @onclick="CloseWorkflowModal"
                        class="px-3 py-1.5 text-xs text-gray-400 hover:text-white transition-colors">Cancel
                </button>
                <button @onclick="CreateWorkflowAsync" disabled="@workflowSaving"
                        class="px-3 py-1.5 text-xs font-medium bg-blue-600 hover:bg-blue-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                    @(workflowSaving ? "Creating…" : "Create Workflow")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private int openCases;
    private int activeRules;
    private long tokensUsed;
    private int workflowRuns24h;
    private List<RunSummary> recentRunsList = [];
    private string? triggerMessage;
    private bool triggerSuccess;
    private bool showWorkflowModal;
    private bool workflowSaving;
    private bool isAdmin;
    private WorkflowDefinition newWorkflow = NewWorkflowDraft();
    private List<string> workflowDatabases = ["lipila_blaze"];
    private string newWorkflowSchedulePreset = "hourly";
    private string? newWorkflowCustomDateTimeLocal;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole(AuthConstants.AdminRole);
        await LoadWorkflowDatabasesAsync();
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        if (isAdmin)
        {
            var cases = await CaseStore.GetOpenCasesAsync();
            openCases = cases.Count;

            var rules = await RuleStore.GetActiveRulesAsync();
            activeRules = rules.Count;
        }
        else
        {
            openCases = 0;
            activeRules = 0;
        }

        var runs = await RunLogStore.GetRecentRunsAsync(100);
        recentRunsList = runs;
        workflowRuns24h = runs.Count(r =>
            r.StartedAt >= DateTime.UtcNow.AddHours(-24) &&
            r.TriggeredBy.StartsWith("workflow:", StringComparison.OrdinalIgnoreCase));
        tokensUsed = runs
            .Where(r => r.StartedAt >= DateTime.UtcNow.AddHours(-24))
            .Sum(r => (long)(r.InputTokens + r.OutputTokens));
    }

    private async Task LoadWorkflowDatabasesAsync()
    {
        var databases = await SchemaLoader.GetDatabasesAsync();
        workflowDatabases = databases.Count > 0
            ? databases.OrderBy(d => d).ToList()
            : ["lipila_blaze"];
    }

    private void OpenWorkflowModal()
    {
        newWorkflow = NewWorkflowDraft();
        if (workflowDatabases.Count > 0)
            newWorkflow.TargetDatabase = workflowDatabases[0];
        newWorkflowSchedulePreset = DetectSchedulePreset(newWorkflow.CronExpression);
        newWorkflowCustomDateTimeLocal = BuildDateTimeLocalFromCron(newWorkflow.CronExpression);
        showWorkflowModal = true;
    }

    private void CloseWorkflowModal()
    {
        if (workflowSaving) return;
        showWorkflowModal = false;
    }

    private async Task CreateWorkflowAsync()
    {
        var validationError = ValidateWorkflow(newWorkflow);
        if (validationError is not null)
        {
            triggerSuccess = false;
            triggerMessage = validationError;
            return;
        }

        workflowSaving = true;
        try
        {
            NormalizeWorkflowForSave(newWorkflow);
            newWorkflow.Id = Guid.NewGuid().ToString("N");
            newWorkflow.CreatedBy = "admin";
            await WorkflowStore.UpsertAsync(newWorkflow);
            await WorkflowScheduler.RefreshSchedulesAsync();
            showWorkflowModal = false;
            triggerSuccess = true;
            triggerMessage = $"Workflow created: {newWorkflow.Name}";
        }
        catch (Exception ex)
        {
            triggerSuccess = false;
            triggerMessage = $"Failed to create workflow: {ex.Message}";
        }
        finally
        {
            workflowSaving = false;
        }
    }

    private static WorkflowDefinition NewWorkflowDraft() => new()
    {
        ActionType = WorkflowActionTypes.EmailReport,
        CronExpression = "0 * * * *",
        Enabled = true,
        TargetDatabase = "lipila_blaze"
    };

    private void OnNewWorkflowSchedulePresetChanged(ChangeEventArgs args)
    {
        newWorkflowSchedulePreset = args.Value?.ToString() ?? "hourly";
        if (CronPresets.TryGetValue(newWorkflowSchedulePreset, out var cron))
        {
            newWorkflow.CronExpression = cron;
        }
    }

    private void OnNewWorkflowCustomDateChanged(ChangeEventArgs args)
    {
        newWorkflowCustomDateTimeLocal = args.Value?.ToString();
        var customCron = BuildCustomDateCron(newWorkflowCustomDateTimeLocal);
        if (!string.IsNullOrWhiteSpace(customCron))
            newWorkflow.CronExpression = customCron;
    }

    private static string? ValidateWorkflow(WorkflowDefinition workflow)
    {
        var normalizedActionType = WorkflowActionTypes.Normalize(workflow.ActionType);

        if (string.IsNullOrWhiteSpace(workflow.Name))
            return "Workflow name is required.";
        if (string.IsNullOrWhiteSpace(workflow.TargetDatabase))
            return "Workflow database is required.";
        if (!WorkflowSchedulerService.IsValidCron(workflow.CronExpression))
            return "Workflow cron expression is invalid.";
        if (normalizedActionType == WorkflowActionTypes.EmailReport &&
            string.IsNullOrWhiteSpace(workflow.CustomPrompt))
            return "Workflow prompt is required.";
        if (!WorkflowActionTypes.All.Contains(normalizedActionType, StringComparer.OrdinalIgnoreCase))
            return "Workflow action type is invalid.";
        return null;
    }

    private static void NormalizeWorkflowForSave(WorkflowDefinition workflow) =>
        workflow.ActionType = WorkflowActionTypes.Normalize(workflow.ActionType);

    private static readonly Dictionary<string, string> CronPresets = new(StringComparer.OrdinalIgnoreCase)
    {
        ["every-5-minutes"] = "*/5 * * * *",
        ["every-15-minutes"] = "*/15 * * * *",
        ["every-30-minutes"] = "*/30 * * * *",
        ["hourly"] = "0 * * * *",
        ["every-2-hours"] = "0 */2 * * *",
        ["daily"] = "0 0 * * *",
        ["weekly"] = "0 0 * * 1"
    };

    private static string DetectSchedulePreset(string? cron)
    {
        if (string.IsNullOrWhiteSpace(cron))
            return "hourly";

        foreach (var preset in CronPresets)
        {
            if (string.Equals(preset.Value, cron.Trim(), StringComparison.OrdinalIgnoreCase))
                return preset.Key;
        }

        return IsCustomDateCron(cron) ? "custom-date" : "hourly";
    }

    private static bool IsCustomDateCron(string cron)
    {
        var parts = cron.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length == 5 &&
               int.TryParse(parts[0], out _) &&
               int.TryParse(parts[1], out _) &&
               int.TryParse(parts[2], out _) &&
               int.TryParse(parts[3], out _) &&
               parts[4] == "*";
    }

    private static string? BuildDateTimeLocalFromCron(string? cron)
    {
        if (string.IsNullOrWhiteSpace(cron))
            return null;

        var parts = cron.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length != 5 ||
            !int.TryParse(parts[0], out var minute) ||
            !int.TryParse(parts[1], out var hour) ||
            !int.TryParse(parts[2], out var day) ||
            !int.TryParse(parts[3], out var month) ||
            month is < 1 or > 12 ||
            day < 1)
        {
            return null;
        }

        var now = DateTime.UtcNow;
        var maxDay = DateTime.DaysInMonth(now.Year, month);
        if (day > maxDay || hour is < 0 or > 23 || minute is < 0 or > 59)
            return null;

        var date = new DateTime(now.Year, month, day, hour, minute, 0, DateTimeKind.Utc);
        return date.ToString("yyyy-MM-ddTHH:mm");
    }

    private static string? BuildCustomDateCron(string? dateTimeLocal)
    {
        if (string.IsNullOrWhiteSpace(dateTimeLocal))
            return null;

        if (!DateTime.TryParse(dateTimeLocal, out var selected))
            return null;

        return $"{selected.Minute} {selected.Hour} {selected.Day} {selected.Month} *";
    }

    private static string RunStatusClasses(string status) => status?.ToLowerInvariant() switch
    {
        "completed" => "inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20",
        "running" => "inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20",
        "failed" or "error" => "inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-rose-500/10 text-rose-400 border border-rose-500/20",
        _ => "inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-gray-500/10 text-gray-400 border border-gray-500/20"
    };

    private string StatsGridClass => isAdmin ? "grid grid-cols-2 lg:grid-cols-4 gap-3" : "grid grid-cols-1 sm:grid-cols-2 gap-3";

}