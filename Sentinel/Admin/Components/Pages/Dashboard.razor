@page "/admin"
@inject ICaseStore CaseStore
@inject IRunLogStore RunLogStore
@inject IFeedbackRuleStore RuleStore
@inject NavigationManager Navigation
@attribute [Authorize(Policy = AuthConstants.Policy)]
@rendermode InteractiveServer

<PageTitle>Dashboard — Sentinel</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-lg font-semibold text-white">Dashboard</h1>
        <div class="flex items-center gap-2">
            @if (!string.IsNullOrEmpty(triggerMessage))
            {
                <span class="text-xs @(triggerSuccess ? "text-emerald-400" : "text-rose-400")">@triggerMessage</span>
            }
            <button @onclick="TriggerRun" disabled="@triggerLoading"
                    class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                @(triggerLoading ? "Running…" : "Run Now")
            </button>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-4 gap-3">
        <div class="p-4 bg-gray-900 border border-gray-800 rounded-lg">
            <div class="text-xs text-gray-500 mb-1">Open Cases</div>
            <div class="text-2xl font-semibold text-white">@openCases</div>
        </div>
        <div class="p-4 bg-gray-900 border border-gray-800 rounded-lg">
            <div class="text-xs text-gray-500 mb-1">Runs (24h)</div>
            <div class="text-2xl font-semibold text-white">@recentRuns</div>
        </div>
        <div class="p-4 bg-gray-900 border border-gray-800 rounded-lg">
            <div class="text-xs text-gray-500 mb-1">Active Rules</div>
            <div class="text-2xl font-semibold text-white">@activeRules</div>
        </div>
        <div class="p-4 bg-gray-900 border border-gray-800 rounded-lg">
            <div class="text-xs text-gray-500 mb-1">Tokens (24h)</div>
            <div class="text-2xl font-semibold text-white font-mono text-lg">@tokensUsed.ToString("N0")</div>
        </div>
    </div>

    <!-- Recent Runs -->
    <div>
        <h2 class="text-sm font-medium text-gray-400 mb-3">Recent Runs</h2>
        <div class="border border-gray-800 rounded-lg overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-gray-900/50">
                    <tr class="text-xs text-gray-500 border-b border-gray-800">
                        <th class="text-left px-4 py-2 font-medium">Run ID</th>
                        <th class="text-left px-4 py-2 font-medium">Started</th>
                        <th class="text-left px-4 py-2 font-medium">Iterations</th>
                        <th class="text-left px-4 py-2 font-medium">Tokens</th>
                        <th class="text-left px-4 py-2 font-medium">Status</th>
                        <th class="text-left px-4 py-2 font-medium">Triggered By</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800/50">
                    @foreach (var run in runs)
                    {
                        <tr class="hover:bg-gray-900/30 transition-colors">
                            <td class="px-4 py-2.5">
                                <a href="/admin/runs/@run.RunId" class="text-emerald-400 hover:text-emerald-300 font-mono text-xs">@run.RunId</a>
                            </td>
                            <td class="px-4 py-2.5 text-gray-400 text-xs">@run.StartedAt.ToString("MMM dd HH:mm")</td>
                            <td class="px-4 py-2.5 text-gray-300 font-mono text-xs">@run.Iterations</td>
                            <td class="px-4 py-2.5 text-gray-300 font-mono text-xs">@((run.InputTokens + run.OutputTokens).ToString("N0"))</td>
                            <td class="px-4 py-2.5">
                                @if (run.Status == "completed")
                                {
                                    <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">completed</span>
                                }
                                else
                                {
                                    <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-500/10 text-amber-400 border border-amber-500/20">@run.Status</span>
                                }
                            </td>
                            <td class="px-4 py-2.5 text-gray-500 text-xs">@run.TriggeredBy</td>
                        </tr>
                    }
                    @if (!runs.Any())
                    {
                        <tr><td colspan="6" class="px-4 py-8 text-center text-gray-600 text-xs">No runs recorded yet</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private int openCases;
    private int recentRuns;
    private int activeRules;
    private long tokensUsed;
    private List<RunSummary> runs = [];
    private bool triggerLoading;
    private string? triggerMessage;
    private bool triggerSuccess;

    protected override async Task OnInitializedAsync()
    {
        var cases = await CaseStore.GetOpenCasesAsync();
        openCases = cases.Count;

        var rules = await RuleStore.GetActiveRulesAsync();
        activeRules = rules.Count;

        runs = await RunLogStore.GetRecentRunsAsync(10);
        recentRuns = runs.Count(r => r.StartedAt >= DateTime.UtcNow.AddHours(-24));
        tokensUsed = runs
            .Where(r => r.StartedAt >= DateTime.UtcNow.AddHours(-24))
            .Sum(r => (long)(r.InputTokens + r.OutputTokens));
    }

    private async Task TriggerRun()
    {
        triggerLoading = true;
        triggerMessage = null;
        try
        {
            Hangfire.BackgroundJob.Enqueue<Sentinel.Jobs.SentinelJob>(j => j.RunAsync("manual:dashboard"));
            triggerSuccess = true;
            triggerMessage = "Run triggered successfully";
        }
        catch
        {
            triggerSuccess = false;
            triggerMessage = "Failed to trigger run";
        }
        triggerLoading = false;

        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            triggerMessage = null;
            InvokeAsync(StateHasChanged);
        });
    }
}
