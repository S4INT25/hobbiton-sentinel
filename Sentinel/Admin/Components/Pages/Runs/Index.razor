@page "/admin/runs"
@inject IRunLogStore RunLogStore
@inject IActiveRunTracker RunTracker
@attribute [Authorize(Policy = AuthConstants.Policy)]
@implements IDisposable

<PageTitle>Runs — Sentinel</PageTitle>

<div class="space-y-4">
    <div class="flex items-center justify-between">
        <h1 class="text-lg font-semibold text-white">Run History</h1>
        <div class="flex items-center gap-2">
            @if (!string.IsNullOrEmpty(triggerMessage))
            {
                <span class="text-xs @(triggerSuccess ? "text-emerald-400" : "text-rose-400")">@triggerMessage</span>
            }
            <button @onclick="TriggerRun" disabled="@triggerLoading"
                    class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                @(triggerLoading ? "Queueing…" : "Run Now")
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(activeRunId))
    {
        <div class="border border-gray-800 rounded-lg p-3 bg-gray-900/30">
            <div class="flex items-center gap-2 text-xs">
                <span class="text-gray-400">Current run:</span>
                <a href="/admin/runs/@activeRunId" class="text-emerald-400 hover:text-emerald-300 font-mono">@activeRunId</a>
                <span class="@RunStatusClasses(activeRunStatus)">@activeRunStatus</span>
                <span class="text-gray-600">(@activeLogCount tool calls)</span>
            </div>
        </div>
    }

    <div class="border border-gray-800 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-900/50">
                <tr class="text-xs text-gray-500 border-b border-gray-800">
                    <th class="text-left px-4 py-2 font-medium">Run ID</th>
                    <th class="text-left px-4 py-2 font-medium">Started</th>
                    <th class="text-left px-4 py-2 font-medium">Duration</th>
                    <th class="text-left px-4 py-2 font-medium">Iterations</th>
                    <th class="text-left px-4 py-2 font-medium">Tokens (in/out)</th>
                    <th class="text-left px-4 py-2 font-medium">Cases</th>
                    <th class="text-left px-4 py-2 font-medium">Alerts</th>
                    <th class="text-left px-4 py-2 font-medium">Status</th>
                    <th class="text-left px-4 py-2 font-medium">Trigger</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800/50">
                @foreach (var run in PagedRuns)
                {
                    var duration = run.FinishedAt - run.StartedAt;
                    <tr class="hover:bg-gray-900/30 transition-colors">
                        <td class="px-4 py-2.5">
                            <a href="/admin/runs/@run.RunId" class="text-emerald-400 hover:text-emerald-300 font-mono text-xs">@run.RunId</a>
                        </td>
                        <td class="px-4 py-2.5 text-gray-400 text-xs">@run.StartedAt.ToString("MMM dd HH:mm")</td>
                        <td class="px-4 py-2.5 text-gray-400 font-mono text-xs">@($"{duration.TotalMinutes:F0}m")</td>
                        <td class="px-4 py-2.5 text-gray-300 font-mono text-xs">@run.Iterations</td>
                        <td class="px-4 py-2.5 text-gray-300 font-mono text-xs">@run.InputTokens.ToString("N0") / @run.OutputTokens.ToString("N0")</td>
                        <td class="px-4 py-2.5 text-gray-300 font-mono text-xs">@run.CasesCreated</td>
                        <td class="px-4 py-2.5 text-gray-300 font-mono text-xs">@run.AlertsSent</td>
                        <td class="px-4 py-2.5">
                            <span class="@RunStatusClasses(run.Status)">@run.Status</span>
                        </td>
                        <td class="px-4 py-2.5 text-gray-500 text-xs">@run.TriggeredBy</td>
                    </tr>
                }
                @if (!DisplayRuns.Any())
                {
                    <tr><td colspan="9" class="px-4 py-8 text-center text-gray-600 text-xs">No runs recorded yet</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (DisplayRuns.Count > PageSize)
    {
        <div class="mt-3 flex items-center justify-between text-xs">
            <span class="text-gray-500">Page @currentPage / @TotalPages</span>
            <div class="flex items-center gap-2">
                <button @onclick="PrevPage" disabled="@(currentPage <= 1)" class="px-2.5 py-1 border border-gray-800 rounded text-gray-300 disabled:opacity-40">Previous</button>
                <button @onclick="NextPage" disabled="@(currentPage >= TotalPages)" class="px-2.5 py-1 border border-gray-800 rounded text-gray-300 disabled:opacity-40">Next</button>
            </div>
        </div>
    }
</div>

@code {
    private List<RunSummary> runs = [];
    private bool triggerLoading;
    private string? triggerMessage;
    private bool triggerSuccess;
    private string? activeRunId;
    private string activeRunStatus = "queued";
    private DateTime? activeRunStartedAt;
    private int activeLogCount;
    private PeriodicTimer? runPollTimer;
    private CancellationTokenSource? runPollCts;
    private int currentPage = 1;
    private const int PageSize = 20;

    private List<RunSummary> DisplayRuns => BuildDisplayRuns();
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)DisplayRuns.Count / PageSize));
    private IEnumerable<RunSummary> PagedRuns => DisplayRuns.Skip((currentPage - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadRuns();
        var trackedRun = await RunTracker.GetLatestTrackedRunAsync();
        if (trackedRun is not null)
        {
            activeRunId = trackedRun.RunId;
            activeRunStatus = trackedRun.Status;
            activeRunStartedAt = trackedRun.StartedAtUtc;
            StartRunMonitoring(trackedRun.RunId);
        }
    }

    private async Task LoadRuns()
    {
        runs = await RunLogStore.GetRecentRunsAsync(200);
        currentPage = Math.Min(currentPage, TotalPages);
    }

    private List<RunSummary> BuildDisplayRuns()
    {
        var result = runs.ToList();
        if (!string.IsNullOrWhiteSpace(activeRunId) && result.All(r => r.RunId != activeRunId))
        {
            result.Insert(0, new RunSummary
            {
                RunId = activeRunId,
                StartedAt = activeRunStartedAt ?? DateTime.UtcNow,
                FinishedAt = activeRunStartedAt ?? DateTime.UtcNow,
                Status = activeRunStatus,
                TriggeredBy = "manual:runs_page"
            });
        }

        return result;
    }

    private async Task TriggerRun()
    {
        triggerLoading = true;
        triggerMessage = null;
        try
        {
            var runId = DateTime.UtcNow.ToString("yyyyMMddHHmmssfff");
            await RunTracker.MarkQueuedAsync(runId, "manual:runs_page", DateTime.UtcNow);
            Hangfire.BackgroundJob.Enqueue<Sentinel.Jobs.SentinelJob>(j => j.RunAsync("manual:runs_page", runId));
            activeRunId = runId;
            activeRunStatus = "queued";
            activeRunStartedAt = DateTime.UtcNow;
            activeLogCount = 0;
            StartRunMonitoring(runId);
            triggerSuccess = true;
            triggerMessage = $"Run queued ({runId})";
        }
        catch
        {
            triggerSuccess = false;
            triggerMessage = "Failed to trigger run";
        }
        triggerLoading = false;
    }

    private void StartRunMonitoring(string runId)
    {
        StopRunMonitoring();
        runPollCts = new CancellationTokenSource();
        runPollTimer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        var token = runPollCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                while (await runPollTimer.WaitForNextTickAsync(token))
                {
                    var summary = await RunLogStore.GetRunSummaryAsync(runId);
                    var logs = await RunLogStore.GetRunLogsAsync(runId);
                    activeLogCount = logs.Count;
                    if (summary is not null)
                    {
                        activeRunStatus = summary.Status;
                    }
                    else
                    {
                        var tracked = await RunTracker.GetAsync(runId);
                        activeRunStatus = tracked?.Status ?? (logs.Count > 0 ? "running" : "queued");
                    }

                    if (summary is not null)
                    {
                        await RunTracker.MarkCompletedAsync(runId);
                        await LoadRuns();
                        StopRunMonitoring();
                    }

                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException)
            {
            }
        }, token);
    }

    private void StopRunMonitoring()
    {
        runPollCts?.Cancel();
        runPollTimer?.Dispose();
        runPollCts?.Dispose();
        runPollTimer = null;
        runPollCts = null;
    }

    private static string RunStatusClasses(string status)
    {
        return status switch
        {
            "completed" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20",
            "error" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-rose-500/10 text-rose-400 border border-rose-500/20",
            "running" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20",
            "queued" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-700/40 text-gray-300 border border-gray-700",
            _ => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-500/10 text-amber-400 border border-amber-500/20"
        };
    }

    private void PrevPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    public void Dispose()
    {
        StopRunMonitoring();
    }
}
