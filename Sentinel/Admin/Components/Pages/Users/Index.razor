@page "/admin/users"
@inject IUserStore UserStore
@inject IAuditLogStore AuditStore
@inject AuthenticationStateProvider AuthState
@attribute [Authorize(Policy = AuthConstants.AdminOnlyPolicy)]

<PageTitle>Users — Sentinel</PageTitle>

<div class="space-y-4">
    <div class="flex items-center justify-between">
        <h1 class="text-lg font-semibold text-white">Users</h1>
        <button @onclick="() => showAdd = !showAdd" class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-colors">
            Add User
        </button>
    </div>

    @if (feedbackMessage is not null)
    {
        <div class="@FeedbackClass()" role="status">
            <div class="flex items-center justify-between gap-3">
                <span>@feedbackMessage</span>
                <button @onclick="ClearFeedback" class="text-[11px] text-gray-300 hover:text-white transition-colors">Dismiss</button>
            </div>
        </div>
    }

    @if (showAdd)
    {
        <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Username</label>
                    <input type="text" @bind="newUsername" required class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white" />
                </div>
                <div>
                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Password</label>
                    <input type="password" @bind="newPassword" required class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white" />
                </div>
                <div>
                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Display Name</label>
                    <input type="text" @bind="newDisplayName" required class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white" />
                </div>
                <div>
                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Role</label>
                    <select @bind="newRole" class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                        <option value="analyst">Analyst</option>
                        <option value="developer">Developer</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                <div class="col-span-2 flex justify-end gap-2">
                    <button type="button" @onclick="() => showAdd = false" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white">Cancel</button>
                    <button @onclick="CreateUser" disabled="@creatingUser" class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md disabled:opacity-50">
                        @(creatingUser ? "Creating…" : "Create")
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="border border-gray-800 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-900/50">
                <tr class="text-xs text-gray-500 border-b border-gray-800">
                    <th class="text-left px-4 py-2 font-medium">Username</th>
                    <th class="text-left px-4 py-2 font-medium">Display Name</th>
                    <th class="text-left px-4 py-2 font-medium">Role</th>
                    <th class="text-left px-4 py-2 font-medium">Last Login</th>
                    <th class="text-left px-4 py-2 font-medium">Active</th>
                    <th class="text-left px-4 py-2 font-medium"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800/50">
                @foreach (var u in PagedUsers)
                {
                    <tr class="hover:bg-gray-900/30 transition-colors">
                        <td class="px-4 py-2.5 text-xs text-gray-200 font-mono">@u.Username</td>
                        <td class="px-4 py-2.5 text-xs text-gray-300">@u.DisplayName</td>
                        <td class="px-4 py-2.5">
                            <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium
                                @(u.Role == "admin"
                                    ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20"
                                    : u.Role == "developer"
                                        ? "bg-blue-500/10 text-blue-300 border border-blue-500/20"
                                        : "bg-gray-800 text-gray-400")">
                                @u.Role
                            </span>
                        </td>
                        <td class="px-4 py-2.5 text-xs text-gray-500 font-mono">@(u.LastLoginAt?.ToString("MMM dd HH:mm") ?? "Never")</td>
                        <td class="px-4 py-2.5">
                            @if (u.IsActive)
                            {
                                <span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span>
                            }
                            else
                            {
                                <span class="w-2 h-2 rounded-full bg-gray-700 inline-block"></span>
                            }
                        </td>
                        <td class="px-4 py-2.5">
                            @if (u.Username != currentUsername)
                            {
                                <div class="flex items-center gap-2">
                                    <button @onclick="() => RequestResetPassword(u)" disabled="@IsBusy($"reset-{u.Id}")" class="text-xs text-gray-500 hover:text-cyan-300 transition-colors disabled:opacity-40">
                                        @(IsBusy($"reset-{u.Id}") ? "Resetting…" : "Reset Password")
                                    </button>
                                    <button @onclick="() => RequestDeleteUser(u)" disabled="@IsBusy($"user-{u.Id}")" class="text-xs text-gray-600 hover:text-rose-400 transition-colors disabled:opacity-40">
                                        @(IsBusy($"user-{u.Id}") ? "Deleting…" : "Delete")
                                    </button>
                                </div>
                            }
                        </td>
                    </tr>
                }

                @if (showResetDialog)
                {
                    <div class="fixed inset-0 z-50 bg-black/70 backdrop-blur-sm flex items-center justify-center p-4">
                        <div class="w-full max-w-md border border-gray-800 bg-gray-900 rounded-xl p-4 space-y-3 shadow-2xl transition-all duration-200">
                            <h3 class="text-sm font-semibold text-white">Reset password</h3>
                            <p class="text-xs text-gray-400">Set a new password for <span class="text-gray-200">@resetTargetName</span>.</p>
                            <div class="space-y-2">
                                <div>
                                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">New password</label>
                                    <input type="password" @bind="resetPassword" class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white" />
                                </div>
                                <div>
                                    <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Confirm password</label>
                                    <input type="password" @bind="resetPasswordConfirm" class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white" />
                                </div>
                            </div>
                            <div class="flex items-center justify-end gap-2 pt-1">
                                <button @onclick="CloseResetDialog" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white transition-colors">Cancel</button>
                                <button @onclick="ConfirmResetPasswordAsync" disabled="@resetInProgress" class="px-3 py-1.5 text-xs font-medium bg-cyan-600 hover:bg-cyan-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                                    @(resetInProgress ? "Resetting…" : "Reset Password")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
    @if (users.Count > PageSize)
    {
        <div class="mt-3 flex items-center justify-between text-xs">
            <span class="text-gray-500">Page @currentPage / @TotalPages</span>
            <div class="flex items-center gap-2">
                <button @onclick="PrevPage" disabled="@(currentPage <= 1)" class="px-2.5 py-1 border border-gray-800 rounded text-gray-300 disabled:opacity-40">Previous</button>
                <button @onclick="NextPage" disabled="@(currentPage >= TotalPages)" class="px-2.5 py-1 border border-gray-800 rounded text-gray-300 disabled:opacity-40">Next</button>
            </div>
        </div>
    }
</div>

@if (showDeleteDialog)
{
    <div class="fixed inset-0 z-50 bg-black/70 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="w-full max-w-md border border-gray-800 bg-gray-900 rounded-xl p-4 space-y-3 shadow-2xl transition-all duration-200">
            <h3 class="text-sm font-semibold text-white">Confirm delete</h3>
            <p class="text-xs text-gray-400">Delete user <span class="text-gray-200">@deleteTargetName</span>? This action cannot be undone.</p>
            <div class="flex items-center justify-end gap-2 pt-1">
                <button @onclick="CloseDeleteDialog" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white transition-colors">Cancel</button>
                <button @onclick="ConfirmDeleteUserAsync" disabled="@deleteInProgress" class="px-3 py-1.5 text-xs font-medium bg-rose-600 hover:bg-rose-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                    @(deleteInProgress ? "Deleting…" : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<AdminUser> users = [];
    private bool showAdd;
    private string newUsername = "";
    private string newPassword = "";
    private string newDisplayName = "";
    private string newRole = "analyst";
    private string? currentUsername;
    private int currentPage = 1;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)users.Count / PageSize));
    private IEnumerable<AdminUser> PagedUsers => users.Skip((currentPage - 1) * PageSize).Take(PageSize);
    private bool creatingUser;
    private string? feedbackMessage;
    private string feedbackKind = "success";
    private readonly HashSet<string> busyActionKeys = [];
    private bool showDeleteDialog;
    private bool deleteInProgress;
    private string deleteTargetId = "";
    private string deleteTargetName = "";
    private bool showResetDialog;
    private bool resetInProgress;
    private string resetTargetId = "";
    private string resetTargetName = "";
    private string resetPassword = "";
    private string resetPasswordConfirm = "";

    protected override async Task OnInitializedAsync()
    {
        users = await UserStore.GetAllAsync();
        var authState = await AuthState.GetAuthenticationStateAsync();
        currentUsername = authState.User.Identity?.Name;
        currentPage = Math.Min(currentPage, TotalPages);
    }

    private async Task CreateUser()
    {
        if (string.IsNullOrWhiteSpace(newUsername) || string.IsNullOrWhiteSpace(newPassword))
        {
            SetFeedback("Username and password are required.", "error");
            return;
        }

        creatingUser = true;
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var user = authState.User;

            var newUser = new AdminUser
            {
                Username = newUsername,
                PasswordHash = BCrypt.Net.BCrypt.HashPassword(newPassword),
                DisplayName = newDisplayName,
                Role = newRole
            };

            await UserStore.SaveAsync(newUser);
            await AuditStore.LogAsync(new AuditLog
            {
                UserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
                Username = user.Identity?.Name ?? "unknown",
                Action = "create",
                ResourceType = "user",
                ResourceId = newUser.Id,
                Details = $"Created user: {newUsername} ({newRole})",
                IpAddress = ""
            });

            newUsername = "";
            newPassword = "";
            newDisplayName = "";
            newRole = "analyst";
            showAdd = false;
            users = await UserStore.GetAllAsync();
            currentPage = Math.Min(currentPage, TotalPages);
            SetFeedback("User created.");
        }
        catch (Exception ex)
        {
            SetFeedback($"Failed to create user: {ex.Message}", "error");
        }
        finally
        {
            creatingUser = false;
        }
    }

    private void RequestDeleteUser(AdminUser user)
    {
        deleteTargetId = user.Id;
        deleteTargetName = user.Username;
        showDeleteDialog = true;
    }

    private void RequestResetPassword(AdminUser user)
    {
        resetTargetId = user.Id;
        resetTargetName = user.Username;
        resetPassword = "";
        resetPasswordConfirm = "";
        showResetDialog = true;
    }

    private void CloseDeleteDialog()
    {
        if (deleteInProgress) return;
        showDeleteDialog = false;
        deleteTargetId = "";
        deleteTargetName = "";
    }

    private void CloseResetDialog()
    {
        if (resetInProgress) return;
        showResetDialog = false;
        resetTargetId = "";
        resetTargetName = "";
        resetPassword = "";
        resetPasswordConfirm = "";
    }

    private async Task ConfirmDeleteUserAsync()
    {
        var key = $"user-{deleteTargetId}";
        if (!busyActionKeys.Add(key)) return;
        deleteInProgress = true;
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var user = authState.User;

            await UserStore.DeleteAsync(deleteTargetId);
            await AuditStore.LogAsync(new AuditLog
            {
                UserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
                Username = user.Identity?.Name ?? "unknown",
                Action = "delete",
                ResourceType = "user",
                ResourceId = deleteTargetId,
                IpAddress = ""
            });

            users = await UserStore.GetAllAsync();
            currentPage = Math.Min(currentPage, TotalPages);
            SetFeedback("User deleted.");
            showDeleteDialog = false;
            deleteTargetId = "";
            deleteTargetName = "";
        }
        catch (Exception ex)
        {
            SetFeedback($"Failed to delete user: {ex.Message}", "error");
        }
        finally
        {
            deleteInProgress = false;
            busyActionKeys.Remove(key);
        }
    }

    private async Task ConfirmResetPasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(resetTargetId))
            return;

        if (string.IsNullOrWhiteSpace(resetPassword) || resetPassword.Length < 8)
        {
            SetFeedback("New password must be at least 8 characters.", "error");
            return;
        }

        if (!string.Equals(resetPassword, resetPasswordConfirm, StringComparison.Ordinal))
        {
            SetFeedback("Passwords do not match.", "error");
            return;
        }

        var key = $"reset-{resetTargetId}";
        if (!busyActionKeys.Add(key)) return;

        resetInProgress = true;
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var actor = authState.User;
            var target = users.FirstOrDefault(u => u.Id == resetTargetId);
            if (target is null)
            {
                SetFeedback("User not found.", "error");
                return;
            }

            target.PasswordHash = BCrypt.Net.BCrypt.HashPassword(resetPassword);
            target.PasswordResetToken = null;
            target.PasswordResetTokenExpiry = null;
            await UserStore.SaveAsync(target);

            await AuditStore.LogAsync(new AuditLog
            {
                UserId = actor.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
                Username = actor.Identity?.Name ?? "unknown",
                Action = "reset_password",
                ResourceType = "user",
                ResourceId = resetTargetId,
                Details = $"Password reset for {target.Username}",
                IpAddress = ""
            });

            SetFeedback($"Password reset for {target.Username}.");
            showResetDialog = false;
            resetTargetId = "";
            resetTargetName = "";
            resetPassword = "";
            resetPasswordConfirm = "";
        }
        catch (Exception ex)
        {
            SetFeedback($"Failed to reset password: {ex.Message}", "error");
        }
        finally
        {
            resetInProgress = false;
            busyActionKeys.Remove(key);
        }
    }

    private void PrevPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private bool IsBusy(string key) => busyActionKeys.Contains(key);

    private void SetFeedback(string message, string kind = "success")
    {
        feedbackMessage = message;
        feedbackKind = kind;
    }

    private void ClearFeedback() => feedbackMessage = null;

    private string FeedbackClass() => feedbackKind switch
    {
        "error" => "rounded-lg border border-rose-500/40 bg-rose-500/10 px-3 py-2 text-xs text-rose-300",
        "info" => "rounded-lg border border-blue-500/40 bg-blue-500/10 px-3 py-2 text-xs text-blue-300",
        _ => "rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-2 text-xs text-emerald-300"
    };
}
