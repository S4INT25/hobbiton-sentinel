@page "/admin/cases/{Id}"
@inject ICaseStore CaseStore
@inject IFeedbackRuleStore RuleStore
@inject ICaseOutcomeStore OutcomeStore
@inject IAuditLogStore AuditStore
@inject AuthenticationStateProvider AuthState
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@attribute [Authorize(Policy = AuthConstants.AdminOnlyPolicy)]

<PageTitle>Case @(fraudCase?.Id?[..8]) — Sentinel</PageTitle>

<div class="space-y-4">
    <div class="flex items-center gap-3">
        <a href="/admin/cases" class="text-gray-500 hover:text-gray-300 text-sm">← Cases</a>
        <h1 class="text-lg font-semibold text-white">@fraudCase?.Title</h1>
    </div>

    @if (fraudCase != null)
    {
        var c = fraudCase;
        <div class="grid grid-cols-5 gap-3 text-xs">
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Severity</div>
                <div class="text-white font-medium">@c.Severity</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Status</div>
                <div class="text-white">@c.Status</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Confidence</div>
                <div class="text-white font-medium">@c.Confidence%</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Created</div>
                <div class="text-white font-mono">@c.FirstSeen.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
                <div class="text-gray-500 mb-0.5">Last Seen</div>
                <div class="text-white font-mono">@c.LastSeen.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
        </div>

        <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/30">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-2">Notes</div>
            <pre class="text-xs text-gray-300 font-mono whitespace-pre-wrap">@c.Notes</pre>
        </div>

        @if (c.FollowUpQueries.Any())
        {
            <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/30">
                <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-2">Follow-Up Queries</div>
                @foreach (var q in c.FollowUpQueries)
                {
                    <pre class="text-xs text-gray-400 font-mono whitespace-pre-wrap mb-2">@q</pre>
                }
            </div>
        }

        <!-- Feedback Actions -->
        <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/50 space-y-3">
            <div class="text-xs font-medium text-gray-300">Actions</div>
            <div class="flex gap-2">
                <button @onclick="() => showFpForm = !showFpForm" type="button"
                        class="px-3 py-1.5 text-xs bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-md border border-gray-700 transition-colors">
                    Mark False Positive
                </button>
                <button @onclick="EscalateCase"
                        class="px-3 py-1.5 text-xs bg-rose-600/20 hover:bg-rose-600/30 text-rose-400 rounded-md border border-rose-500/30 transition-colors">
                    Escalate
                </button>
                <button @onclick="ResolveCase"
                        class="px-3 py-1.5 text-xs bg-emerald-600/20 hover:bg-emerald-600/30 text-emerald-400 rounded-md border border-emerald-500/30 transition-colors">
                    Resolve
                </button>
            </div>

            @if (showFpForm)
            {
                <div class="border border-gray-800 rounded-lg p-4 bg-gray-900/70 space-y-3 mt-3">
                    <div class="text-xs text-gray-400">Mark as false positive and optionally create a suppression rule so this doesn't get flagged again.</div>
                    <div class="space-y-3">
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Reason</label>
                            <input type="text" @bind="fpReason" required
                                   class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white"
                                   placeholder="Why this is not fraud..." />
                        </div>

                        <div>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" @bind="createRule"
                                       class="rounded border-gray-700 bg-gray-900 text-emerald-500 focus:ring-emerald-500/20" />
                                <span class="text-xs text-gray-300">Create suppression rule to prevent future flags</span>
                            </label>

                            @if (createRule)
                            {
                                <div class="grid grid-cols-2 gap-3 mt-3">
                                    <div>
                                        <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Rule Type</label>
                                        <select @bind="fpRuleType" class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                                            <option value="ip">IP Address</option>
                                            <option value="cidr">CIDR Range</option>
                                            <option value="asn">ASN</option>
                                            <option value="pattern_id">Pattern ID</option>
                                            <option value="keyword">Keyword</option>
                                            <option value="recipient">Recipient</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Match Value</label>
                                        <input type="text" @bind="fpMatchValue"
                                               class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white"
                                               placeholder="e.g. 159.89.x.x or AS14061" />
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="flex gap-2">
                            <button @onclick="HandleFalsePositive" class="px-3 py-1.5 text-xs font-medium bg-gray-700 hover:bg-gray-600 text-white rounded-md transition-colors">
                                Confirm False Positive
                            </button>
                            <button @onclick="() => showFpForm = false" class="px-3 py-1.5 text-xs text-gray-500 hover:text-gray-300">
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-8 text-gray-600 text-sm">Case not found</div>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    private FraudCase? fraudCase;
    private bool showFpForm;
    private string fpReason = "";
    private bool createRule = true;
    private string fpRuleType = "ip";
    private string fpMatchValue = "";

    protected override async Task OnInitializedAsync()
    {
        fraudCase = await CaseStore.GetCaseAsync(Id);
    }

    private Task EscalateCase() => HandleFeedback("escalate");
    private Task ResolveCase() => HandleFeedback("resolve");

    private async Task HandleFeedback(string action)
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;

        switch (action)
        {
            case "escalate":
                var c = await CaseStore.GetCaseAsync(Id);
                if (c != null) { c.Severity = "critical"; await CaseStore.SaveCaseAsync(c); }
                break;
            case "resolve":
                // Analyst manually resolving = confirmed fraud (they investigated and took action)
                if (fraudCase != null)
                {
                    await OutcomeStore.SaveAsync(new CaseOutcome
                    {
                            CaseId = Id,
                            Title = fraudCase.Title,
                            Category = fraudCase.Category,
                            Outcome = "confirmed_fraud",
                            OriginalSeverity = fraudCase.Severity,
                            Confidence = fraudCase.Confidence,
                            AffectedEntities = string.Join(", ", fraudCase.AffectedEntities),
                            WorkflowId = fraudCase.WorkflowId,
                            Resolution = "Manually resolved by analyst — confirmed fraud",
                            ResolvedBy = user.Identity?.Name ?? "analyst",
                            OccurrenceCount = fraudCase.OccurrenceCount
                    });
                }
                await CaseStore.ResolveCaseAsync(Id, "Manually resolved by analyst");
                break;
        }

        await AuditStore.LogAsync(new AuditLog
        {
            UserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "",
            Username = user.Identity?.Name ?? "unknown",
            Action = $"case_{action}",
            ResourceType = "case",
            ResourceId = Id,
            IpAddress = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? ""
        });

        fraudCase = await CaseStore.GetCaseAsync(Id);
    }

    private async Task HandleFalsePositive()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;

        // Save outcome as false_positive for historical learning
        if (fraudCase != null)
        {
            await OutcomeStore.SaveAsync(new CaseOutcome
            {
                    CaseId = Id,
                    Title = fraudCase.Title,
                    Category = fraudCase.Category,
                    Outcome = "false_positive",
                    OriginalSeverity = fraudCase.Severity,
                    Confidence = fraudCase.Confidence,
                    AffectedEntities = string.Join(", ", fraudCase.AffectedEntities),
                    WorkflowId = fraudCase.WorkflowId,
                    Resolution = $"False positive: {fpReason}",
                    ResolvedBy = user.Identity?.Name ?? "analyst",
                    OccurrenceCount = fraudCase.OccurrenceCount
            });
        }

        await CaseStore.ResolveCaseAsync(Id, $"False positive: {fpReason}");

        if (createRule && !string.IsNullOrWhiteSpace(fpRuleType) && !string.IsNullOrWhiteSpace(fpMatchValue))
        {
            var rule = new FeedbackRule
            {
                RuleType = fpRuleType,
                MatchValue = fpMatchValue,
                Action = "suppress",
                Reason = fpReason,
                CreatedBy = user.Identity?.Name ?? "unknown",
                SourceCaseId = Id
            };
            await RuleStore.SaveAsync(rule);

            await AuditStore.LogAsync(new AuditLog
            {
                UserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "",
                Username = user.Identity?.Name ?? "unknown",
                Action = "create",
                ResourceType = "rule",
                ResourceId = rule.Id,
                Details = $"From case {Id}: {fpRuleType}={fpMatchValue}",
                IpAddress = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? ""
            });
        }

        await AuditStore.LogAsync(new AuditLog
        {
            UserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "",
            Username = user.Identity?.Name ?? "unknown",
            Action = "case_false_positive",
            ResourceType = "case",
            ResourceId = Id,
            Details = fpReason,
            IpAddress = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? ""
        });

        Navigation.NavigateTo("/admin/cases");
    }
}
