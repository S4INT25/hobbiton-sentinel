@page "/admin/cases"
@inject ICaseStore CaseStore
@attribute [Authorize(Policy = AuthConstants.Policy)]

<PageTitle>Cases — Sentinel</PageTitle>

<div class="space-y-4">
    <h1 class="text-lg font-semibold text-white">Cases</h1>

    <div class="border border-gray-800 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-900/50">
                <tr class="text-xs text-gray-500 border-b border-gray-800">
                    <th class="text-left px-4 py-2 font-medium">ID</th>
                    <th class="text-left px-4 py-2 font-medium">Title</th>
                    <th class="text-left px-4 py-2 font-medium">Severity</th>
                    <th class="text-left px-4 py-2 font-medium">Status</th>
                    <th class="text-left px-4 py-2 font-medium">Created</th>
                    <th class="text-left px-4 py-2 font-medium">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800/50">
                @foreach (var c in PagedCases)
                {
                    var sevColor = c.Severity switch
                    {
                        "critical" => "rose",
                        "warning" => "amber",
                        _ => "blue"
                    };
                    <tr class="hover:bg-gray-900/30 transition-colors">
                        <td class="px-4 py-2.5 font-mono text-xs text-gray-400">@c.Id[..8]</td>
                        <td class="px-4 py-2.5 text-xs text-gray-200 max-w-sm truncate">@c.Title</td>
                        <td class="px-4 py-2.5">
                            <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-@(sevColor)-500/10 text-@(sevColor)-400 border border-@(sevColor)-500/20">@c.Severity</span>
                        </td>
                        <td class="px-4 py-2.5 text-xs text-gray-500">@c.Status</td>
                        <td class="px-4 py-2.5 text-xs text-gray-500">@c.FirstSeen.ToString("MMM dd HH:mm")</td>
                        <td class="px-4 py-2.5 flex gap-2">
                            <a href="/admin/cases/@c.Id" class="text-xs text-emerald-400 hover:text-emerald-300">View</a>
                        </td>
                    </tr>
                }
                @if (!cases.Any())
                {
                    <tr><td colspan="6" class="px-4 py-8 text-center text-gray-600 text-xs">No open cases</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if (cases.Count > PageSize)
    {
        <div class="mt-3 flex items-center justify-between text-xs">
            <span class="text-gray-500">Page @currentPage / @TotalPages</span>
            <div class="flex items-center gap-2">
                <button @onclick="PrevPage" disabled="@(currentPage <= 1)" class="px-2.5 py-1 border border-gray-800 rounded text-gray-300 disabled:opacity-40">Previous</button>
                <button @onclick="NextPage" disabled="@(currentPage >= TotalPages)" class="px-2.5 py-1 border border-gray-800 rounded text-gray-300 disabled:opacity-40">Next</button>
            </div>
        </div>
    }
</div>

@code {
    private List<FraudCase> cases = [];
    private int currentPage = 1;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)cases.Count / PageSize));
    private IEnumerable<FraudCase> PagedCases => cases.Skip((currentPage - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        cases = await CaseStore.GetOpenCasesAsync();
        currentPage = Math.Min(currentPage, TotalPages);
    }

    private void PrevPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }
}
