@page "/admin/cases"
@inject ICaseStore CaseStore
@inject IAuditLogStore AuditStore
@inject AuthenticationStateProvider AuthState
@attribute [Authorize(Policy = AuthConstants.Policy)]

<PageTitle>Cases — Sentinel</PageTitle>

<div class="space-y-4">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
        <h1 class="text-lg font-semibold text-white">Cases</h1>
        <div class="flex items-center gap-3">
            <select @bind="sortOrder" @bind:after="ApplySort" class="px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white">
                <option value="severity">Sort: Severity</option>
                <option value="newest">Sort: Newest first</option>
                <option value="oldest">Sort: Oldest first</option>
            </select>
        </div>
    </div>

    @if (feedbackMessage is not null)
    {
        <div class="@FeedbackClass()" role="status">
            <div class="flex items-center justify-between gap-3">
                <span>@feedbackMessage</span>
                <button @onclick="ClearFeedback" class="text-[11px] text-gray-300 hover:text-white transition-colors">Dismiss</button>
            </div>
        </div>
    }

    <div class="border border-gray-800 rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[640px]">
            <thead class="bg-gray-900/50">
                <tr class="text-xs text-gray-500 border-b border-gray-800">
                    <th class="text-left px-4 py-2 font-medium">ID</th>
                    <th class="text-left px-4 py-2 font-medium">Title</th>
                    <th class="text-left px-4 py-2 font-medium">Severity</th>
                    <th class="text-left px-4 py-2 font-medium">Status</th>
                    <th class="text-left px-4 py-2 font-medium">Created</th>
                    <th class="text-left px-4 py-2 font-medium">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800/50">
                @foreach (var c in PagedCases)
                {
                    <tr class="hover:bg-gray-900/30 transition-colors">
                        <td class="px-4 py-2.5 font-mono text-xs text-gray-400">@c.Id[..Math.Min(8, c.Id.Length)]</td>
                        <td class="px-4 py-2.5 text-xs text-gray-200 max-w-sm truncate">@c.Title</td>
                        <td class="px-4 py-2.5">
                            <span class="@SeverityClasses(c.Severity)">@c.Severity</span>
                        </td>
                        <td class="px-4 py-2.5 text-xs text-gray-500">@c.Status</td>
                        <td class="px-4 py-2.5 text-xs text-gray-500">@c.FirstSeen.ToString("MMM dd HH:mm")</td>
                        <td class="px-4 py-2.5">
                            <div class="flex items-center gap-2">
                                <a href="/admin/cases/@c.Id" class="text-xs text-emerald-400 hover:text-emerald-300 transition-colors">View</a>
                                <button @onclick="() => RequestResolveCase(c)" disabled="@IsCaseBusy(c.Id)" class="text-xs text-gray-500 hover:text-emerald-400 transition-colors disabled:opacity-40">
                                    Resolve
                                </button>
                                <button @onclick="() => RequestDeleteCase(c)" disabled="@IsCaseBusy(c.Id)" class="text-xs text-gray-600 hover:text-rose-400 transition-colors disabled:opacity-40">
                                    @(IsBusy($"case-delete-{c.Id}") ? "Deleting…" : "Delete")
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!cases.Any())
                {
                    <tr><td colspan="6" class="px-4 py-8 text-center text-gray-600 text-xs">No open cases</td></tr>
                }
            </tbody>
        </table>
        </div>
    </div>
    @if (cases.Count > PageSize)
    {
        <div class="mt-3 flex items-center justify-between text-xs">
            <span class="text-gray-500">@cases.Count cases · page @currentPage of @TotalPages</span>
            <div class="flex items-center gap-2">
                <button @onclick="PrevPage" disabled="@(currentPage <= 1)" class="px-2.5 py-1 border border-gray-800 rounded text-gray-300 disabled:opacity-40 transition-colors hover:border-gray-700">Previous</button>
                <button @onclick="NextPage" disabled="@(currentPage >= TotalPages)" class="px-2.5 py-1 border border-gray-800 rounded text-gray-300 disabled:opacity-40 transition-colors hover:border-gray-700">Next</button>
            </div>
        </div>
    }
</div>

@if (showDeleteDialog)
{
    <div class="fixed inset-0 z-50 bg-black/70 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="w-full max-w-md border border-gray-800 bg-gray-900 rounded-xl p-4 space-y-3 shadow-2xl transition-all duration-200">
            <h3 class="text-sm font-semibold text-white">Confirm delete</h3>
            <p class="text-xs text-gray-400">Delete case <span class="text-gray-200 font-mono">@deleteTargetName</span>? This action cannot be undone.</p>
            <div class="flex items-center justify-end gap-2 pt-1">
                <button @onclick="CloseDeleteDialog" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white transition-colors">Cancel</button>
                <button @onclick="ConfirmDeleteCaseAsync" disabled="@deleteInProgress" class="px-3 py-1.5 text-xs font-medium bg-rose-600 hover:bg-rose-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                    @(deleteInProgress ? "Deleting…" : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@if (showResolveDialog)
{
    <div class="fixed inset-0 z-50 bg-black/70 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="w-full max-w-md border border-gray-800 bg-gray-900 rounded-xl p-4 space-y-3 shadow-2xl transition-all duration-200">
            <h3 class="text-sm font-semibold text-white">Resolve case</h3>
            <p class="text-xs text-gray-400">Resolve case <span class="text-gray-200 font-mono">@resolveTargetName</span> directly from this list.</p>
            <div>
                <label class="block text-[10px] text-gray-500 uppercase tracking-wider mb-1">Resolution note</label>
                <input type="text" @bind="resolveReason" class="w-full px-2.5 py-1.5 bg-gray-900 border border-gray-800 rounded text-xs text-white" />
            </div>
            <div class="flex items-center justify-end gap-2 pt-1">
                <button @onclick="CloseResolveDialog" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white transition-colors">Cancel</button>
                <button @onclick="ConfirmResolveCaseAsync" disabled="@resolveInProgress" class="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-500 text-white rounded-md transition-all duration-200 disabled:opacity-50">
                    @(resolveInProgress ? "Resolving…" : "Resolve")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<FraudCase> cases = [];
    private int currentPage = 1;
    private const int PageSize = 15;
    private string sortOrder = "newest";
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)cases.Count / PageSize));
    private IEnumerable<FraudCase> PagedCases => cases.Skip((currentPage - 1) * PageSize).Take(PageSize);
    private string? feedbackMessage;
    private string feedbackKind = "success";
    private readonly HashSet<string> busyActionKeys = [];
    private bool showDeleteDialog;
    private bool deleteInProgress;
    private string deleteTargetId = "";
    private string deleteTargetName = "";
    private bool showResolveDialog;
    private bool resolveInProgress;
    private string resolveTargetId = "";
    private string resolveTargetName = "";
    private string resolveReason = "Manually resolved by analyst";

    protected override async Task OnInitializedAsync()
    {
        await LoadCases();
    }

    private async Task LoadCases()
    {
        cases = await CaseStore.GetOpenCasesAsync();
        ApplySort();
        currentPage = Math.Min(currentPage, TotalPages);
    }

    private void ApplySort()
    {
        cases = sortOrder switch
        {
            "newest" => cases.OrderByDescending(c => c.FirstSeen).ToList(),
            "oldest" => cases.OrderBy(c => c.FirstSeen).ToList(),
            _ => cases.OrderByDescending(c => c.Severity switch
            {
                "critical" => 4, "high" => 3, "medium" => 2, _ => 1
            }).ToList()
        };
        currentPage = 1;
    }

    private void RequestDeleteCase(FraudCase c)
    {
        deleteTargetId = c.Id;
        deleteTargetName = c.Id[..Math.Min(8, c.Id.Length)];
        showDeleteDialog = true;
    }

    private void CloseDeleteDialog()
    {
        if (deleteInProgress) return;
        showDeleteDialog = false;
        deleteTargetId = "";
        deleteTargetName = "";
    }

    private async Task ConfirmDeleteCaseAsync()
    {
        var key = $"case-delete-{deleteTargetId}";
        if (!busyActionKeys.Add(key)) return;
        deleteInProgress = true;
        try
        {
            await CaseStore.DeleteCaseAsync(deleteTargetId);

            var authState = await AuthState.GetAuthenticationStateAsync();
            var user = authState.User;
            await AuditStore.LogAsync(new AuditLog
            {
                UserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
                Username = user.Identity?.Name ?? "unknown",
                Action = "delete",
                ResourceType = "case",
                ResourceId = deleteTargetId,
                Details = "Case deleted by admin",
                IpAddress = ""
            });

            await LoadCases();
            SetFeedback("Case deleted.");
            showDeleteDialog = false;
            deleteTargetId = "";
            deleteTargetName = "";
        }
        catch (Exception ex)
        {
            SetFeedback($"Failed to delete case: {ex.Message}", "error");
        }
        finally
        {
            deleteInProgress = false;
            busyActionKeys.Remove(key);
        }
    }

    private void RequestResolveCase(FraudCase c)
    {
        resolveTargetId = c.Id;
        resolveTargetName = c.Id[..Math.Min(8, c.Id.Length)];
        resolveReason = "Manually resolved by analyst";
        showResolveDialog = true;
    }

    private void CloseResolveDialog()
    {
        if (resolveInProgress) return;
        showResolveDialog = false;
        resolveTargetId = "";
        resolveTargetName = "";
    }

    private async Task ConfirmResolveCaseAsync()
    {
        var key = $"case-resolve-{resolveTargetId}";
        if (!busyActionKeys.Add(key)) return;
        resolveInProgress = true;
        try
        {
            await CaseStore.ResolveCaseAsync(resolveTargetId, resolveReason);

            var authState = await AuthState.GetAuthenticationStateAsync();
            var user = authState.User;
            await AuditStore.LogAsync(new AuditLog
            {
                UserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
                Username = user.Identity?.Name ?? "unknown",
                Action = "case_resolve",
                ResourceType = "case",
                ResourceId = resolveTargetId,
                Details = resolveReason,
                IpAddress = ""
            });

            await LoadCases();
            SetFeedback("Case resolved.");
            showResolveDialog = false;
            resolveTargetId = "";
            resolveTargetName = "";
        }
        catch (Exception ex)
        {
            SetFeedback($"Failed to resolve case: {ex.Message}", "error");
        }
        finally
        {
            resolveInProgress = false;
            busyActionKeys.Remove(key);
        }
    }

    private static string SeverityClasses(string severity) => severity switch
    {
        "critical" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-rose-500/10 text-rose-400 border border-rose-500/20",
        "high" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-orange-500/10 text-orange-400 border border-orange-500/20",
        "warning" or "medium" => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-500/10 text-amber-400 border border-amber-500/20",
        _ => "inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20"
    };

    private void PrevPage() { if (currentPage > 1) currentPage--; }
    private void NextPage() { if (currentPage < TotalPages) currentPage++; }

    private bool IsBusy(string key) => busyActionKeys.Contains(key);
    private bool IsCaseBusy(string caseId) =>
        IsBusy($"case-delete-{caseId}") || IsBusy($"case-resolve-{caseId}");

    private void SetFeedback(string message, string kind = "success")
    {
        feedbackMessage = message;
        feedbackKind = kind;
    }

    private void ClearFeedback() => feedbackMessage = null;

    private string FeedbackClass() => feedbackKind switch
    {
        "error" => "rounded-lg border border-rose-500/40 bg-rose-500/10 px-3 py-2 text-xs text-rose-300",
        "info" => "rounded-lg border border-blue-500/40 bg-blue-500/10 px-3 py-2 text-xs text-blue-300",
        _ => "rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-2 text-xs text-emerald-300"
    };
}
