@page "/admin/forgot-password"
@layout EmptyLayout
@attribute [AllowAnonymous]

@code {
    [SupplyParameterFromQuery(Name = "sent")]
    public string? Sent { get; set; }
}

<PageTitle>Forgot password — Sentinel</PageTitle>

<div class="h-full flex items-center justify-center">
    <div class="w-full max-w-sm px-6">
        <div class="text-center mb-8">
            <img src="https://hobbiton.tech/assets/logo2-7db998ca.png" alt="Hobbiton logo" class="w-50 h-24 mx-auto mb-3 rounded-lg object-contain" />
            <h1 class="text-lg font-semibold text-white">Sentinel</h1>
            <p class="text-sm text-gray-500 mt-1">Reset your password</p>
        </div>

        @if (Sent == "1")
        {
            <div class="mb-4 p-4 rounded-md bg-emerald-500/10 border border-emerald-500/20 text-sm text-emerald-400 text-center space-y-1">
                <p class="font-medium">Check your inbox</p>
                <p class="text-xs text-emerald-500">If that email exists, a reset link has been sent. It expires in 1 hour.</p>
            </div>
            <p class="mt-4 text-center text-xs text-gray-500">
                <a href="/admin/login" class="text-emerald-400 hover:text-emerald-300">Back to sign in</a>
            </p>
        }
        else
        {
            <form action="/admin/auth/forgot-password" method="post" class="space-y-4">
                <div>
                    <label class="block text-xs font-medium text-gray-400 mb-1.5">Work email</label>
                    <input type="email" name="email" required autocomplete="email" autofocus
                           placeholder="you@hobbiton.co.zm"
                           class="w-full px-3 py-2 bg-gray-900 border border-gray-800 rounded-md text-sm text-white placeholder-gray-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20" />
                </div>
                <button type="submit"
                        class="w-full py-2 px-4 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-md transition-colors">
                    Send reset link
                </button>
            </form>

            <p class="mt-6 text-center text-xs text-gray-500">
                Remembered it?
                <a href="/admin/login" class="text-emerald-400 hover:text-emerald-300">Sign in</a>
            </p>
        }
    </div>
</div>
